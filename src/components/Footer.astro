---
---

<footer class="bg-[var(--ehren-blue)] border-t border-white/10 pt-20 pb-10 text-slate-300 mt-auto">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 lg:gap-8 mb-16">
            
            <!-- Brand Column -->
            <div class="space-y-6">
                <a href="/" class="flex items-center gap-3 flex-shrink-0 group inline-flex">
                    <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-[var(--ehren-accent)] to-[var(--ehren-blue-light)] flex items-center justify-center text-white shadow-lg">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                            <path d="M9 12l2 2 4-4"/>
                        </svg>
                    </div>
                    <span class="text-2xl font-extrabold tracking-tight text-white">
                        Ehren-<span class="text-[var(--ehren-accent)]">Deal</span>
                    </span>
                </a>
                <p class="text-sm leading-relaxed text-slate-400">
                    Deutschlands sicherste C2C-Plattform für lokale Deals. Handeln mit digitalem Handschlag, verifizierten Identitäten und integriertem Käuferschutz.
                </p>
                <div class="flex flex-wrap gap-2 pt-2">
                    <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-blue-500/10 text-blue-400 text-xs font-bold border border-blue-500/20">
                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
                        SSL-Verschlüsselt
                    </span>
                    <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-green-500/10 text-green-400 text-xs font-bold border border-green-500/20">
                        <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path></svg>
                        IDnow Verifiziert
                    </span>
                </div>
            </div>

            <!-- Links: Käufer -->
            <div class="lg:ml-auto">
                <h4 class="text-white font-bold tracking-wider text-sm uppercase mb-5">Für Käufer</h4>
                <ul class="space-y-3.5">
                    <li><a href="/" class="text-sm text-slate-400 hover:text-white transition-colors">Angebote entdecken</a></li>
                    <li><a href="/sicherheit" class="text-sm text-slate-400 hover:text-white transition-colors">Käuferschutz</a></li>
                    <li><a href="/sicherheit#handshake" class="text-sm text-slate-400 hover:text-white transition-colors">Der Ehren-Handschlag</a></li>
                    <li><a href="/sicherheit#tipps" class="text-sm text-slate-400 hover:text-white transition-colors">Sicherheitstipps</a></li>
                </ul>
            </div>

            <!-- Links: Verkäufer -->
            <div>
                <h4 class="text-white font-bold tracking-wider text-sm uppercase mb-5">Für Verkäufer</h4>
                <ul class="space-y-3.5">
                    <li><a href="/inserat-erstellen" class="text-sm text-[var(--ehren-accent)] hover:text-white font-semibold transition-colors">Anzeige aufgeben</a></li>
                    <li><a href="/anmelden" class="text-sm text-slate-400 hover:text-white transition-colors">Identität bestätigen</a></li>
                    <li><a href="/profil" class="text-sm text-slate-400 hover:text-white transition-colors">Trust Score aufbauen</a></li>
                    <li><a href="/sicherheit#treuhand" class="text-sm text-slate-400 hover:text-white transition-colors">Treuhand Abwicklung</a></li>
                </ul>
            </div>

            <!-- Links: Legal -->
            <div>
                <h4 class="text-white font-bold tracking-wider text-sm uppercase mb-5">Unternehmen</h4>
                <ul class="space-y-3.5">
                    <li><a href="/ueber-uns" class="text-sm text-slate-400 hover:text-white transition-colors">Über uns</a></li>
                    <li><a href="/kontakt" class="text-sm text-slate-400 hover:text-white transition-colors">Kontakt & Support</a></li>
                    <li><a href="/agb" class="text-sm text-slate-400 hover:text-white transition-colors">AGB</a></li>
                    <li><a href="/datenschutz" class="text-sm text-slate-400 hover:text-white transition-colors">Datenschutz</a></li>
                    <li><a href="/impressum" class="text-sm text-slate-400 hover:text-white transition-colors">Impressum</a></li>
                </ul>
            </div>
        </div>

        <!-- Footer Bottom -->
        <div class="pt-8 border-t border-white/10 flex flex-col md:flex-row items-center justify-between gap-6">
            <p class="text-sm text-slate-500">
                &copy; 2026 Ehren-Deal GmbH. Alle Rechte vorbehalten.
            </p>
            <div class="flex flex-wrap items-center justify-center gap-3">
                <span class="px-3 py-1.5 rounded-lg bg-white/5 border border-white/10 text-xs font-semibold text-slate-300">Treuhand</span>
                <span class="px-3 py-1.5 rounded-lg bg-white/5 border border-white/10 text-xs font-semibold text-slate-300">Apple Pay</span>
                <span class="px-3 py-1.5 rounded-lg bg-white/5 border border-white/10 text-xs font-semibold text-slate-300">Google Pay</span>
                <span class="px-3 py-1.5 rounded-lg bg-white/5 border border-white/10 text-xs font-semibold text-slate-300">SEPA</span>
            </div>
        </div>
    </div>
</footer>
