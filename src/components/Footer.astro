---
---

<footer class="border-t border-foreground/[.04] mt-auto">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 lg:gap-8 mb-14">

            <!-- Brand -->
            <div class="space-y-4">
                <a href="/" class="inline-flex items-center gap-3">
                    <div class="footer-medallion">
                        <svg class="footer-ring" viewBox="0 0 140 140" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <defs><path id="frp" d="M70,70 m-52,0 a52,52 0 1,1 104,0 a52,52 0 1,1-104,0"/></defs>
                            <text font-family="Barlow Condensed, sans-serif" font-size="8.8" fill="#c8973a" letter-spacing="5.2" font-weight="400" opacity=".45">
                                <textPath href="#frp">EHREN-DEAL  ·  HANDELN MIT HANDSCHLAG  ·  </textPath>
                            </text>
                            <circle cx="70" cy="70" r="61" stroke="#c8973a" stroke-width=".4" opacity=".1"/>
                        </svg>
                        <div class="footer-medal-inner">
                            <svg viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg" style="width:24px;height:24px;">
                                <path d="M4 20 L13 14 L19 18 L21 18 L27 14 L36 20" stroke="#c8973a" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
                                <path d="M13 14 L13 27" stroke="#c8973a" stroke-width="1.4" stroke-linecap="round" opacity=".4"/>
                                <path d="M27 14 L27 27" stroke="#c8973a" stroke-width="1.4" stroke-linecap="round" opacity=".4"/>
                                <path d="M19 18 L19 28" stroke="#c8973a" stroke-width="1.4" stroke-linecap="round" opacity=".6"/>
                                <path d="M21 18 L21 28" stroke="#c8973a" stroke-width="1.4" stroke-linecap="round" opacity=".6"/>
                                <line x1="13" y1="27" x2="27" y2="27" stroke="#c8973a" stroke-width="1.4" stroke-linecap="round" opacity=".3"/>
                                <circle cx="20" cy="9" r="1.2" fill="#c8973a" opacity=".5"/>
                            </svg>
                        </div>
                    </div>
                    <span class="font-condensed font-medium text-sm tracking-[.12em] uppercase text-foreground">
                        Ehren‑Deal
                    </span>
                </a>
                <p class="text-sm leading-relaxed text-foreground/35 font-light">
                    Deutschlands sicherste C2C-Plattform für lokale Deals mit digitalem Handschlag und Identitätsprüfung.
                </p>
            </div>

            <!-- Käufer -->
            <div class="lg:ml-auto">
                <h4 class="font-condensed font-medium text-xs tracking-[.1em] uppercase text-foreground/50 mb-5">Für Käufer</h4>
                <ul class="space-y-2.5">
                    <li><a href="/" class="text-sm text-foreground/40 hover:text-primary transition-colors font-light">Angebote entdecken</a></li>
                    <li><a href="/sicherheit" class="text-sm text-foreground/40 hover:text-primary transition-colors font-light">Käuferschutz</a></li>
                    <li><a href="/sicherheit#handshake" class="text-sm text-foreground/40 hover:text-primary transition-colors font-light">Der Ehren-Handschlag</a></li>
                    <li><a href="/sicherheit#tipps" class="text-sm text-foreground/40 hover:text-primary transition-colors font-light">Sicherheitstipps</a></li>
                </ul>
            </div>

            <!-- Verkäufer -->
            <div>
                <h4 class="font-condensed font-medium text-xs tracking-[.1em] uppercase text-foreground/50 mb-5">Für Verkäufer</h4>
                <ul class="space-y-2.5">
                    <li><a href="/inserat-erstellen" class="text-sm text-primary/80 hover:text-primary font-light transition-colors">Anzeige aufgeben</a></li>
                    <li><a href="/anmelden" class="text-sm text-foreground/40 hover:text-primary transition-colors font-light">Identität bestätigen</a></li>
                    <li><a href="/profil" class="text-sm text-foreground/40 hover:text-primary transition-colors font-light">Trust Score aufbauen</a></li>
                    <li><a href="/sicherheit#treuhand" class="text-sm text-foreground/40 hover:text-primary transition-colors font-light">Treuhand Abwicklung</a></li>
                </ul>
            </div>

            <!-- Legal -->
            <div>
                <h4 class="font-condensed font-medium text-xs tracking-[.1em] uppercase text-foreground/50 mb-5">Unternehmen</h4>
                <ul class="space-y-2.5">
                    <li><a href="/ueber-uns" class="text-sm text-foreground/40 hover:text-primary transition-colors font-light">Über uns</a></li>
                    <li><a href="/kontakt" class="text-sm text-foreground/40 hover:text-primary transition-colors font-light">Kontakt & Support</a></li>
                    <li><a href="/agb" class="text-sm text-foreground/40 hover:text-primary transition-colors font-light">AGB</a></li>
                    <li><a href="/datenschutz" class="text-sm text-foreground/40 hover:text-primary transition-colors font-light">Datenschutz</a></li>
                    <li><a href="/impressum" class="text-sm text-foreground/40 hover:text-primary transition-colors font-light">Impressum</a></li>
                </ul>
            </div>
        </div>

        <!-- Bottom -->
        <div class="pt-6 border-t border-foreground/[.04] flex flex-col md:flex-row items-center justify-between gap-4">
            <p class="text-xs text-foreground/25 font-light font-condensed tracking-wider uppercase">
                &copy; 2025 Ehren‑Deal
            </p>
            <div class="flex items-center gap-3 text-xs text-foreground/25 font-condensed tracking-wider uppercase">
                <a href="/impressum" class="hover:text-primary transition-colors">Impressum</a>
                <span class="text-primary/30">·</span>
                <a href="/datenschutz" class="hover:text-primary transition-colors">Datenschutz</a>
                <span class="text-primary/30">·</span>
                <a href="/agb" class="hover:text-primary transition-colors">AGB</a>
            </div>
        </div>
    </div>
</footer>


<style>
    .footer-medallion {
        position: relative;
        width: 52px;
        height: 52px;
        flex-shrink: 0;
    }
    .footer-ring {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        animation: footer-spin 30s linear infinite;
    }
    .footer-medal-inner {
        position: absolute;
        inset: 0;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    @keyframes footer-spin {
        from { transform: rotate(0deg); }
        to { transform: rotate(360deg); }
    }
</style>