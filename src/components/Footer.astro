---
---

<footer class="border-t border-foreground/[.12] mt-auto">

    <!-- Trust bar -->
    <div class="border-b border-foreground/[.08] bg-secondary/30">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-5">
            <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 text-center sm:text-left">
                <div class="flex items-center gap-3 sm:justify-start justify-center">
                    <svg class="w-5 h-5 text-primary/70 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
                    <div>
                        <div class="text-xs font-condensed uppercase tracking-wider text-foreground/80 font-medium">Treuhand-Schutz</div>
                        <div class="text-[.7rem] text-foreground/50 font-light">Geld sicher bis Warenerhalt</div>
                    </div>
                </div>
                <div class="flex items-center gap-3 sm:justify-start justify-center">
                    <svg class="w-5 h-5 text-primary/70 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5.121 17.804A13.937 13.937 0 0112 16c2.5 0 4.847.655 6.879 1.804M15 10a3 3 0 11-6 0 3 3 0 016 0zm6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                    <div>
                        <div class="text-xs font-condensed uppercase tracking-wider text-foreground/80 font-medium">Verifizierte Identitäten</div>
                        <div class="text-[.7rem] text-foreground/50 font-light">Keine Fake-Profile</div>
                    </div>
                </div>
                <div class="flex items-center gap-3 sm:justify-start justify-center">
                    <svg class="w-5 h-5 text-primary/70 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 11v4a1 1 0 001 1h1m4-6v4a1 1 0 001 1h1m-8 0h8M6 22h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v14a2 2 0 002 2z"/></svg>
                    <div>
                        <div class="text-xs font-condensed uppercase tracking-wider text-foreground/80 font-medium">Digitaler Handschlag</div>
                        <div class="text-[.7rem] text-foreground/50 font-light">Transparent & verbindlich</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-8 mb-10">

            <!-- Brand -->
            <div class="col-span-2 md:col-span-1 space-y-3">
                <a href="/" class="inline-flex items-center gap-2">
                    <svg viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg" style="width:28px;height:28px;">
                        <path d="M4 20 L13 14 L19 18 L21 18 L27 14 L36 20" stroke="#c8973a" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
                        <path d="M13 14 L13 27" stroke="#c8973a" stroke-width="1.4" stroke-linecap="round" opacity=".4"/>
                        <path d="M27 14 L27 27" stroke="#c8973a" stroke-width="1.4" stroke-linecap="round" opacity=".4"/>
                        <path d="M19 18 L19 28" stroke="#c8973a" stroke-width="1.4" stroke-linecap="round" opacity=".6"/>
                        <path d="M21 18 L21 28" stroke="#c8973a" stroke-width="1.4" stroke-linecap="round" opacity=".6"/>
                        <line x1="13" y1="27" x2="27" y2="27" stroke="#c8973a" stroke-width="1.4" stroke-linecap="round" opacity=".3"/>
                    </svg>
                    <span class="font-condensed font-medium text-sm tracking-[.12em] uppercase text-foreground">
                        Ehren‑Deal
                    </span>
                </a>
                <p class="text-xs leading-relaxed text-foreground/50 font-light max-w-[200px]">
                    Deutschlands sicherste C2C-Plattform mit digitalem Handschlag und Identitätsprüfung.
                </p>
            </div>

            <!-- Käufer -->
            <div>
                <h4 class="font-condensed font-medium text-[.65rem] tracking-[.12em] uppercase text-foreground/50 mb-4">Für Käufer</h4>
                <ul class="space-y-2">
                    <li><a href="/" class="text-xs text-foreground/70 hover:text-primary transition-colors font-light">Angebote entdecken</a></li>
                    <li><a href="/sicherheit" class="text-xs text-foreground/70 hover:text-primary transition-colors font-light">Käuferschutz</a></li>
                    <li><a href="/sicherheit#handshake" class="text-xs text-foreground/70 hover:text-primary transition-colors font-light">Ehren-Handschlag</a></li>
                    <li><a href="/sicherheit#tipps" class="text-xs text-foreground/70 hover:text-primary transition-colors font-light">Sicherheitstipps</a></li>
                </ul>
            </div>

            <!-- Verkäufer -->
            <div>
                <h4 class="font-condensed font-medium text-[.65rem] tracking-[.12em] uppercase text-foreground/50 mb-4">Für Verkäufer</h4>
                <ul class="space-y-2">
                    <li><a href="/inserat-erstellen" class="text-xs text-primary/80 hover:text-primary font-light transition-colors">Anzeige aufgeben</a></li>
                    <li><a href="/anmelden" class="text-xs text-foreground/70 hover:text-primary transition-colors font-light">Identität bestätigen</a></li>
                    <li><a href="/profil" class="text-xs text-foreground/70 hover:text-primary transition-colors font-light">Trust Score aufbauen</a></li>
                    <li><a href="/sicherheit#treuhand" class="text-xs text-foreground/70 hover:text-primary transition-colors font-light">Treuhand Abwicklung</a></li>
                </ul>
            </div>

            <!-- Legal -->
            <div>
                <h4 class="font-condensed font-medium text-[.65rem] tracking-[.12em] uppercase text-foreground/50 mb-4">Unternehmen</h4>
                <ul class="space-y-2">
                    <li><a href="/kontakt" class="text-xs text-foreground/70 hover:text-primary transition-colors font-light">Kontakt & Support</a></li>
                    <li><a href="/agb" class="text-xs text-foreground/70 hover:text-primary transition-colors font-light">AGB</a></li>
                    <li><a href="/datenschutz" class="text-xs text-foreground/70 hover:text-primary transition-colors font-light">Datenschutz</a></li>
                    <li><a href="/impressum" class="text-xs text-foreground/70 hover:text-primary transition-colors font-light">Impressum</a></li>
                </ul>
            </div>
        </div>

        <!-- Bottom -->
        <div class="pt-6 border-t border-foreground/[.10] flex flex-col sm:flex-row items-center justify-between gap-3">
            <p class="text-[.65rem] text-foreground/40 font-light font-condensed tracking-wider uppercase">
                &copy; 2025 Ehren‑Deal – Handeln mit Handschlag
            </p>
            <div class="flex items-center gap-4 text-[.65rem] text-foreground/40 font-condensed tracking-wider uppercase">
                <a href="/impressum" class="hover:text-primary transition-colors">Impressum</a>
                <a href="/datenschutz" class="hover:text-primary transition-colors">Datenschutz</a>
                <a href="/agb" class="hover:text-primary transition-colors">AGB</a>
            </div>
        </div>
    </div>
</footer>
