---
const navLinks = [
    { href: "/", label: "Startseite" },
    { href: "/kategorien", label: "Kategorien" },
    { href: "/sicherheit", label: "Sicherheit" },
];
const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 bg-background/90 backdrop-blur-xl border-b border-foreground/[.20]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-16">
            <!-- Logo -->
            <a href="/" class="flex items-center gap-3 flex-shrink-0 group">
                <div class="medallion-wrap">
                    <svg class="ring-svg" viewBox="0 0 140 140" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <defs>
                            <path id="rp" d="M70,70 m-52,0 a52,52 0 1,1 104,0 a52,52 0 1,1-104,0"/>
                        </defs>
                        <text font-family="Barlow Condensed, sans-serif" font-size="8.8" fill="#c8973a" letter-spacing="5.2" font-weight="400" opacity=".65">
                            <textPath href="#rp">EHREN-DEAL  ·  HANDELN MIT HANDSCHLAG  ·  </textPath>
                        </text>
                        <circle cx="70" cy="70" r="61" stroke="#c8973a" stroke-width=".4" opacity=".15"/>
                    </svg>
                    <div class="medal-inner">
                        <svg class="mark-svg" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <path d="M4 20 L13 14 L19 18 L21 18 L27 14 L36 20" stroke="#c8973a" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
                            <path d="M13 14 L13 27" stroke="#c8973a" stroke-width="1.4" stroke-linecap="round" opacity=".4"/>
                            <path d="M27 14 L27 27" stroke="#c8973a" stroke-width="1.4" stroke-linecap="round" opacity=".4"/>
                            <path d="M19 18 L19 28" stroke="#c8973a" stroke-width="1.4" stroke-linecap="round" opacity=".6"/>
                            <path d="M21 18 L21 28" stroke="#c8973a" stroke-width="1.4" stroke-linecap="round" opacity=".6"/>
                            <line x1="13" y1="27" x2="27" y2="27" stroke="#c8973a" stroke-width="1.4" stroke-linecap="round" opacity=".3"/>
                            <circle cx="20" cy="9" r="1.2" fill="#c8973a" opacity=".5"/>
                        </svg>
                    </div>
                </div>
                <span class="font-condensed font-medium text-lg tracking-[.12em] uppercase text-foreground">
                    Ehren‑Deal
                </span>
            </a>

            <!-- Desktop Nav -->
            <nav class="hidden md:flex items-center gap-8">
                {navLinks.map((link) => (
                    <a
                        href={link.href}
                        class={`font-condensed text-[.78rem] font-medium tracking-[.08em] uppercase transition-colors duration-200 ${
                            currentPath === link.href
                            ? "text-primary"
                            : "text-foreground/80 hover:text-foreground"
                        }`}
                    >
                        {link.label}
                    </a>
                ))}
            </nav>

            <!-- Right side -->
            <div class="hidden md:flex items-center gap-5">
                <a href="/anmelden" class="font-condensed text-[.78rem] font-medium tracking-[.08em] uppercase text-foreground/80 hover:text-foreground transition-colors">
                    Anmelden
                </a>
                <a href="/inserat-erstellen" class="btn-outline text-[.72rem] py-1.5 px-4">
                    Anzeige aufgeben
                </a>
            </div>

            <!-- Mobile Menu Button -->
            <button
                class="md:hidden p-2 text-foreground/75 hover:text-foreground transition-colors focus:outline-none"
                id="mobileMenuBtn"
                aria-label="Menü öffnen"
            >
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16"></path></svg>
            </button>
        </div>
    </div>

    <!-- Mobile Menu -->
    <div class="md:hidden hidden absolute top-full left-0 w-full bg-background border-b border-foreground/[.20]" id="mobileMenu">
        <div class="px-6 pt-3 pb-6 space-y-1">
            {navLinks.map((link) => (
                <a
                    href={link.href}
                    class={`block py-3 font-condensed text-sm font-medium tracking-wider uppercase border-b border-foreground/[.20] ${
                        currentPath === link.href ? "text-primary" : "text-foreground/75 hover:text-foreground"
                    }`}
                >
                    {link.label}
                </a>
            ))}
            <div class="pt-4 space-y-3">
                <a href="/anmelden" class="block text-center py-3 font-condensed text-sm font-medium text-foreground/75 hover:text-foreground transition-colors uppercase tracking-wider">
                    Anmelden
                </a>
                <a href="/inserat-erstellen" class="btn-outline w-full flex items-center justify-center py-2.5">
                    Anzeige aufgeben
                </a>
            </div>
        </div>
    </div>
</header>

<script>
    const btn = document.getElementById("mobileMenuBtn");
    const menu = document.getElementById("mobileMenu");

    btn?.addEventListener("click", () => {
        if (menu?.classList.contains('hidden')) {
            menu.classList.remove('hidden');
        } else {
            menu?.classList.add('hidden');
        }
    });
</script>


<style>
    .medallion-wrap {
        position: relative;
        width: 64px;
        height: 64px;
        flex-shrink: 0;
    }
    .ring-svg {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        animation: spin-slow 25s linear infinite;
    }
    .medal-inner {
        position: absolute;
        inset: 0;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    .mark-svg {
        width: 30px;
        height: 30px;
    }
    @keyframes spin-slow {
        from { transform: rotate(0deg); }
        to { transform: rotate(360deg); }
    }
</style>