---
const navLinks = [
    { href: "/", label: "Startseite" },
    { href: "/kategorien", label: "Kategorien" },
    { href: "/sicherheit", label: "Sicherheit" },
];
const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 bg-background/80 backdrop-blur-xl border-b border-secondary shadow-sm">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-20">
            <!-- Logo -->
            <a href="/" class="flex items-center gap-3 flex-shrink-0 group">
                <div class="w-10 h-10 rounded-default bg-primary flex items-center justify-center text-primary-foreground shadow-sm group-hover:scale-105 transition-transform duration-300">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                        <path d="M9 12l2 2 4-4"/>
                    </svg>
                </div>
                <span class="text-2xl font-headings font-extrabold tracking-tight text-primary">
                    Ehren-<span class="text-foreground/60">Deal</span>
                </span>
            </a>

            <!-- Search Bar (desktop) -->
            <form class="hidden md:flex flex-1 max-w-lg mx-8" action="/">
                <div class="relative w-full group">
                    <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none text-muted-foreground group-focus-within:text-primary transition-colors">
                        <svg class="w-5 h-5 text-foreground/40" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                    </div>
                    <input
                        type="text"
                        name="query"
                        placeholder="Was suchst du?"
                        class="w-full pl-11 pr-4 py-2.5 bg-secondary/50 border border-secondary rounded-full text-foreground placeholder-foreground/50 focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all duration-300"
                    />
                </div>
            </form>

            <!-- Desktop Nav -->
            <nav class="hidden md:flex items-center gap-6">
                <div class="flex items-center gap-1.5">
                    {navLinks.map((link) => (
                        <a
                            href={link.href}
                            class={`px-4 py-2 rounded-default text-sm font-bold transition-all duration-200 ${
                                currentPath === link.href 
                                ? "bg-secondary text-foreground" 
                                : "text-foreground/70 hover:text-foreground hover:bg-secondary/50"
                            }`}
                        >
                            {link.label}
                        </a>
                    ))}
                </div>
                <div class="w-px h-8 bg-secondary mx-2"></div>
                <div class="flex items-center gap-3">
                    <a href="/anmelden" class="text-foreground/80 hover:text-primary text-sm font-bold transition-colors px-2">
                        Anmelden
                    </a>
                    <a href="/inserat-erstellen" class="btn-primary py-2.5 px-5 text-sm">
                        <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
                        Anzeige aufgeben
                    </a>
                </div>
            </nav>

            <!-- Mobile Menu Button -->
            <button
                class="md:hidden p-2.5 rounded-default text-foreground/70 hover:text-primary hover:bg-secondary/50 transition-colors focus:outline-none"
                id="mobileMenuBtn"
                aria-label="Menü öffnen"
            >
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path></svg>
            </button>
        </div>

        <!-- Mobile Search -->
        <form class="md:hidden pb-4" action="/">
            <div class="relative">
                <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none text-foreground/40">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                </div>
                <input
                    type="text"
                    name="query"
                    placeholder="Suchen..."
                    class="w-full pl-11 pr-4 py-3 bg-secondary/50 border border-secondary rounded-default text-foreground placeholder-foreground/50 focus:outline-none focus:ring-2 focus:ring-primary/20"
                />
            </div>
        </form>
    </div>

    <!-- Mobile Menu Overlay -->
    <div class="md:hidden hidden absolute top-full left-0 w-full bg-background border-b border-secondary shadow-xl origin-top" id="mobileMenu">
        <div class="px-4 pt-2 pb-6 space-y-1">
            {navLinks.map((link) => (
                <a 
                    href={link.href} 
                    class={`block px-4 py-3 rounded-default text-base font-bold ${
                        currentPath === link.href ? "bg-secondary text-primary" : "text-foreground/80 hover:bg-secondary/50 hover:text-primary"
                    }`}
                >
                    {link.label}
                </a>
            ))}
            <div class="h-px bg-secondary my-4"></div>
            <div class="space-y-3 px-2">
                <a href="/anmelden" class="block w-full px-4 py-3 text-center rounded-default font-bold text-foreground bg-secondary/50 hover:bg-secondary transition-colors">
                    Anmelden
                </a>
                <a href="/inserat-erstellen" class="btn-primary w-full shadow-none flex items-center justify-center">
                    <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
                    Anzeige aufgeben
                </a>
            </div>
        </div>
    </div>
</header>

<script>
    const btn = document.getElementById("mobileMenuBtn");
    const menu = document.getElementById("mobileMenu");
    
    btn?.addEventListener("click", () => {
        if (menu?.classList.contains('hidden')) {
            menu.classList.remove('hidden');
        } else {
            menu?.classList.add('hidden');
        }
    });
</script>
