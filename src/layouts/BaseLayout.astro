---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}
const {
  title = "Ehren-Deal – Handeln mit Handschlag",
  description = "Deutschlands sicherste C2C-Plattform für lokale Deals mit digitalem Handschlag und Identitätsprüfung.",
} = Astro.props;
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    
    <!-- Google Fonts: Inter for UI, Outfit for Headings -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Outfit:wght@500;700;800&display=swap" rel="stylesheet" />
  </head>
  <body class="bg-background text-foreground font-body antialiased selection:bg-primary/20 selection:text-foreground">
    <slot />
  </body>
</html>
