---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}
const {
  title = "Ehren-Deal – Handeln mit Handschlag",
  description = "Deutschlands sicherste C2C-Plattform für lokale Deals mit digitalem Handschlag und Identitätsprüfung.",
} = Astro.props;
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    
    <!-- Google Fonts: Cormorant Garamond + Barlow + Barlow Condensed -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,500;0,600;1,300;1,500&family=Barlow:wght@300;400;500&family=Barlow+Condensed:wght@300;400;500;600&display=swap" rel="stylesheet" />
  </head>
  <body class="bg-background text-foreground font-body antialiased">
    <div class="bg-grain"></div>
    <slot />
  </body>
</html>
