---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";

const articles = [
  {
    slug: "sicher-online-kaufen",
    title: "Sicher online kaufen — 10 Tipps f\u00fcr den gebrauchten Marktplatz",
    excerpt: "Online-Marktpl\u00e4tze bieten tolle Schn\u00e4ppchen, doch Sicherheit sollte immer an erster Stelle stehen. Wir zeigen dir, worauf du beim Kauf gebrauchter Artikel achten musst.",
    category: "Sicherheit",
    readingTime: "8 Min.",
    date: "2026-03-28",
    gradient: "from-primary to-navy",
  },
  {
    slug: "betrug-erkennen",
    title: "Betrug erkennen und vermeiden — So sch\u00fctzt du dich",
    excerpt: "Vorkasse-Betrug, Fake-Inserate und Phishing geh\u00f6ren zu den h\u00e4ufigsten Maschen auf Online-Marktpl\u00e4tzen. Erfahre, wie du sie erkennst und dich effektiv sch\u00fctzt.",
    category: "Sicherheit",
    readingTime: "6 Min.",
    date: "2026-03-22",
    gradient: "from-danger to-accent",
  },
  {
    slug: "tipps-fuer-verkaeufer",
    title: "Erfolgreich verkaufen — Tipps f\u00fcr bessere Inserate",
    excerpt: "Gute Fotos, faire Preise und ansprechende Beschreibungen machen den Unterschied. Mit diesen Tipps verkaufst du schneller und erzielst bessere Preise.",
    category: "Tipps & Tricks",
    readingTime: "5 Min.",
    date: "2026-03-15",
    gradient: "from-success to-primary",
  },
  {
    slug: "treuhand-erklaert",
    title: "Treuhand-Zahlung erkl\u00e4rt — Warum dein Geld sicher ist",
    excerpt: "Die Treuhand-Zahlung ist das Herzst\u00fcck von Ehren-Deal. Wir erkl\u00e4ren Schritt f\u00fcr Schritt, wie der Zahlungsschutz funktioniert und warum er sicherer ist als Direkt\u00fcberweisung.",
    category: "Neuigkeiten",
    readingTime: "4 Min.",
    date: "2026-03-10",
    gradient: "from-accent to-success",
  },
];

const categories = ["Alle", "Sicherheit", "Tipps & Tricks", "Neuigkeiten"];
const currentCategory = Astro.url.searchParams.get("kategorie") ?? "Alle";
const filtered = currentCategory === "Alle"
  ? articles
  : articles.filter((a) => a.category === currentCategory);
---

<BaseLayout
  title="Ratgeber — Tipps f\u00fcr sicheres Kaufen & Verkaufen | Ehren-Deal"
  description="Im Ehren-Deal Ratgeber findest du hilfreiche Artikel rund um sicheres Kaufen und Verkaufen auf Online-Marktpl\u00e4tzen, Betrugspr\u00e4vention und Verk\u00e4ufer-Tipps."
  canonicalPath="/ratgeber"
>
  <Header />
  <main id="main-content" class="min-h-screen">

    <!-- Hero -->
    <section class="bg-gradient-to-br from-navy to-primary-dark text-white py-16 sm:py-20">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <nav class="text-sm text-white/50 mb-6" aria-label="Breadcrumb">
          <ol class="flex items-center gap-1.5">
            <li><a href="/" class="hover:text-white/80 transition-colors">Startseite</a></li>
            <li>/</li>
            <li class="text-white/80">Ratgeber</li>
          </ol>
        </nav>
        <div class="max-w-2xl">
          <h1 class="text-3xl sm:text-4xl md:text-5xl font-bold text-white leading-[1.1] mb-4">
            Ratgeber
          </h1>
          <p class="text-lg text-white/70 max-w-lg">
            Wissen f\u00fcr sicheres Handeln. Tipps, Anleitungen und Hintergrundwissen rund um Kauf, Verkauf und Sicherheit auf Ehren-Deal.
          </p>
        </div>
      </div>
    </section>

    <!-- Categories + Articles -->
    <section class="py-10 sm:py-14">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

        <!-- Category Filter -->
        <div class="flex flex-wrap gap-2 mb-10">
          {categories.map((cat) => (
            <a
              href={cat === "Alle" ? "/ratgeber" : `/ratgeber?kategorie=${encodeURIComponent(cat)}`}
              class={`px-4 py-2 rounded-full text-sm font-medium transition-colors ${
                currentCategory === cat
                  ? "bg-primary text-white"
                  : "bg-surface text-text-secondary border border-border hover:border-primary hover:text-primary"
              }`}
            >
              {cat}
            </a>
          ))}
        </div>

        <!-- Article Grid -->
        {filtered.length > 0 ? (
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            {filtered.map((article, i) => (
              <a href={`/ratgeber/${article.slug}`} class="group block h-full">
                <article class="card h-full flex flex-col overflow-hidden">
                  <!-- Image Placeholder -->
                  <div class={`aspect-[16/9] w-full bg-gradient-to-br ${article.gradient} relative flex items-center justify-center p-6`}>
                    <span class="text-white/90 text-lg sm:text-xl font-bold text-center leading-snug line-clamp-3 max-w-sm">
                      {article.title}
                    </span>
                  </div>

                  <div class="p-5 sm:p-6 flex flex-col flex-grow">
                    <div class="flex items-center gap-3 mb-3">
                      <span class="text-xs font-semibold text-primary bg-primary-light px-2.5 py-0.5 rounded-full">
                        {article.category}
                      </span>
                      <span class="text-caption text-text-muted">{article.readingTime} Lesezeit</span>
                    </div>

                    <h2 class="text-lg font-semibold text-text mb-2 group-hover:text-primary transition-colors leading-snug">
                      {article.title}
                    </h2>

                    <p class="text-sm text-text-secondary leading-relaxed mb-4 flex-grow">
                      {article.excerpt}
                    </p>

                    <div class="flex items-center justify-between pt-3 border-t border-border">
                      <time datetime={article.date} class="text-caption text-text-muted">
                        {new Date(article.date).toLocaleDateString("de-DE", { day: "numeric", month: "long", year: "numeric" })}
                      </time>
                      <span class="text-sm font-medium text-primary group-hover:translate-x-0.5 transition-transform">
                        Weiterlesen &rarr;
                      </span>
                    </div>
                  </div>
                </article>
              </a>
            ))}
          </div>
        ) : (
          <div class="text-center py-20 rounded-DEFAULT border border-dashed border-border">
            <h3 class="text-h3 text-text mb-2">Keine Artikel gefunden</h3>
            <p class="text-text-secondary max-w-sm mx-auto">
              In dieser Kategorie gibt es noch keine Artikel. Schau in einer anderen Kategorie vorbei.
            </p>
          </div>
        )}
      </div>
    </section>

    <!-- CTA -->
    <section class="bg-surface border-t border-border py-14">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h2 class="text-h2 mb-3">Bereit f\u00fcr sichere Deals?</h2>
        <p class="text-text-secondary mb-6 max-w-md mx-auto">Registriere dich jetzt und profitiere vom Treuhand-Schutz bei jedem Kauf.</p>
        <a href="/anmelden" class="btn-primary px-8">Jetzt registrieren</a>
      </div>
    </section>

  </main>
  <Footer />

  <!-- JSON-LD CollectionPage -->
  <script is:inline type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": "Ehren-Deal Ratgeber",
    "description": "Tipps und Anleitungen f\u00fcr sicheres Kaufen und Verkaufen auf Online-Marktpl\u00e4tzen.",
    "url": "https://ehren-deal.de/ratgeber",
    "publisher": {
      "@type": "Organization",
      "name": "Ehren-Deal",
      "url": "https://ehren-deal.de"
    }
  })} />
</BaseLayout>
