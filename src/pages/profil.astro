---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { lucia, prisma } from "../lib/auth";

// Auth check – redirect to login if not authenticated
const sessionId = Astro.cookies.get(lucia.sessionCookieName)?.value;
if (!sessionId) return Astro.redirect("/anmelden?redirect=/profil");

let sessionUser: { id: string } | null = null;
try {
    const result = await lucia.validateSession(sessionId);
    sessionUser = result.user;
} catch { /* DB not available */ }
if (!sessionUser) return Astro.redirect("/anmelden?redirect=/profil");

// Fetch full user from DB with relations
let dbUser: any = null;
try {
    dbUser = await prisma.user.findUnique({
        where: { id: sessionUser.id },
        include: {
            trustScore: true,
            listings: {
                where: { status: { in: ['ACTIVE', 'RESERVED', 'SOLD'] } },
                orderBy: { createdAt: 'desc' },
                take: 5,
                include: { images: true },
            },
            sellerDeals: { where: { status: 'COMPLETED' } },
        },
    });
} catch { /* DB not available */ }
if (!dbUser) return Astro.redirect("/anmelden?redirect=/profil");

// Computed values
const fullName = [dbUser.firstName, dbUser.lastName].filter(Boolean).join(' ') || dbUser.email.split('@')[0];
const initials = dbUser.firstName ? dbUser.firstName[0].toUpperCase() : dbUser.email[0].toUpperCase();
const trustScore = dbUser.trustScore?.score ?? 0;
const trustLevel = dbUser.trustScore?.level ?? 'NEW';
const trustLabel = trustScore >= 80 ? 'Exzellent' : trustScore >= 60 ? 'Gut' : trustScore >= 40 ? 'Aufbauend' : 'Neu';
const completedDeals = dbUser.sellerDeals.length;
const memberSince = dbUser.createdAt.toLocaleDateString('de-DE', { month: 'long', year: 'numeric' });
const cityDisplay = dbUser.city || '';

// Mask phone for display
function maskPhone(phone: string | null): string {
    if (!phone) return '';
    if (phone.length < 6) return phone;
    return phone.slice(0, 6) + ' ***' + phone.slice(-2);
}
---

<BaseLayout title="Mein Profil – Ehren-Deal">
    <Header />
    <main class="min-h-screen bg-background pb-16">
        <div class="max-w-7xl mx-auto">
            <!-- Profile Header -->
            <div class="border-b border-border bg-surface">
                <div class="flex flex-wrap items-center gap-6 py-10 px-6 sm:px-12 max-w-7xl mx-auto">
                    <div class="w-24 h-24 bg-primary-light rounded-full flex items-center justify-center text-3xl font-semibold text-primary flex-shrink-0">
                        {dbUser.avatarUrl ? (
                            <img src={dbUser.avatarUrl} alt={fullName} class="w-full h-full object-cover rounded-full" />
                        ) : (
                            initials
                        )}
                    </div>
                    <div class="flex-1">
                        <div class="flex flex-wrap items-center gap-3 mb-2">
                            <h1 class="text-h2 text-text m-0">{fullName}</h1>
                            {dbUser.idVerified && (
                                <span class="badge-verifiziert">KYC-verifiziert</span>
                            )}
                            {dbUser.emailVerified && (
                                <span class="badge-verifiziert">Bestätigt</span>
                            )}
                        </div>
                        <p class="text-body-sm text-text-secondary mb-5">
                            Mitglied seit {memberSince}{cityDisplay ? ` · ${cityDisplay}` : ''}
                        </p>
                        <div class="flex flex-wrap gap-8">
                            <div class="flex flex-col gap-0.5">
                                <span class="text-xl font-bold text-success">{trustScore}</span>
                                <span class="text-label text-text-muted">Trust Score</span>
                            </div>
                            <div class="flex flex-col gap-0.5">
                                <span class="text-xl font-bold text-text">{dbUser.listings.length}</span>
                                <span class="text-label text-text-muted">Anzeigen</span>
                            </div>
                            <div class="flex flex-col gap-0.5">
                                <span class="text-xl font-bold text-text">{completedDeals}</span>
                                <span class="text-label text-text-muted">Verkäufe</span>
                            </div>
                        </div>
                    </div>
                    <div class="profile-actions hide-mobile flex flex-col gap-3">
                        <a href="/inserat-erstellen" class="btn-primary">+ Anzeige aufgeben</a>
                        <a href="/nachrichten" class="btn-secondary">Nachrichten</a>
                    </div>
                </div>
            </div>

            <div class="grid grid-cols-1 lg:grid-cols-[320px_1fr] gap-8 mt-8 px-4 sm:px-6 lg:px-8">
                <!-- Left: Verification + Settings -->
                <div>
                    <!-- Verification Status -->
                    <div class="bg-surface border border-border rounded-lg p-6 shadow-card">
                        <h3 class="text-label text-text-secondary mb-5">Verifizierungsstatus</h3>
                        <div class="flex flex-col gap-3">
                            <!-- E-Mail -->
                            <div class={`flex items-center gap-4 p-4 rounded-lg transition-colors ${dbUser.emailVerified ? 'bg-success-light border border-success/20' : 'bg-background border border-border'}`}>
                                <div class={`w-9 h-9 flex items-center justify-center rounded-lg flex-shrink-0 ${dbUser.emailVerified ? 'bg-success/10 text-success' : 'bg-accent-light text-accent'}`}>
                                    {dbUser.emailVerified ? (
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"></polyline></svg>
                                    ) : (
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line></svg>
                                    )}
                                </div>
                                <div>
                                    <div class="text-sm font-medium text-text mb-0.5">E-Mail-Adresse</div>
                                    <div class="text-caption text-text-secondary">{dbUser.email}</div>
                                </div>
                                {dbUser.emailVerified ? (
                                    <span class="ml-auto flex-shrink-0 inline-flex items-center px-2.5 py-1 bg-success-light text-success rounded-sm text-label font-semibold">Bestätigt</span>
                                ) : (
                                    <button id="resend-email-btn" class="ml-auto flex-shrink-0 btn-secondary text-xs px-3 py-1.5">Erneut senden</button>
                                )}
                            </div>
                            <!-- Phone -->
                            <div class={`flex items-center gap-4 p-4 rounded-lg transition-colors ${dbUser.phoneVerified ? 'bg-success-light border border-success/20' : 'bg-background border border-border'}`}>
                                <div class={`w-9 h-9 flex items-center justify-center rounded-lg flex-shrink-0 ${dbUser.phoneVerified ? 'bg-success/10 text-success' : 'bg-accent-light text-accent'}`}>
                                    {dbUser.phoneVerified ? (
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"></polyline></svg>
                                    ) : (
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line></svg>
                                    )}
                                </div>
                                <div>
                                    <div class="text-sm font-medium text-text mb-0.5">Handynummer</div>
                                    <div class="text-caption text-text-secondary">{dbUser.phone ? maskPhone(dbUser.phone) : 'Nicht hinterlegt'}</div>
                                </div>
                                {dbUser.phoneVerified ? (
                                    <span class="ml-auto flex-shrink-0 inline-flex items-center px-2.5 py-1 bg-success-light text-success rounded-sm text-label font-semibold">Bestätigt</span>
                                ) : (
                                    <button id="verify-phone-btn" class="ml-auto flex-shrink-0 btn-secondary text-xs px-3 py-1.5">Verifizieren</button>
                                )}
                            </div>
                            <!-- KYC -->
                            <div class={`flex items-center gap-4 p-4 rounded-lg transition-colors ${dbUser.idVerified ? 'bg-success-light border border-success/20' : 'bg-background border border-border'}`}>
                                <div class={`w-9 h-9 flex items-center justify-center rounded-lg flex-shrink-0 ${dbUser.idVerified ? 'bg-success/10 text-success' : 'bg-accent-light text-accent'}`}>
                                    {dbUser.idVerified ? (
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"></polyline></svg>
                                    ) : (
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line></svg>
                                    )}
                                </div>
                                <div>
                                    <div class="text-sm font-medium text-text mb-0.5">Personalausweis (KYC)</div>
                                    <div class="text-caption text-text-secondary">{dbUser.idVerified ? 'Vollständig verifiziert' : 'Noch nicht verifiziert'}</div>
                                </div>
                                {dbUser.idVerified ? (
                                    <span class="ml-auto flex-shrink-0 inline-flex items-center px-2.5 py-1 bg-success-light text-success rounded-sm text-label font-semibold">KYC</span>
                                ) : (
                                    <button id="start-kyc-btn" class="ml-auto flex-shrink-0 btn-secondary text-xs px-3 py-1.5">Jetzt starten</button>
                                )}
                            </div>
                        </div>
                        <!-- Trust Score Bar -->
                        <div class="mt-6 pt-5 border-t border-border">
                            <div class="flex justify-between text-label text-text-secondary mb-3">
                                <span>Vertrauens-Score</span>
                                <span class="text-success font-bold">{trustLabel}</span>
                            </div>
                            <div class="bg-background h-2 rounded-full overflow-hidden mb-1.5">
                                <div class="h-full bg-success rounded-full transition-all duration-500" style={`width:${trustScore}%`}></div>
                            </div>
                            <div class="flex justify-between text-caption text-text-muted mt-1">
                                <span>0</span>
                                <span class="font-bold text-success">{trustScore} / 100</span>
                                <span>100</span>
                            </div>
                        </div>
                    </div>

                    <!-- Quick Links -->
                    <div class="bg-surface border border-border rounded-lg p-6 shadow-card mt-4">
                        <h3 class="text-label text-text-secondary mb-5">Konto</h3>
                        <div class="flex flex-col gap-1">
                            <a href="/einstellungen" class="flex items-center gap-3 p-3 text-body-sm text-text-secondary rounded-lg transition-all hover:bg-background hover:text-text">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"></circle><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"></path></svg>
                                Einstellungen
                            </a>
                            <a href="/sicherheit" class="flex items-center gap-3 p-3 text-body-sm text-text-secondary rounded-lg transition-all hover:bg-background hover:text-text">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
                                Sicherheitscenter
                            </a>
                            <a href="/nachrichten" class="flex items-center gap-3 p-3 text-body-sm text-text-secondary rounded-lg transition-all hover:bg-background hover:text-text">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path></svg>
                                Nachrichten
                            </a>
                        </div>
                    </div>
                </div>

                <!-- Right: Listings + Reviews -->
                <div>
                    <!-- My Listings -->
                    <div class="bg-surface border border-border rounded-lg p-6 shadow-card">
                        <div class="flex justify-between items-center mb-5">
                            <h3 class="text-label text-text-secondary m-0">Meine Anzeigen</h3>
                            <a href="/inserat-erstellen" class="btn-primary text-xs px-4 py-2">+ Neu</a>
                        </div>
                        <div class="flex flex-col gap-4">
                            {dbUser.listings.length === 0 ? (
                                <p class="text-body-sm text-text-muted">Du hast noch keine Anzeigen erstellt.</p>
                            ) : (
                                dbUser.listings.map((l) => (
                                    <a href={`/inserat/${l.id}`} class="flex items-center gap-4 p-3 border border-border rounded-lg transition-all hover:border-primary/30 hover:shadow-card no-underline text-inherit" style="text-decoration:none; color:inherit;">
                                        <img
                                            src={l.images[0]?.url || '/placeholder.jpg'}
                                            alt={l.title}
                                            class="w-20 h-16 object-cover flex-shrink-0 bg-background rounded-lg"
                                        />
                                        <div class="flex-1 min-w-0">
                                            <div class="text-sm font-medium text-text truncate mb-1">{l.title}</div>
                                            <div class="text-base font-bold text-primary">{(l.price / 100).toLocaleString("de-DE")} €</div>
                                            <div class="text-caption text-text-muted mt-1">{l.city} · {l.createdAt.toLocaleDateString('de-DE')}</div>
                                        </div>
                                        <div class="flex flex-col items-end gap-2 flex-shrink-0">
                                            <span class={`inline-flex items-center px-2 py-0.5 rounded-sm text-label font-semibold ${l.status === 'ACTIVE' ? 'bg-success-light text-success' : l.status === 'SOLD' ? 'bg-background text-text-muted' : 'bg-accent-light text-accent'}`}>
                                                {l.status === 'ACTIVE' ? 'Aktiv' : l.status === 'SOLD' ? 'Verkauft' : l.status === 'RESERVED' ? 'Reserviert' : l.status}
                                            </span>
                                        </div>
                                    </a>
                                ))
                            )}
                        </div>
                    </div>

                    <!-- Deals -->
                    <div class="bg-surface border border-border rounded-lg p-6 shadow-card mt-5">
                        <div class="flex items-center gap-3 mb-5">
                            <h3 class="text-label text-text-secondary m-0">Abgeschlossene Deals</h3>
                        </div>
                        {completedDeals === 0 ? (
                            <p class="text-body-sm text-text-muted">Noch keine abgeschlossenen Deals.</p>
                        ) : (
                            <p class="text-body-sm text-text-secondary">
                                Du hast <strong>{completedDeals}</strong> Deal{completedDeals !== 1 ? 's' : ''} erfolgreich abgeschlossen.
                                <a href="/dashboard/deals" class="text-primary hover:underline ml-1">Alle anzeigen</a>
                            </p>
                        )}
                    </div>
                </div>
            </div>
        </div>
    </main>
    <Footer />
</BaseLayout>

<style>
    @media (max-width: 600px) {
        .profile-actions.hide-mobile { @apply w-full; }
    }

    /* Modal */
    .modal-overlay { @apply fixed inset-0 bg-black/60 z-50 flex items-center justify-center p-4; display:none; }
    .modal-overlay.open { display:flex; }
    .modal-box { @apply bg-surface border border-border rounded-lg p-8 max-w-md w-full shadow-card-hover; }
    .modal-title { @apply text-h3 text-text mb-4; }
    .modal-input { @apply w-full px-4 py-3 bg-background border border-border rounded-DEFAULT text-text text-sm mb-4 outline-none transition-colors; }
    .modal-input:focus { @apply border-primary ring-2 ring-primary/20; }
    .modal-actions { @apply flex gap-3 justify-end; }
    .modal-msg { @apply text-caption text-text-muted mb-3; }
    .modal-msg.error { @apply text-danger; }
    .modal-msg.success { @apply text-success; }
</style>

<!-- Phone Verification Modal -->
<div id="phone-modal" class="modal-overlay">
    <div class="modal-box">
        <h3 class="modal-title">Handynummer verifizieren</h3>
        <div id="phone-step-1">
            <p class="modal-msg">Wir senden einen 6-stelligen Code an deine Handynummer.</p>
            {!dbUser.phone && (
                <input id="phone-input" type="tel" class="modal-input" placeholder="+49 151 12345678" />
            )}
            {dbUser.phone && (
                <p class="text-sm text-text-secondary mb-4">Nummer: {maskPhone(dbUser.phone)}</p>
            )}
            <div id="phone-msg-1" class="modal-msg"></div>
            <div class="modal-actions">
                <button id="phone-cancel" class="btn-ghost text-sm px-4 py-2">Abbrechen</button>
                <button id="phone-send-btn" class="btn-primary text-sm px-4 py-2">Code senden</button>
            </div>
        </div>
        <div id="phone-step-2" style="display:none;">
            <p class="modal-msg">Gib den 6-stelligen Code ein, den du per SMS erhalten hast.</p>
            <input id="phone-code-input" type="text" class="modal-input" placeholder="123456" maxlength="6" inputmode="numeric" pattern="[0-9]*" />
            <div id="phone-msg-2" class="modal-msg"></div>
            <div class="modal-actions">
                <button id="phone-back" class="btn-ghost text-sm px-4 py-2">Zurück</button>
                <button id="phone-verify-btn" class="btn-primary text-sm px-4 py-2">Bestätigen</button>
            </div>
        </div>
    </div>
</div>

<script>
function fetchWithTimeout(url: string, opts: RequestInit = {}, timeoutMs = 15000): Promise<Response> {
    const ctrl = new AbortController();
    const timer = setTimeout(() => ctrl.abort(), timeoutMs);
    return fetch(url, { ...opts, signal: ctrl.signal }).finally(() => clearTimeout(timer));
}

// Email resend
document.getElementById('resend-email-btn')?.addEventListener('click', async (e) => {
    const btn = e.currentTarget as HTMLButtonElement;
    btn.disabled = true;
    btn.textContent = 'Wird gesendet...';
    try {
        const res = await fetchWithTimeout('/api/verify/email/send', { method: 'POST' });
        const data = await res.json();
        if (data.ok) {
            btn.textContent = '✓ Gesendet!';
            btn.classList.remove('btn-secondary');
            btn.classList.add('btn-ghost');
        } else {
            btn.textContent = 'Fehler – Erneut versuchen';
            btn.disabled = false;
        }
    } catch (err) {
        btn.textContent = err instanceof DOMException && err.name === 'AbortError'
            ? 'Timeout – Erneut versuchen' : 'Fehler – Erneut versuchen';
        btn.disabled = false;
    }
});

// Phone verification modal
const phoneModal = document.getElementById('phone-modal')!;
const phoneStep1 = document.getElementById('phone-step-1')!;
const phoneStep2 = document.getElementById('phone-step-2')!;

document.getElementById('verify-phone-btn')?.addEventListener('click', () => {
    phoneModal.classList.add('open');
    phoneStep1.style.display = '';
    phoneStep2.style.display = 'none';
});

document.getElementById('phone-cancel')?.addEventListener('click', () => phoneModal.classList.remove('open'));
document.getElementById('phone-back')?.addEventListener('click', () => {
    phoneStep1.style.display = '';
    phoneStep2.style.display = 'none';
});

phoneModal.addEventListener('click', (e) => {
    if (e.target === phoneModal) phoneModal.classList.remove('open');
});

document.getElementById('phone-send-btn')?.addEventListener('click', async () => {
    const msg = document.getElementById('phone-msg-1')!;
    const btn = document.getElementById('phone-send-btn') as HTMLButtonElement;
    const phoneInput = document.getElementById('phone-input') as HTMLInputElement | null;
    const phone = phoneInput?.value?.trim() || '';
    btn.disabled = true;
    msg.textContent = 'Sende Code...';
    msg.className = 'modal-msg';
    try {
        const res = await fetchWithTimeout('/api/verify/phone/send', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ phone }),
        }, 20000);
        const data = await res.json();
        if (data.ok) {
            phoneStep1.style.display = 'none';
            phoneStep2.style.display = '';
        } else {
            msg.textContent = data.error || 'Fehler beim Senden';
            msg.className = 'modal-msg error';
        }
    } catch (err) {
        msg.textContent = err instanceof DOMException && err.name === 'AbortError'
            ? 'Zeitüberschreitung – SMTP-Server nicht erreichbar' : 'Netzwerkfehler';
        msg.className = 'modal-msg error';
    }
    btn.disabled = false;
});

document.getElementById('phone-verify-btn')?.addEventListener('click', async () => {
    const msg = document.getElementById('phone-msg-2')!;
    const btn = document.getElementById('phone-verify-btn') as HTMLButtonElement;
    const code = (document.getElementById('phone-code-input') as HTMLInputElement).value.trim();
    if (code.length !== 6) { msg.textContent = 'Bitte 6-stelligen Code eingeben'; msg.className = 'modal-msg error'; return; }
    btn.disabled = true;
    msg.textContent = 'Prüfe...';
    msg.className = 'modal-msg';
    try {
        const res = await fetchWithTimeout('/api/verify/phone/verify', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ code }),
        });
        const data = await res.json();
        if (data.ok) {
            msg.textContent = '✓ Handynummer verifiziert!';
            msg.className = 'modal-msg success';
            setTimeout(() => location.reload(), 1500);
        } else {
            msg.textContent = data.error || 'Ungültiger Code';
            msg.className = 'modal-msg error';
        }
    } catch (err) {
        msg.textContent = err instanceof DOMException && err.name === 'AbortError'
            ? 'Zeitüberschreitung' : 'Netzwerkfehler';
        msg.className = 'modal-msg error';
    }
    btn.disabled = false;
});

// KYC button
document.getElementById('start-kyc-btn')?.addEventListener('click', async (e) => {
    const btn = e.currentTarget as HTMLButtonElement;
    btn.disabled = true;
    btn.textContent = 'Wird gestartet...';
    try {
        const res = await fetchWithTimeout('/api/kyc/start', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({}),
        });
        const data = await res.json();
        if (data.redirectUrl) {
            window.location.href = data.redirectUrl;
        } else {
            btn.textContent = data.error || 'Nicht verfügbar';
            setTimeout(() => { btn.textContent = '→ Jetzt'; btn.disabled = false; }, 3000);
        }
    } catch (err) {
        btn.textContent = err instanceof DOMException && err.name === 'AbortError'
            ? 'Zeitüberschreitung' : 'Fehler';
        setTimeout(() => { btn.textContent = '→ Jetzt'; btn.disabled = false; }, 3000);
    }
});
</script>
