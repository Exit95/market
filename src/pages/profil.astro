---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { lucia, prisma } from "../lib/auth";

// Auth check – redirect to login if not authenticated
const sessionId = Astro.cookies.get(lucia.sessionCookieName)?.value;
if (!sessionId) return Astro.redirect("/anmelden?redirect=/profil");

const { user: sessionUser } = await lucia.validateSession(sessionId);
if (!sessionUser) return Astro.redirect("/anmelden?redirect=/profil");

// Fetch full user from DB with relations
const dbUser = await prisma.user.findUnique({
    where: { id: sessionUser.id },
    include: {
        trustScore: true,
        listings: {
            where: { status: { in: ['ACTIVE', 'RESERVED', 'SOLD'] } },
            orderBy: { createdAt: 'desc' },
            take: 5,
            include: { images: true },
        },
        sellerDeals: { where: { status: 'COMPLETED' } },
    },
});
if (!dbUser) return Astro.redirect("/anmelden?redirect=/profil");

// Computed values
const fullName = [dbUser.firstName, dbUser.lastName].filter(Boolean).join(' ') || dbUser.email.split('@')[0];
const initials = dbUser.firstName ? dbUser.firstName[0].toUpperCase() : dbUser.email[0].toUpperCase();
const trustScore = dbUser.trustScore?.score ?? 0;
const trustLevel = dbUser.trustScore?.level ?? 'NEW';
const trustLabel = trustScore >= 80 ? 'Exzellent' : trustScore >= 60 ? 'Gut' : trustScore >= 40 ? 'Aufbauend' : 'Neu';
const completedDeals = dbUser.sellerDeals.length;
const memberSince = dbUser.createdAt.toLocaleDateString('de-DE', { month: 'long', year: 'numeric' });
const cityDisplay = dbUser.city || '';

// Mask phone for display
function maskPhone(phone: string | null): string {
    if (!phone) return '';
    if (phone.length < 6) return phone;
    return phone.slice(0, 6) + ' ***' + phone.slice(-2);
}
---

<BaseLayout title="Mein Profil – Ehren-Deal">
    <Header />
    <main class="profile-main">
        <div class="container">
            <!-- Profile Header -->
            <div class="profile-banner">
                <div class="banner-bg"></div>
                <div class="profile-info">
                    <div class="profile-avatar">{initials}</div>
                    <div class="profile-details">
                        <div class="profile-name-row">
                            <h1 class="profile-name">{fullName}</h1>
                            {dbUser.idVerified && (
                                <span class="trust-badge trust-kyc">KYC-verifiziert</span>
                            )}
                            {dbUser.emailVerified && (
                                <span class="trust-badge trust-verified">Bestätigt</span>
                            )}
                        </div>
                        <p class="profile-since">
                            Mitglied seit {memberSince}{cityDisplay ? ` · ${cityDisplay}` : ''}
                        </p>
                        <div class="profile-stats-row">
                            <div class="pstat">
                                <span class="pstat-val">{trustScore}</span><span
                                    class="pstat-label">Trust Score</span>
                            </div>
                            <div class="pstat">
                                <span class="pstat-val">{dbUser.listings.length}</span><span
                                    class="pstat-label">Anzeigen</span>
                            </div>
                            <div class="pstat">
                                <span class="pstat-val">{completedDeals}</span><span
                                    class="pstat-label">Verkäufe</span>
                            </div>
                        </div>
                    </div>
                    <div class="profile-actions hide-mobile">
                        <a href="/inserat-erstellen" class="btn btn-primary"
                            >+ Anzeige aufgeben</a
                        >
                        <a href="/nachrichten" class="btn btn-secondary"
                            >Nachrichten</a
                        >
                    </div>
                </div>
            </div>

            <div class="profile-grid">
                <!-- Left: Verification + Settings -->
                <div class="profile-left">
                    <!-- Verification Status -->
                    <div class="card">
                        <h3 class="card-section-title">Verifizierungsstatus</h3>
                        <div class="verif-list">
                            <!-- E-Mail -->
                            <div class={`verif-item ${dbUser.emailVerified ? 'done' : 'pending'}`}>
                                <div class={`verif-icon ${dbUser.emailVerified ? 'success' : 'warning'}`}>
                                    {dbUser.emailVerified ? (
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"></polyline></svg>
                                    ) : (
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line></svg>
                                    )}
                                </div>
                                <div>
                                    <div class="verif-name">E-Mail-Adresse</div>
                                    <div class="verif-sub">{dbUser.email}</div>
                                </div>
                                {dbUser.emailVerified ? (
                                    <span class="badge badge-success">Bestätigt</span>
                                ) : (
                                    <button id="resend-email-btn" class="btn btn-secondary btn-sm">→ Erneut senden</button>
                                )}
                            </div>
                            <!-- Phone -->
                            <div class={`verif-item ${dbUser.phoneVerified ? 'done' : 'pending'}`}>
                                <div class={`verif-icon ${dbUser.phoneVerified ? 'success' : 'warning'}`}>
                                    {dbUser.phoneVerified ? (
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"></polyline></svg>
                                    ) : (
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line></svg>
                                    )}
                                </div>
                                <div>
                                    <div class="verif-name">Handynummer</div>
                                    <div class="verif-sub">{dbUser.phone ? maskPhone(dbUser.phone) : 'Nicht hinterlegt'}</div>
                                </div>
                                {dbUser.phoneVerified ? (
                                    <span class="badge badge-success">Bestätigt</span>
                                ) : (
                                    <button id="verify-phone-btn" class="btn btn-secondary btn-sm">→ Verifizieren</button>
                                )}
                            </div>
                            <!-- KYC -->
                            <div class={`verif-item ${dbUser.idVerified ? 'done' : 'pending'}`}>
                                <div class={`verif-icon ${dbUser.idVerified ? 'success' : 'warning'}`}>
                                    {dbUser.idVerified ? (
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"></polyline></svg>
                                    ) : (
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line></svg>
                                    )}
                                </div>
                                <div>
                                    <div class="verif-name">Personalausweis (KYC)</div>
                                    <div class="verif-sub">{dbUser.idVerified ? 'Vollständig verifiziert' : 'Noch nicht verifiziert'}</div>
                                </div>
                                {dbUser.idVerified ? (
                                    <span class="badge badge-success">KYC</span>
                                ) : (
                                    <button id="start-kyc-btn" class="btn btn-secondary btn-sm">→ Jetzt</button>
                                )}
                            </div>
                        </div>
                        <div class="trust-score">
                            <div class="trust-score-label">
                                <span>Vertrauens-Score</span>
                                <span style={`color:var(--color-success); font-weight:700;`}>{trustLabel}</span>
                            </div>
                            <div class="trust-score-bar-wrap">
                                <div class="trust-score-bar" style={`width:${trustScore}%`}></div>
                            </div>
                            <div style="display:flex; justify-content:space-between; font-size:var(--text-xs); color:var(--color-text-faint); margin-top:4px;">
                                <span>0</span>
                                <span style="font-weight:700; color:var(--color-success);">{trustScore} / 100</span>
                                <span>100</span>
                            </div>
                        </div>
                    </div>

                    <!-- Quick Links -->
                    <div class="card" style="margin-top:var(--space-4);">
                        <h3 class="card-section-title">Konto</h3>
                        <div class="quick-links">
                            <a href="/einstellungen" class="quick-link">
                                <svg
                                    width="16"
                                    height="16"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2"
                                    ><circle cx="12" cy="12" r="3"
                                    ></circle><path
                                        d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"
                                    ></path></svg
                                >
                                Einstellungen
                            </a>
                            <a href="/sicherheit" class="quick-link">
                                <svg
                                    width="16"
                                    height="16"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2"
                                    ><path
                                        d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"
                                    ></path></svg
                                >
                                Sicherheitscenter
                            </a>
                            <a href="/nachrichten" class="quick-link">
                                <svg
                                    width="16"
                                    height="16"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2"
                                    ><path
                                        d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"
                                    ></path></svg
                                >
                                Nachrichten
                            </a>
                        </div>
                    </div>
                </div>

                <!-- Right: Listings + Reviews -->
                <div class="profile-right">
                    <!-- My Listings -->
                    <div class="card">
                        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:var(--space-5);">
                            <h3 class="card-section-title" style="margin:0;">Meine Anzeigen</h3>
                            <a href="/inserat-erstellen" class="btn btn-primary btn-sm">+ Neu</a>
                        </div>
                        <div class="my-listings-list">
                            {dbUser.listings.length === 0 ? (
                                <p class="text-sm text-foreground/60 font-light">Du hast noch keine Anzeigen erstellt.</p>
                            ) : (
                                dbUser.listings.map((l) => (
                                    <a href={`/inserat/${l.id}`} class="my-listing-item" style="text-decoration:none; color:inherit;">
                                        <img
                                            src={l.images[0]?.url || '/placeholder.jpg'}
                                            alt={l.title}
                                            class="my-listing-img"
                                        />
                                        <div class="my-listing-info">
                                            <div class="my-listing-title">{l.title}</div>
                                            <div class="my-listing-price">{(l.price / 100).toLocaleString("de-DE")} €</div>
                                            <div class="my-listing-meta">{l.city} · {l.createdAt.toLocaleDateString('de-DE')}</div>
                                        </div>
                                        <div class="my-listing-actions">
                                            <span class={`badge ${l.status === 'ACTIVE' ? 'badge-success' : l.status === 'SOLD' ? 'badge-neutral' : 'badge-warning'}`} style="font-size:0.6rem;">
                                                {l.status === 'ACTIVE' ? 'Aktiv' : l.status === 'SOLD' ? 'Verkauft' : l.status === 'RESERVED' ? 'Reserviert' : l.status}
                                            </span>
                                        </div>
                                    </a>
                                ))
                            )}
                        </div>
                    </div>

                    <!-- Deals -->
                    <div class="card" style="margin-top:var(--space-5);">
                        <div style="display:flex; align-items:center; gap:var(--space-3); margin-bottom:var(--space-5);">
                            <h3 class="card-section-title" style="margin:0;">Abgeschlossene Deals</h3>
                        </div>
                        {completedDeals === 0 ? (
                            <p class="text-sm text-foreground/60 font-light">Noch keine abgeschlossenen Deals.</p>
                        ) : (
                            <p class="text-sm text-foreground/80 font-light">
                                Du hast <strong>{completedDeals}</strong> Deal{completedDeals !== 1 ? 's' : ''} erfolgreich abgeschlossen.
                                <a href="/dashboard/deals" class="text-primary hover:underline ml-1">Alle anzeigen →</a>
                            </p>
                        )}
                    </div>
                </div>
            </div>
        </div>
    </main>
    <Footer />
</BaseLayout>

<style>
    .profile-main { @apply pb-16 min-h-screen text-foreground font-body; }

    .profile-banner { @apply border-b border-foreground/[.20] relative overflow-hidden; }
    .banner-bg { @apply absolute inset-0 bg-secondary/40 opacity-50; }

    .profile-info { @apply relative flex flex-wrap items-center gap-6 py-10 px-6 sm:px-12 max-w-7xl mx-auto z-10; }
    .profile-avatar { @apply w-24 h-24 bg-secondary border border-foreground/[.22] flex items-center justify-center text-3xl font-headings font-light text-primary flex-shrink-0; }

    .profile-details { @apply flex-1; }
    .profile-name-row { @apply flex flex-wrap items-center gap-3 mb-2; }
    .profile-name { @apply text-2xl font-headings font-light tracking-wide text-foreground m-0; }

    .trust-badge { @apply text-[10px] font-condensed font-medium px-2.5 py-1 inline-flex items-center gap-1 uppercase tracking-[.1em] border; }
    .trust-kyc { @apply bg-foreground/[.12] text-foreground/75 border-foreground/[.20]; }
    .trust-verified { @apply bg-primary/[.04] text-primary/70 border-primary/10; }

    .profile-since { @apply text-xs text-foreground/80 mb-5 font-condensed tracking-wider; }

    .profile-stats-row { @apply flex flex-wrap gap-8; }
    .pstat { @apply flex flex-col gap-0.5; }
    .pstat-val { @apply text-xl font-headings font-light text-foreground; }
    .pstat-label { @apply text-[10px] font-condensed uppercase tracking-[.12em] text-foreground/80; }

    .profile-actions { @apply flex flex-col gap-3; }

    /* Profile Grid */
    .profile-grid { @apply grid grid-cols-1 lg:grid-cols-[320px_1fr] gap-8 mt-8 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8; }

    .card { @apply bg-secondary/40 border border-foreground/[.20] p-6; }
    .card-section-title { @apply text-[10px] font-condensed uppercase tracking-[.15em] text-foreground/80 mb-5 m-0; }

    /* Verification */
    .verif-list { @apply flex flex-col gap-3; }
    .verif-item { @apply flex items-center gap-4 p-4 bg-foreground/[.12] border border-foreground/[.22] transition-colors; }
    .verif-item.done { @apply bg-success/[.03] border-success/10; }
    .verif-item.pending { @apply bg-warning/[.03] border-warning/10; }

    .verif-icon { @apply w-9 h-9 flex items-center justify-center flex-shrink-0; }
    .verif-icon.success { @apply bg-success/[.08] text-success; }
    .verif-icon.warning { @apply bg-warning/[.08] text-warning; }

    .verif-name { @apply text-sm font-medium text-foreground/80 mb-0.5; }
    .verif-sub { @apply text-xs text-foreground/80; }
    .verif-item > :last-child { @apply ml-auto flex-shrink-0; }

    .trust-score { @apply mt-6 pt-5 border-t border-foreground/[.20]; }
    .trust-score-label { @apply flex justify-between text-xs font-condensed uppercase tracking-wider text-foreground/80 mb-3; }
    .trust-score-bar-wrap { @apply bg-foreground/[.12] h-1.5 overflow-hidden mb-1.5; }
    .trust-score-bar { @apply h-full bg-success/60; }

    /* Quick Links */
    .quick-links { @apply flex flex-col gap-1; }
    .quick-link { @apply flex items-center gap-3 p-3 text-xs font-condensed uppercase tracking-wider text-foreground/80 transition-all hover:bg-foreground/[.12] hover:text-foreground/80; }

    /* My Listings */
    .my-listings-list { @apply flex flex-col gap-4; }
    .my-listing-item { @apply flex items-center gap-4 p-3 border border-foreground/[.22] transition-all hover:border-primary/30 hover:bg-foreground/[.12]; }
    .my-listing-img { @apply w-20 h-16 object-cover flex-shrink-0 bg-secondary; }
    .my-listing-info { @apply flex-1 min-w-0; }
    .my-listing-title { @apply text-sm font-medium text-foreground/80 truncate mb-1; }
    .my-listing-price { @apply text-base font-headings font-light text-primary; }
    .my-listing-meta { @apply text-[10px] text-foreground/80 mt-1 font-condensed tracking-wider; }
    .my-listing-actions { @apply flex flex-col items-end gap-2 flex-shrink-0; }

    /* Reviews */
    .review-summary { @apply flex items-center gap-2; }
    .stars { color: var(--gold); }
    .reviews-list { @apply flex flex-col gap-5; }
    .review-item { @apply p-5 bg-foreground/[.12] border border-foreground/[.22]; }
    .review-header { @apply flex items-center gap-3 mb-4; }
    .reviewer-avatar { @apply w-9 h-9 bg-secondary border border-foreground/[.22] flex items-center justify-center text-xs font-condensed text-foreground/75 flex-shrink-0; }
    .reviewer-name { @apply text-sm font-medium text-foreground/75 mb-0.5; }
    .review-date { @apply ml-auto text-[10px] text-foreground/80 font-condensed tracking-wider; }
    .review-text { @apply text-sm text-foreground/80 font-light leading-relaxed mb-3; }

    @media (max-width: 1024px) {
        .profile-info { @apply px-6; }
    }
    @media (max-width: 600px) {
        .profile-info { @apply flex-col text-center; }
        .profile-stats-row, .profile-name-row { @apply justify-center; }
        .hide-mobile { @apply w-full; }
        .profile-actions { @apply w-full; }
    }

    /* Modal */
    .modal-overlay { @apply fixed inset-0 bg-black/60 z-50 flex items-center justify-center p-4; display:none; }
    .modal-overlay.open { display:flex; }
    .modal-box { @apply bg-background border border-foreground/20 p-8 max-w-md w-full; }
    .modal-title { @apply text-lg font-headings font-light text-foreground mb-4; }
    .modal-input { @apply w-full p-3 bg-secondary/40 border border-foreground/20 text-foreground text-sm mb-4 outline-none; }
    .modal-input:focus { @apply border-primary/50; }
    .modal-actions { @apply flex gap-3 justify-end; }
    .modal-msg { @apply text-xs text-foreground/60 mb-3; }
    .modal-msg.error { @apply text-red-400; }
    .modal-msg.success { @apply text-green-400; }
</style>

<!-- Phone Verification Modal -->
<div id="phone-modal" class="modal-overlay">
    <div class="modal-box">
        <h3 class="modal-title">Handynummer verifizieren</h3>
        <div id="phone-step-1">
            <p class="modal-msg">Wir senden einen 6-stelligen Code an deine Handynummer.</p>
            {!dbUser.phone && (
                <input id="phone-input" type="tel" class="modal-input" placeholder="+49 151 12345678" />
            )}
            {dbUser.phone && (
                <p class="text-sm text-foreground/80 mb-4">Nummer: {maskPhone(dbUser.phone)}</p>
            )}
            <div id="phone-msg-1" class="modal-msg"></div>
            <div class="modal-actions">
                <button id="phone-cancel" class="btn btn-ghost btn-sm">Abbrechen</button>
                <button id="phone-send-btn" class="btn btn-primary btn-sm">Code senden</button>
            </div>
        </div>
        <div id="phone-step-2" style="display:none;">
            <p class="modal-msg">Gib den 6-stelligen Code ein, den du per SMS erhalten hast.</p>
            <input id="phone-code-input" type="text" class="modal-input" placeholder="123456" maxlength="6" inputmode="numeric" pattern="[0-9]*" />
            <div id="phone-msg-2" class="modal-msg"></div>
            <div class="modal-actions">
                <button id="phone-back" class="btn btn-ghost btn-sm">Zurück</button>
                <button id="phone-verify-btn" class="btn btn-primary btn-sm">Bestätigen</button>
            </div>
        </div>
    </div>
</div>

<script>
function fetchWithTimeout(url: string, opts: RequestInit = {}, timeoutMs = 15000): Promise<Response> {
    const ctrl = new AbortController();
    const timer = setTimeout(() => ctrl.abort(), timeoutMs);
    return fetch(url, { ...opts, signal: ctrl.signal }).finally(() => clearTimeout(timer));
}

// Email resend
document.getElementById('resend-email-btn')?.addEventListener('click', async (e) => {
    const btn = e.currentTarget as HTMLButtonElement;
    btn.disabled = true;
    btn.textContent = 'Wird gesendet...';
    try {
        const res = await fetchWithTimeout('/api/verify/email/send', { method: 'POST' });
        const data = await res.json();
        if (data.ok) {
            btn.textContent = '✓ Gesendet!';
            btn.classList.remove('btn-secondary');
            btn.classList.add('btn-ghost');
        } else {
            btn.textContent = 'Fehler – Erneut versuchen';
            btn.disabled = false;
        }
    } catch (err) {
        btn.textContent = err instanceof DOMException && err.name === 'AbortError'
            ? 'Timeout – Erneut versuchen' : 'Fehler – Erneut versuchen';
        btn.disabled = false;
    }
});

// Phone verification modal
const phoneModal = document.getElementById('phone-modal')!;
const phoneStep1 = document.getElementById('phone-step-1')!;
const phoneStep2 = document.getElementById('phone-step-2')!;

document.getElementById('verify-phone-btn')?.addEventListener('click', () => {
    phoneModal.classList.add('open');
    phoneStep1.style.display = '';
    phoneStep2.style.display = 'none';
});

document.getElementById('phone-cancel')?.addEventListener('click', () => phoneModal.classList.remove('open'));
document.getElementById('phone-back')?.addEventListener('click', () => {
    phoneStep1.style.display = '';
    phoneStep2.style.display = 'none';
});

phoneModal.addEventListener('click', (e) => {
    if (e.target === phoneModal) phoneModal.classList.remove('open');
});

document.getElementById('phone-send-btn')?.addEventListener('click', async () => {
    const msg = document.getElementById('phone-msg-1')!;
    const btn = document.getElementById('phone-send-btn') as HTMLButtonElement;
    const phoneInput = document.getElementById('phone-input') as HTMLInputElement | null;
    const phone = phoneInput?.value?.trim() || '';
    btn.disabled = true;
    msg.textContent = 'Sende Code...';
    msg.className = 'modal-msg';
    try {
        const res = await fetchWithTimeout('/api/verify/phone/send', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ phone }),
        }, 20000);
        const data = await res.json();
        if (data.ok) {
            phoneStep1.style.display = 'none';
            phoneStep2.style.display = '';
        } else {
            msg.textContent = data.error || 'Fehler beim Senden';
            msg.className = 'modal-msg error';
        }
    } catch (err) {
        msg.textContent = err instanceof DOMException && err.name === 'AbortError'
            ? 'Zeitüberschreitung – SMTP-Server nicht erreichbar' : 'Netzwerkfehler';
        msg.className = 'modal-msg error';
    }
    btn.disabled = false;
});

document.getElementById('phone-verify-btn')?.addEventListener('click', async () => {
    const msg = document.getElementById('phone-msg-2')!;
    const btn = document.getElementById('phone-verify-btn') as HTMLButtonElement;
    const code = (document.getElementById('phone-code-input') as HTMLInputElement).value.trim();
    if (code.length !== 6) { msg.textContent = 'Bitte 6-stelligen Code eingeben'; msg.className = 'modal-msg error'; return; }
    btn.disabled = true;
    msg.textContent = 'Prüfe...';
    msg.className = 'modal-msg';
    try {
        const res = await fetchWithTimeout('/api/verify/phone/verify', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ code }),
        });
        const data = await res.json();
        if (data.ok) {
            msg.textContent = '✓ Handynummer verifiziert!';
            msg.className = 'modal-msg success';
            setTimeout(() => location.reload(), 1500);
        } else {
            msg.textContent = data.error || 'Ungültiger Code';
            msg.className = 'modal-msg error';
        }
    } catch (err) {
        msg.textContent = err instanceof DOMException && err.name === 'AbortError'
            ? 'Zeitüberschreitung' : 'Netzwerkfehler';
        msg.className = 'modal-msg error';
    }
    btn.disabled = false;
});

// KYC button
document.getElementById('start-kyc-btn')?.addEventListener('click', async (e) => {
    const btn = e.currentTarget as HTMLButtonElement;
    btn.disabled = true;
    btn.textContent = 'Wird gestartet...';
    try {
        const res = await fetchWithTimeout('/api/kyc/start', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({}),
        });
        const data = await res.json();
        if (data.redirectUrl) {
            window.location.href = data.redirectUrl;
        } else {
            btn.textContent = data.error || 'Nicht verfügbar';
            setTimeout(() => { btn.textContent = '→ Jetzt'; btn.disabled = false; }, 3000);
        }
    } catch (err) {
        btn.textContent = err instanceof DOMException && err.name === 'AbortError'
            ? 'Zeitüberschreitung' : 'Fehler';
        setTimeout(() => { btn.textContent = '→ Jetzt'; btn.disabled = false; }, 3000);
    }
});
</script>
