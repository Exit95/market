---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { requireAdmin, isAuthContext } from "../../lib/auth-middleware";

const auth = await requireAdmin(Astro.request, Astro.cookies);
if (!isAuthContext(auth)) return Astro.redirect("/anmelden");

const headers = Astro.request.headers;
const origin = Astro.url.origin;

const [statsRes, queueRes, auditRes] = await Promise.all([
    fetch(`${origin}/api/admin/stats`, { headers }),
    fetch(`${origin}/api/admin/review-queue`, { headers }),
    fetch(`${origin}/api/admin/audit-log`, { headers }),
]);

const stats: any = statsRes.ok ? await statsRes.json() : {};
const queue: any[] = queueRes.ok ? await queueRes.json() : [];
const recent: any[] = auditRes.ok ? await auditRes.json() : [];

const critCount = queue.filter((e) => e.signals.some((s: any) => s.severity === "CRITICAL")).length;
const highCount = queue.filter((e) => e.signals.some((s: any) => s.severity === "HIGH")).length;
const unresolvedCount = queue.reduce((n: number, e: any) => n + e.signals.length, 0);

const SEV_COLOR: Record<string, string> = {
    CRITICAL: "#ef4444", HIGH: "#f97316", MEDIUM: "#eab308", LOW: "#64748b",
};

function formatCents(cents: number) {
    return (cents / 100).toLocaleString("de-DE", { style: "currency", currency: "EUR" });
}
---

<BaseLayout title="Admin Panel – Ehren-Deal">
    <Header />
    <main class="adm-page">
        <!-- Sidebar -->
        <aside class="adm-sidebar" id="sidebar">
            <div class="sidebar-head">
                <div class="sidebar-logo">
                    <svg viewBox="0 0 24 24" fill="none" stroke="#1B65A6" stroke-width="1.5" class="w-6 h-6"><path d="M10.5 6h9.75M10.5 6a1.5 1.5 0 1 1-3 0m3 0a1.5 1.5 0 1 0-3 0M3.75 6H7.5m3 12h9.75m-9.75 0a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m-3.75 0H7.5m9-6h3.75m-3.75 0a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m-9.75 0h9.75"/></svg>
                    <span class="sidebar-title">Admin Panel</span>
                </div>
                <span class="sidebar-user">{auth.user.email}</span>
            </div>
            <nav class="sidebar-nav">
                <button class="nav-item active" data-tab="overview">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="nav-icon"><path d="M3.75 6A2.25 2.25 0 0 1 6 3.75h2.25A2.25 2.25 0 0 1 10.5 6v2.25a2.25 2.25 0 0 1-2.25 2.25H6a2.25 2.25 0 0 1-2.25-2.25V6ZM3.75 15.75A2.25 2.25 0 0 1 6 13.5h2.25a2.25 2.25 0 0 1 2.25 2.25V18a2.25 2.25 0 0 1-2.25 2.25H6A2.25 2.25 0 0 1 3.75 18v-2.25ZM13.5 6a2.25 2.25 0 0 1 2.25-2.25H18A2.25 2.25 0 0 1 20.25 6v2.25A2.25 2.25 0 0 1 18 10.5h-2.25a2.25 2.25 0 0 1-2.25-2.25V6ZM13.5 15.75a2.25 2.25 0 0 1 2.25-2.25H18a2.25 2.25 0 0 1 2.25 2.25V18A2.25 2.25 0 0 1 18 20.25h-2.25A2.25 2.25 0 0 1 13.5 18v-2.25Z"/></svg>
                    Übersicht
                </button>
                <button class="nav-item" data-tab="users">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="nav-icon"><path d="M15 19.128a9.38 9.38 0 0 0 2.625.372 9.337 9.337 0 0 0 4.121-.952 4.125 4.125 0 0 0-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 0 1 8.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0 1 11.964-3.07M12 6.375a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0Zm8.25 2.25a2.625 2.625 0 1 1-5.25 0 2.625 2.625 0 0 1 5.25 0Z"/></svg>
                    Benutzer
                </button>
                <button class="nav-item" data-tab="listings">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="nav-icon"><path d="M13.5 16.875h3.375m0 0h3.375m-3.375 0V13.5m0 3.375v3.375M6 10.5h2.25a2.25 2.25 0 0 0 2.25-2.25V6a2.25 2.25 0 0 0-2.25-2.25H6A2.25 2.25 0 0 0 3.75 6v2.25A2.25 2.25 0 0 0 6 10.5Zm0 9.75h2.25A2.25 2.25 0 0 0 10.5 18v-2.25a2.25 2.25 0 0 0-2.25-2.25H6a2.25 2.25 0 0 0-2.25 2.25V18A2.25 2.25 0 0 0 6 20.25Zm9.75-9.75H18a2.25 2.25 0 0 0 2.25-2.25V6A2.25 2.25 0 0 0 18 3.75h-2.25A2.25 2.25 0 0 0 13.5 6v2.25a2.25 2.25 0 0 0 2.25 2.25Z"/></svg>
                    Inserate
                </button>
                <button class="nav-item" data-tab="deals">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="nav-icon"><path d="M2.25 18.75a60.07 60.07 0 0 1 15.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 0 1 3 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 0 0-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 0 1-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 0 0 3 15h-.75M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm3 0h.008v.008H18V10.5Zm-12 0h.008v.008H6V10.5Z"/></svg>
                    Deals
                </button>
                <button class="nav-item" data-tab="fraud">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="nav-icon"><path d="M12 9v3.75m0-10.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.75c0 5.592 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.57-.598-3.75h-.152c-3.196 0-6.1-1.249-8.25-3.286Zm0 13.036h.008v.008H12v-.008Z"/></svg>
                    Betrug
                    {unresolvedCount > 0 && <span class="nav-badge">{unresolvedCount}</span>}
                </button>
                <button class="nav-item" data-tab="audit">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="nav-icon"><path d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z"/></svg>
                    Protokoll
                </button>
            </nav>
            <div class="sidebar-footer">
                <a href="/" class="nav-item">Zurück zur Seite</a>
            </div>
        </aside>

        <!-- Content Area -->
        <div class="adm-content">
            <!-- Mobile Header -->
            <div class="mobile-bar">
                <button id="menuToggle" class="menu-btn" aria-label="Seitenmenü öffnen">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-5 h-5"><path d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"/></svg>
                </button>
                <span class="mobile-title">Admin Panel</span>
            </div>

            <!-- TAB: Overview -->
            <section class="tab-panel active" id="tab-overview">
                <div class="panel-header">
                    <h1 class="panel-title">Dashboard Übersicht</h1>
                    <span class="panel-subtitle">Ehren-Deal Plattform-Statistiken</span>
                </div>

                <div class="stats-grid">
                    <div class="stat-card">
                        <div class="stat-icon users-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z"/></svg>
                        </div>
                        <div class="stat-info">
                            <div class="stat-val">{stats.users?.total ?? 0}</div>
                            <div class="stat-label">Benutzer gesamt</div>
                            <div class="stat-sub">+{stats.users?.new30d ?? 0} letzte 30 Tage</div>
                        </div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-icon listings-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M20.25 7.5l-.625 10.632a2.25 2.25 0 0 1-2.247 2.118H6.622a2.25 2.25 0 0 1-2.247-2.118L3.75 7.5M10 11.25h4M3.375 7.5h17.25c.621 0 1.125-.504 1.125-1.125v-1.5c0-.621-.504-1.125-1.125-1.125H3.375c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125Z"/></svg>
                        </div>
                        <div class="stat-info">
                            <div class="stat-val">{stats.listings?.active ?? 0}</div>
                            <div class="stat-label">Aktive Inserate</div>
                            <div class="stat-sub">{stats.listings?.total ?? 0} gesamt, +{stats.listings?.new7d ?? 0} diese Woche</div>
                        </div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-icon deals-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z"/></svg>
                        </div>
                        <div class="stat-info">
                            <div class="stat-val">{stats.deals?.completed ?? 0}</div>
                            <div class="stat-label">Abgeschlossene Deals</div>
                            <div class="stat-sub">{stats.deals?.pending ?? 0} ausstehend, {stats.deals?.disputed ?? 0} strittig</div>
                        </div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-icon revenue-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M2.25 18.75a60.07 60.07 0 0 1 15.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 0 1 3 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 0 0-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 0 1-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 0 0 3 15h-.75M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm3 0h.008v.008H18V10.5Zm-12 0h.008v.008H6V10.5Z"/></svg>
                        </div>
                        <div class="stat-info">
                            <div class="stat-val">{formatCents(stats.revenue?.totalCents ?? 0)}</div>
                            <div class="stat-label">Gesamtvolumen</div>
                            <div class="stat-sub">Gebühren: {formatCents(stats.revenue?.feeCents ?? 0)}</div>
                        </div>
                    </div>
                </div>

                <!-- Quick metrics row -->
                <div class="metrics-row">
                    <div class="metric-pill danger">
                        <span class="metric-num">{stats.users?.banned ?? 0}</span>
                        <span class="metric-lbl">Gesperrt</span>
                    </div>
                    <div class="metric-pill warning">
                        <span class="metric-num">{stats.fraud?.unresolved ?? 0}</span>
                        <span class="metric-lbl">Offene Signale</span>
                    </div>
                    <div class="metric-pill info">
                        <span class="metric-num">{stats.volume30d?.count ?? 0}</span>
                        <span class="metric-lbl">Deals (30T)</span>
                    </div>
                    <div class="metric-pill gold">
                        <span class="metric-num">{formatCents(stats.volume30d?.totalCents ?? 0)}</span>
                        <span class="metric-lbl">Volumen (30T)</span>
                    </div>
                    <div class="metric-pill neutral">
                        <span class="metric-num">{stats.auditEvents7d ?? 0}</span>
                        <span class="metric-lbl">Events (7T)</span>
                    </div>
                </div>

                <!-- Recent Audit in overview -->
                <div class="panel-section">
                    <h2 class="section-title">Letzte Admin-Aktionen</h2>
                    {recent.length === 0 && <p class="empty-msg">Keine Einträge.</p>}
                    <div class="log-table-wrap">
                        <table class="log-table">
                            <thead><tr><th>Zeit</th><th>Aktion</th><th>Details</th></tr></thead>
                            <tbody>
                            {recent.slice(0, 10).map((a: any) => (
                                <tr>
                                    <td class="cell-muted cell-nowrap">{new Date(a.createdAt).toLocaleString("de-DE")}</td>
                                    <td><code class="action-code">{a.action}</code></td>
                                    <td class="cell-muted cell-truncate">{JSON.stringify(a.metaJson ?? {})}</td>
                                </tr>
                            ))}
                            </tbody>
                        </table>
                    </div>
                </div>
            </section>

            <!-- TAB: Users -->
            <section class="tab-panel" id="tab-users">
                <div class="panel-header">
                    <h1 class="panel-title">Benutzerverwaltung</h1>
                    <div class="panel-actions">
                        <input type="text" id="userSearch" placeholder="Suche nach E-Mail, Name oder ID..." class="search-input" />
                        <select id="userFilter" class="filter-select">
                            <option value="all">Alle</option>
                            <option value="banned">Gesperrt</option>
                            <option value="admin">Admins</option>
                            <option value="unverified">Unverifiziert</option>
                        </select>
                    </div>
                </div>
                <div id="usersContainer" class="data-container">
                    <p class="loading-msg">Lade Benutzer...</p>
                </div>
                <div id="usersPagination" class="pagination-bar"></div>
            </section>

            <!-- TAB: Listings -->
            <section class="tab-panel" id="tab-listings">
                <div class="panel-header">
                    <h1 class="panel-title">Inseratsverwaltung</h1>
                    <div class="panel-actions">
                        <input type="text" id="listingSearch" placeholder="Suche nach Titel oder ID..." class="search-input" />
                        <select id="listingFilter" class="filter-select">
                            <option value="all">Alle Status</option>
                            <option value="active">Aktiv</option>
                            <option value="draft">Entwurf</option>
                            <option value="sold">Verkauft</option>
                            <option value="removed">Entfernt</option>
                        </select>
                    </div>
                </div>
                <div id="listingsContainer" class="data-container">
                    <p class="loading-msg">Lade Inserate...</p>
                </div>
                <div id="listingsPagination" class="pagination-bar"></div>
            </section>

            <!-- TAB: Deals -->
            <section class="tab-panel" id="tab-deals">
                <div class="panel-header">
                    <h1 class="panel-title">Deal-Übersicht</h1>
                    <div class="panel-actions">
                        <select id="dealFilter" class="filter-select">
                            <option value="all">Alle Status</option>
                            <option value="pending">Ausstehend</option>
                            <option value="paid">Bezahlt</option>
                            <option value="completed">Abgeschlossen</option>
                            <option value="disputed">Strittig</option>
                            <option value="cancelled">Storniert</option>
                        </select>
                    </div>
                </div>
                <div id="dealsContainer" class="data-container">
                    <p class="loading-msg">Lade Deals...</p>
                </div>
                <div id="dealsPagination" class="pagination-bar"></div>
            </section>

            <!-- TAB: Fraud -->
            <section class="tab-panel" id="tab-fraud">
                <div class="panel-header">
                    <h1 class="panel-title">Betrugserkennung & Review Queue</h1>
                    <span class="panel-subtitle">{unresolvedCount} offene Signale</span>
                </div>
                <div class="fraud-stats">
                    <div class="fraud-stat crit"><span class="fs-num">{critCount}</span><span class="fs-lbl">CRITICAL</span></div>
                    <div class="fraud-stat high"><span class="fs-num">{highCount}</span><span class="fs-lbl">HIGH</span></div>
                    <div class="fraud-stat med"><span class="fs-num">{unresolvedCount - critCount - highCount}</span><span class="fs-lbl">MEDIUM/LOW</span></div>
                </div>
                {queue.length === 0 && <p class="empty-msg">Keine offenen Signale. Alles sicher.</p>}
                {queue.map((entry: any) => (
                    <div class="fraud-card" data-uid={entry.user.id}>
                        <div class="fc-header">
                            <div class="fc-user">
                                <span class="fc-name">{entry.user.firstName ?? "?"} {entry.user.lastName?.[0] ?? ""}.</span>
                                <code class="fc-email">{entry.user.email}</code>
                            </div>
                            <div class="fc-badges">
                                {entry.user.bannedAt && <span class="badge-sm danger">GESPERRT</span>}
                                {entry.user.shadowBanned && <span class="badge-sm warning">SHADOW</span>}
                                {entry.user.trustScore && <span class="badge-sm gold">{entry.user.trustScore.level} {entry.user.trustScore.score}pt</span>}
                            </div>
                        </div>
                        <div class="fc-signals">
                            {entry.signals.map((sig: any) => (
                                <div class="signal-row" style={`border-left: 3px solid ${SEV_COLOR[sig.severity] ?? "#999"}`}>
                                    <span class="sig-type">{sig.type}</span>
                                    <span class="sig-sev" style={`color:${SEV_COLOR[sig.severity]}`}>{sig.severity}</span>
                                    <code class="sig-meta">{JSON.stringify(sig.metaJson)}</code>
                                    <button class="action-btn ghost" data-resolve={sig.id}>Resolve</button>
                                </div>
                            ))}
                        </div>
                        <div class="fc-actions">
                            {!entry.user.bannedAt
                                ? <button class="action-btn danger" data-action="ban" data-uid={entry.user.id}>Sperren</button>
                                : <button class="action-btn outline" data-action="unban" data-uid={entry.user.id}>Entsperren</button>
                            }
                            {!entry.user.shadowBanned
                                ? <button class="action-btn warning" data-action="shadowban" data-uid={entry.user.id}>Shadowban</button>
                                : <button class="action-btn ghost" data-action="unshadowban" data-uid={entry.user.id}>Unshadowban</button>
                            }
                            {!entry.user.idVerified
                                ? <button class="action-btn gold" data-action="verifyId" data-uid={entry.user.id}>ID Verifizieren</button>
                                : <button class="action-btn ghost" data-action="removeVerifyId" data-uid={entry.user.id}>ID Entziehen</button>
                            }
                        </div>
                    </div>
                ))}
            </section>

            <!-- TAB: Audit Log -->
            <section class="tab-panel" id="tab-audit">
                <div class="panel-header">
                    <h1 class="panel-title">Audit-Protokoll</h1>
                    <span class="panel-subtitle">Letzte 50 Admin-Aktionen</span>
                </div>
                <div class="log-table-wrap">
                    <table class="log-table full">
                        <thead><tr><th>Zeitpunkt</th><th>Aktion</th><th>Details</th></tr></thead>
                        <tbody>
                        {recent.length === 0 && <tr><td colspan="3" class="empty-msg">Keine Einträge.</td></tr>}
                        {recent.map((a: any) => (
                            <tr>
                                <td class="cell-muted cell-nowrap">{new Date(a.createdAt).toLocaleString("de-DE")}</td>
                                <td><code class="action-code">{a.action}</code></td>
                                <td class="cell-muted cell-truncate">{JSON.stringify(a.metaJson ?? {})}</td>
                            </tr>
                        ))}
                        </tbody>
                    </table>
                </div>
            </section>
        </div>
    </main>
    <Footer />
</BaseLayout>

<style>
    /* ── Layout ── */
    .adm-page { display: flex; min-height: 100vh; background: #F8FAFB; }
    .adm-sidebar {
        width: 240px; min-height: 100vh; background: #FFFFFF; border-right: 1px solid #E5E7EB;
        display: flex; flex-direction: column; position: fixed; top: 0; left: 0; z-index: 100;
        transform: translateX(0);
    }
    .adm-content { flex: 1; margin-left: 240px; padding: 1.5rem 2rem 3rem; min-height: 100vh; }
    .sidebar-head { padding: 1.25rem 1rem .75rem; border-bottom: 1px solid #E5E7EB; }
    .sidebar-logo { display: flex; align-items: center; gap: .5rem; margin-bottom: .25rem; }
    .sidebar-title { font-family: 'Inter', system-ui, sans-serif; font-size: 1.1rem; color: #1B65A6; font-weight: 600; }
    .sidebar-user { font-size: .7rem; color: #64748B; display: block; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .sidebar-nav { flex: 1; padding: .75rem .5rem; display: flex; flex-direction: column; gap: 2px; }
    .nav-item {
        display: flex; align-items: center; gap: .6rem; padding: .55rem .75rem; border-radius: 4px;
        font-size: .82rem; color: #64748B; background: transparent; border: none; cursor: pointer;
        font-family: 'Inter', system-ui, sans-serif; text-decoration: none; width: 100%; text-align: left;
        transition: all .15s;
    }
    .nav-item:hover { background: rgba(27,101,166,.06); color: #1A2332; }
    .nav-item.active { background: rgba(27,101,166,.1); color: #1B65A6; font-weight: 600; }
    .nav-icon { width: 18px; height: 18px; flex-shrink: 0; }
    .nav-badge {
        margin-left: auto; background: #DC2626; color: #fff; font-size: .65rem; font-weight: 700;
        padding: 1px 6px; border-radius: 10px;
    }
    .sidebar-footer { padding: .75rem .5rem; border-top: 1px solid #E5E7EB; }
    .mobile-bar { display: none; }
    .menu-btn { background: none; border: none; color: #1A2332; cursor: pointer; padding: .25rem; }

    /* ── Tabs ── */
    .tab-panel { display: none; }
    .tab-panel.active { display: block; }

    /* ── Panel Header ── */
    .panel-header { margin-bottom: 1.5rem; }
    .panel-title { font-family: 'Inter', system-ui, sans-serif; font-size: 1.6rem; font-weight: 600; color: #1A2332; margin: 0; }
    .panel-subtitle { font-size: .78rem; color: #64748B; }
    .panel-actions { display: flex; gap: .5rem; margin-top: .75rem; flex-wrap: wrap; }

    /* ── Stats Grid ── */
    .stats-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 1rem; margin-bottom: 1.5rem; }
    .stat-card {
        background: #FFFFFF; border: 1px solid #E5E7EB; border-radius: 4px;
        padding: 1.25rem; display: flex; align-items: center; gap: 1rem;
    }
    .stat-icon {
        width: 42px; height: 42px; border-radius: 4px; display: flex; align-items: center; justify-content: center;
        flex-shrink: 0;
    }
    .stat-icon svg { width: 22px; height: 22px; }
    .users-icon { background: rgba(99,102,241,.12); color: #818cf8; }
    .listings-icon { background: rgba(27,101,166,.1); color: #1B65A6; }
    .deals-icon { background: rgba(34,160,107,.1); color: #22A06B; }
    .revenue-icon { background: rgba(27,101,166,.1); color: #1B65A6; }
    .stat-val { font-size: 1.5rem; font-weight: 700; color: #1A2332; line-height: 1.1; }
    .stat-label { font-size: .72rem; color: #64748B; text-transform: uppercase; font-family: 'Inter', system-ui, sans-serif; letter-spacing: .04em; }
    .stat-sub { font-size: .7rem; color: #94A3B8; }

    /* ── Metrics Row ── */
    .metrics-row { display: flex; gap: .6rem; flex-wrap: wrap; margin-bottom: 2rem; }
    .metric-pill {
        display: flex; align-items: center; gap: .4rem; padding: .4rem .8rem; border-radius: 4px;
        font-size: .75rem; font-family: 'Inter', system-ui, sans-serif;
    }
    .metric-num { font-weight: 700; }
    .metric-lbl { color: #64748B; }
    .metric-pill.danger { background: rgba(220,38,38,.08); color: #DC2626; border: 1px solid rgba(220,38,38,.2); }
    .metric-pill.warning { background: rgba(234,179,8,.08); color: #eab308; border: 1px solid rgba(234,179,8,.2); }
    .metric-pill.info { background: rgba(99,102,241,.08); color: #818cf8; border: 1px solid rgba(99,102,241,.2); }
    .metric-pill.gold { background: rgba(27,101,166,.08); color: #1B65A6; border: 1px solid rgba(27,101,166,.2); }
    .metric-pill.neutral { background: rgba(100,116,139,.08); color: #64748B; border: 1px solid rgba(100,116,139,.2); }

    /* ── Section ── */
    .panel-section { margin-top: 1.5rem; }
    .section-title { font-family: 'Inter', system-ui, sans-serif; font-size: .95rem; font-weight: 600; color: #1B65A6; text-transform: uppercase; letter-spacing: .06em; margin-bottom: .75rem; }

    /* ── Tables ── */
    .log-table-wrap { overflow-x: auto; }
    .log-table { width: 100%; border-collapse: collapse; font-size: .78rem; }
    .log-table th { text-align: left; padding: .5rem .75rem; color: #64748B; font-weight: 600; font-size: .7rem; text-transform: uppercase; letter-spacing: .05em; border-bottom: 1px solid #E5E7EB; }
    .log-table td { padding: .5rem .75rem; border-bottom: 1px solid #F1F5F9; }
    .cell-muted { color: #64748B; }
    .cell-nowrap { white-space: nowrap; }
    .cell-truncate { max-width: 350px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .action-code { background: rgba(27,101,166,.08); color: #1B65A6; padding: 1px 6px; border-radius: 3px; font-size: .72rem; }
    .empty-msg { color: #94A3B8; padding: 1.5rem; text-align: center; font-size: .85rem; }
    .loading-msg { color: #64748B; padding: 2rem; text-align: center; }

    /* ── Search & Filter ── */
    .search-input {
        background: #FFFFFF; border: 1px solid #E5E7EB; border-radius: 4px; color: #1A2332;
        padding: .45rem .75rem; font-size: .8rem; min-width: 240px; font-family: 'Inter', system-ui, sans-serif;
    }
    .search-input:focus { outline: none; border-color: rgba(27,101,166,.4); box-shadow: 0 0 0 2px rgba(27,101,166,.1); }
    .search-input::placeholder { color: #94A3B8; }
    .filter-select {
        background: #FFFFFF; border: 1px solid #E5E7EB; border-radius: 4px; color: #1A2332;
        padding: .45rem .6rem; font-size: .8rem; font-family: 'Inter', system-ui, sans-serif; cursor: pointer;
    }
    .filter-select:focus { outline: none; border-color: rgba(27,101,166,.4); }

    /* ── Data Container ── */
    .data-container { min-height: 200px; }
    .data-card {
        background: #FFFFFF; border: 1px solid #E5E7EB; border-radius: 4px;
        padding: .85rem 1rem; margin-bottom: .5rem; display: flex; align-items: center; gap: 1rem; flex-wrap: wrap;
    }
    .data-card:hover { border-color: rgba(27,101,166,.3); }

    /* ── Fraud ── */
    .fraud-stats { display: flex; gap: .75rem; margin-bottom: 1.5rem; }
    .fraud-stat {
        padding: .75rem 1.25rem; border-radius: 4px; text-align: center; min-width: 100px;
    }
    .fraud-stat.crit { background: rgba(220,38,38,.06); border: 1px solid rgba(220,38,38,.2); }
    .fraud-stat.high { background: rgba(249,115,22,.06); border: 1px solid rgba(249,115,22,.2); }
    .fraud-stat.med { background: rgba(234,179,8,.06); border: 1px solid rgba(234,179,8,.2); }
    .fs-num { display: block; font-size: 1.5rem; font-weight: 800; }
    .fraud-stat.crit .fs-num { color: #DC2626; }
    .fraud-stat.high .fs-num { color: #f97316; }
    .fraud-stat.med .fs-num { color: #eab308; }
    .fs-lbl { font-size: .65rem; color: #64748B; text-transform: uppercase; letter-spacing: .06em; font-weight: 600; }

    .fraud-card {
        background: #FFFFFF; border: 1px solid #E5E7EB; border-radius: 4px;
        padding: 1rem 1.25rem; margin-bottom: .6rem;
    }
    .fc-header { display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: .5rem; margin-bottom: .6rem; }
    .fc-user { display: flex; align-items: center; gap: .5rem; }
    .fc-name { font-weight: 600; font-size: .85rem; color: #1A2332; }
    .fc-email { font-size: .72rem; color: #64748B; }
    .fc-badges { display: flex; gap: .3rem; }
    .badge-sm {
        font-size: .6rem; padding: 2px 6px; border-radius: 3px; font-weight: 700;
        text-transform: uppercase; letter-spacing: .04em;
    }
    .badge-sm.danger { background: rgba(220,38,38,.1); color: #DC2626; }
    .badge-sm.warning { background: rgba(234,179,8,.1); color: #eab308; }
    .badge-sm.gold { background: rgba(27,101,166,.1); color: #1B65A6; }
    .fc-signals { display: flex; flex-direction: column; gap: .3rem; margin-bottom: .6rem; }
    .signal-row {
        display: flex; align-items: center; gap: .6rem; padding: .35rem .65rem;
        background: #F8FAFB; border-radius: 4px; flex-wrap: wrap;
    }
    .sig-type { font-weight: 700; font-size: .72rem; color: #1A2332; }
    .sig-sev { font-size: .7rem; font-weight: 700; }
    .sig-meta { font-size: .62rem; color: #94A3B8; flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .fc-actions { display: flex; gap: .4rem; flex-wrap: wrap; }

    /* ── Action Buttons ── */
    .action-btn {
        padding: .3rem .65rem; border-radius: 4px; font-size: .72rem; font-weight: 600; cursor: pointer;
        border: 1px solid transparent; font-family: 'Inter', system-ui, sans-serif; text-transform: uppercase;
        letter-spacing: .04em; transition: all .15s;
    }
    .action-btn.danger { background: rgba(220,38,38,.08); color: #DC2626; border-color: rgba(220,38,38,.2); }
    .action-btn.danger:hover { background: #DC2626; color: #fff; }
    .action-btn.warning { background: rgba(234,179,8,.08); color: #eab308; border-color: rgba(234,179,8,.2); }
    .action-btn.warning:hover { background: #eab308; color: #000; }
    .action-btn.gold { background: rgba(27,101,166,.08); color: #1B65A6; border-color: rgba(27,101,166,.2); }
    .action-btn.gold:hover { background: #1B65A6; color: #fff; }
    .action-btn.ghost { background: transparent; color: #64748B; border-color: #E5E7EB; }
    .action-btn.ghost:hover { color: #1A2332; border-color: #CBD5E1; }
    .action-btn.outline { background: transparent; color: #64748B; border-color: #E5E7EB; }
    .action-btn.outline:hover { color: #1A2332; border-color: #CBD5E1; }

    /* ── Pagination ── */
    .pagination-bar { display: flex; align-items: center; gap: .4rem; margin-top: 1rem; justify-content: center; }
    .page-btn {
        padding: .3rem .6rem; border-radius: 4px; font-size: .75rem; cursor: pointer;
        background: #FFFFFF; border: 1px solid #E5E7EB; color: #64748B;
        font-family: 'Inter', system-ui, sans-serif;
    }
    .page-btn:hover { border-color: rgba(27,101,166,.3); color: #1B65A6; }
    .page-btn.active { background: rgba(27,101,166,.08); color: #1B65A6; border-color: rgba(27,101,166,.3); }
    .page-btn:disabled { opacity: .3; cursor: default; }
    .page-info { font-size: .72rem; color: #64748B; margin: 0 .5rem; }

    /* ── Responsive ── */
    @media (max-width: 768px) {
        .adm-sidebar { transform: translateX(-100%); transition: transform .25s; }
        .adm-sidebar.open { transform: translateX(0); }
        .adm-content { margin-left: 0; padding: 1rem; }
        .mobile-bar {
            display: flex; align-items: center; gap: .75rem; padding: .5rem 0; margin-bottom: 1rem;
            border-bottom: 1px solid #E5E7EB;
        }
        .mobile-title { font-family: 'Inter', system-ui, sans-serif; color: #1B65A6; font-size: 1.1rem; }
        .stats-grid { grid-template-columns: 1fr 1fr; }
        .search-input { min-width: 100%; }
    }
</style>

<script>
    // ── Tab Switching ──
    const navBtns = document.querySelectorAll<HTMLButtonElement>('.nav-item[data-tab]');
    const panels = document.querySelectorAll<HTMLElement>('.tab-panel');
    const tabLoaded: Record<string, boolean> = { overview: true, fraud: true, audit: true };

    navBtns.forEach(btn => {
        btn.addEventListener('click', () => {
            const tab = btn.dataset.tab!;
            navBtns.forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
            panels.forEach(p => { p.classList.toggle('active', p.id === `tab-${tab}`); });
            // Close mobile sidebar
            document.getElementById('sidebar')?.classList.remove('open');
            // Lazy-load data tabs
            if (!tabLoaded[tab]) { tabLoaded[tab] = true; loadTab(tab); }
        });
    });

    // ── Mobile Menu ──
    document.getElementById('menuToggle')?.addEventListener('click', () => {
        document.getElementById('sidebar')?.classList.toggle('open');
    });

    // ── Data Loading ──
    function fmtCents(c: number) { return (c / 100).toLocaleString('de-DE', { style: 'currency', currency: 'EUR' }); }
    function fmtDate(d: string) { return new Date(d).toLocaleDateString('de-DE', { day: '2-digit', month: '2-digit', year: '2-digit' }); }
    function esc(s: string) { const d = document.createElement('div'); d.textContent = s; return d.innerHTML; }

    async function loadTab(tab: string, page = 1) {
        if (tab === 'users') await loadUsers(page);
        if (tab === 'listings') await loadListings(page);
        if (tab === 'deals') await loadDeals(page);
    }

    // ── Users ──
    async function loadUsers(page = 1) {
        const q = (document.getElementById('userSearch') as HTMLInputElement)?.value || '';
        const f = (document.getElementById('userFilter') as HTMLSelectElement)?.value || 'all';
        const container = document.getElementById('usersContainer')!;
        container.innerHTML = '<p class="loading-msg">Lade Benutzer...</p>';
        try {
            const res = await fetch(`/api/admin/users?page=${page}&limit=20&q=${encodeURIComponent(q)}&filter=${f}`);
            const data = await res.json();
            if (!data.users?.length) { container.innerHTML = '<p class="empty-msg">Keine Benutzer gefunden.</p>'; return; }
            container.innerHTML = data.users.map((u: any) => `
                <div class="data-card">
                    <div style="flex:1;min-width:200px">
                        <div style="font-weight:600;font-size:.85rem;color:#1A2332">${esc(u.firstName || '')} ${esc(u.lastName || '')}</div>
                        <div style="font-size:.72rem;color:#64748B">${esc(u.email)} &middot; ${fmtDate(u.createdAt)}</div>
                    </div>
                    <div style="display:flex;gap:.3rem;flex-wrap:wrap;align-items:center">
                        ${u.role === 'ADMIN' ? '<span class="badge-sm gold">ADMIN</span>' : ''}
                        ${u.bannedAt ? '<span class="badge-sm danger">GESPERRT</span>' : ''}
                        ${u.emailVerified ? '<span class="badge-sm" style="background:rgba(34,160,107,.1);color:#22A06B">VERIFIZIERT</span>' : '<span class="badge-sm" style="background:rgba(100,116,139,.1);color:#64748B">UNVERIFIZIERT</span>'}
                        ${u.idVerified ? '<span class="badge-sm gold">ID ✓</span>' : ''}
                    </div>
                    <div style="display:flex;gap:.3rem">
                        ${!u.bannedAt ? `<button class="action-btn danger" onclick="adminAction('${u.id}','ban')">Sperren</button>` : `<button class="action-btn outline" onclick="adminAction('${u.id}','unban')">Entsperren</button>`}
                    </div>
                </div>
            `).join('');
            renderPagination('usersPagination', page, data.pagination?.pages || 1, (p: number) => loadUsers(p));
        } catch { container.innerHTML = '<p class="empty-msg">Fehler beim Laden.</p>'; }
    }

    // ── Listings ──
    async function loadListings(page = 1) {
        const q = (document.getElementById('listingSearch') as HTMLInputElement)?.value || '';
        const f = (document.getElementById('listingFilter') as HTMLSelectElement)?.value || 'all';
        const container = document.getElementById('listingsContainer')!;
        container.innerHTML = '<p class="loading-msg">Lade Inserate...</p>';
        try {
            const res = await fetch(`/api/admin/listings?page=${page}&limit=20&q=${encodeURIComponent(q)}&status=${f}`);
            const data = await res.json();
            if (!data.listings?.length) { container.innerHTML = '<p class="empty-msg">Keine Inserate gefunden.</p>'; return; }
            const statusColor: Record<string,string> = { ACTIVE: '#22A06B', DRAFT: '#64748B', SOLD: '#1B65A6', REMOVED: '#DC2626' };
            container.innerHTML = data.listings.map((l: any) => `
                <div class="data-card">
                    <div style="flex:1;min-width:200px">
                        <div style="font-weight:600;font-size:.85rem;color:#1A2332">${esc(l.title)}</div>
                        <div style="font-size:.72rem;color:#64748B">${esc(l.seller?.firstName || '?')} ${esc(l.seller?.lastName || '')} &middot; ${fmtDate(l.createdAt)}</div>
                    </div>
                    <div style="font-weight:700;color:#1B65A6;font-size:.9rem">${fmtCents(l.price)}</div>
                    <span class="badge-sm" style="background:${statusColor[l.status] || '#555'}22;color:${statusColor[l.status] || '#555'}">${l.status}</span>
                </div>
            `).join('');
            renderPagination('listingsPagination', page, data.pagination?.pages || 1, (p: number) => loadListings(p));
        } catch { container.innerHTML = '<p class="empty-msg">Fehler beim Laden.</p>'; }
    }

    // ── Deals ──
    async function loadDeals(page = 1) {
        const f = (document.getElementById('dealFilter') as HTMLSelectElement)?.value || 'all';
        const container = document.getElementById('dealsContainer')!;
        container.innerHTML = '<p class="loading-msg">Lade Deals...</p>';
        try {
            const res = await fetch(`/api/admin/deals?page=${page}&limit=20&status=${f}`);
            const data = await res.json();
            if (!data.deals?.length) { container.innerHTML = '<p class="empty-msg">Keine Deals gefunden.</p>'; return; }
            const stColor: Record<string,string> = { PENDING: '#eab308', PAID: '#818cf8', COMPLETED: '#22A06B', DISPUTED: '#DC2626', CANCELLED: '#64748B' };
            container.innerHTML = data.deals.map((d: any) => `
                <div class="data-card">
                    <div style="flex:1;min-width:180px">
                        <div style="font-weight:600;font-size:.82rem;color:#1A2332">${esc(d.listing?.title || 'Deal #' + d.id.slice(0,8))}</div>
                        <div style="font-size:.7rem;color:#64748B">Käufer: ${esc(d.buyer?.firstName || '?')} &middot; ${fmtDate(d.createdAt)}</div>
                    </div>
                    <div style="font-weight:700;color:#1B65A6;font-size:.9rem">${fmtCents(d.totalAmount)}</div>
                    <span class="badge-sm" style="background:${stColor[d.status] || '#555'}22;color:${stColor[d.status] || '#555'}">${d.status}</span>
                </div>
            `).join('');
            renderPagination('dealsPagination', page, data.pagination?.pages || 1, (p: number) => loadDeals(p));
        } catch { container.innerHTML = '<p class="empty-msg">Fehler beim Laden.</p>'; }
    }

    // ── Pagination ──
    function renderPagination(containerId: string, current: number, total: number, loader: (p: number) => void) {
        const el = document.getElementById(containerId);
        if (!el || total <= 1) { if (el) el.innerHTML = ''; return; }
        let html = `<button class="page-btn" ${current <= 1 ? 'disabled' : ''} data-p="${current - 1}">&laquo;</button>`;
        for (let i = 1; i <= total; i++) {
            if (total > 7 && i > 2 && i < total - 1 && Math.abs(i - current) > 1) {
                if (i === 3 || i === total - 2) html += '<span class="page-info">...</span>';
                continue;
            }
            html += `<button class="page-btn ${i === current ? 'active' : ''}" data-p="${i}">${i}</button>`;
        }
        html += `<button class="page-btn" ${current >= total ? 'disabled' : ''} data-p="${current + 1}">&raquo;</button>`;
        el.innerHTML = html;
        el.querySelectorAll<HTMLButtonElement>('.page-btn').forEach(b => {
            b.addEventListener('click', () => { if (!b.disabled) loader(parseInt(b.dataset.p!)); });
        });
    }

    // ── Search/Filter Listeners ──
    let userDebounce: any;
    document.getElementById('userSearch')?.addEventListener('input', () => { clearTimeout(userDebounce); userDebounce = setTimeout(() => loadUsers(), 350); });
    document.getElementById('userFilter')?.addEventListener('change', () => loadUsers());
    let listingDebounce: any;
    document.getElementById('listingSearch')?.addEventListener('input', () => { clearTimeout(listingDebounce); listingDebounce = setTimeout(() => loadListings(), 350); });
    document.getElementById('listingFilter')?.addEventListener('change', () => loadListings());
    document.getElementById('dealFilter')?.addEventListener('change', () => loadDeals());

    // ── Admin Actions (global) ──
    (window as any).adminAction = async (uid: string, action: string) => {
        const reason = action === 'ban' ? prompt('Sperrgrund:') : undefined;
        if (action === 'ban' && !reason) return;
        const res = await fetch(`/api/admin/users/${uid}/action`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ action, ...(reason && { reason }) }),
        });
        if (res.ok) location.reload();
        else alert('Fehler: ' + (await res.json()).error);
    };

    // ── Fraud Action Buttons ──
    document.querySelectorAll('[data-action]').forEach(btn => {
        (btn as HTMLElement).addEventListener('click', async () => {
            const uid = (btn as HTMLElement).dataset.uid!;
            const action = (btn as HTMLElement).dataset.action!;
            (window as any).adminAction(uid, action);
        });
    });

    document.querySelectorAll('[data-resolve]').forEach(btn => {
        (btn as HTMLElement).addEventListener('click', async () => {
            const sigId = (btn as HTMLElement).dataset.resolve!;
            const card = (btn as HTMLElement).closest('[data-uid]') as HTMLElement;
            const uid = card?.dataset.uid!;
            const res = await fetch(`/api/admin/users/${uid}/action`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ action: 'resolveSignal', signalId: sigId }),
            });
            if (res.ok) location.reload();
        });
    });
</script>
