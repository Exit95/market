---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<BaseLayout title="Kontakt & Support – Ehren-Deal">
    <Header />
    <main class="min-h-screen pt-12 pb-24">
        <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">

            <div class="mb-12">
                <h1 class="text-4xl md:text-5xl font-headings font-bold text-primary mb-3">Kontakt & Support</h1>
                <p class="text-foreground/80 text-lg font-light max-w-2xl">
                    Du hast Fragen, ein Problem oder brauchst Hilfe? Unser Support-Team ist für dich da.
                </p>
            </div>

            <div class="grid md:grid-cols-2 gap-8 mb-16">

                <!-- Contact Form -->
                <div class="bg-secondary/40 border border-foreground/[.20] p-6 md:p-8">
                    <h2 class="font-condensed font-semibold text-sm uppercase tracking-[.12em] text-foreground mb-6">Nachricht senden</h2>
                    <form class="flex flex-col gap-4" id="contactForm">
                        <div class="flex flex-col gap-2">
                            <label for="contact-name" class="text-sm font-medium text-foreground">Name *</label>
                            <input type="text" id="contact-name" name="name" required class="input-field" placeholder="Dein Name" />
                        </div>
                        <div class="flex flex-col gap-2">
                            <label for="contact-email" class="text-sm font-medium text-foreground">E-Mail-Adresse *</label>
                            <input type="email" id="contact-email" name="email" required class="input-field" placeholder="name@example.com" />
                        </div>
                        <div class="flex flex-col gap-2">
                            <label for="contact-subject" class="text-sm font-medium text-foreground">Betreff *</label>
                            <select id="contact-subject" name="subject" required class="input-field">
                                <option value="">Bitte wählen</option>
                                <option value="allgemein">Allgemeine Anfrage</option>
                                <option value="konto">Konto & Registrierung</option>
                                <option value="inserat">Inserat / Anzeige</option>
                                <option value="zahlung">Zahlung & Treuhand</option>
                                <option value="streitfall">Streitfall / Reklamation</option>
                                <option value="datenschutz">Datenschutz (DSGVO-Anfrage)</option>
                                <option value="sonstiges">Sonstiges</option>
                            </select>
                        </div>
                        <div class="flex flex-col gap-2">
                            <label for="contact-message" class="text-sm font-medium text-foreground">Nachricht *</label>
                            <textarea id="contact-message" name="message" rows="5" required class="input-field resize-y" placeholder="Beschreibe dein Anliegen …"></textarea>
                        </div>
                        <button type="submit" class="btn btn-primary w-full mt-2">Nachricht absenden</button>
                    </form>
                </div>

                <!-- Contact Info -->
                <div class="flex flex-col gap-6">
                    <div class="bg-secondary/40 border border-foreground/[.20] p-6">
                        <div class="flex items-center gap-3 mb-3">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-primary flex-shrink-0"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.362 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.338 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
                            <h3 class="font-condensed font-semibold text-sm uppercase tracking-[.12em] text-foreground">Telefon / WhatsApp</h3>
                        </div>
                        <p class="text-sm text-foreground/80 font-light mb-2">Schnellster Kontaktweg:</p>
                        <a href="https://wa.me/4915757126123" class="text-primary font-medium text-sm hover:underline" target="_blank" rel="noopener noreferrer">+49 157 57126123</a>
                        <p class="text-xs text-foreground/75 font-light mt-3">WhatsApp bevorzugt – meist Antwort innerhalb weniger Stunden.</p>
                    </div>

                    <div class="bg-secondary/40 border border-foreground/[.20] p-6">
                        <div class="flex items-center gap-3 mb-3">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-primary flex-shrink-0"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
                            <h3 class="font-condensed font-semibold text-sm uppercase tracking-[.12em] text-foreground">Support per E-Mail</h3>
                        </div>
                        <p class="text-sm text-foreground/80 font-light mb-2">Für allgemeine Anfragen und Support:</p>
                        <a href="mailto:office@ehren-deal.de" class="text-primary font-medium text-sm hover:underline">office@ehren-deal.de</a>
                        <p class="text-xs text-foreground/75 font-light mt-3">Antwortzeit: In der Regel innerhalb von 24 Stunden (Mo–Fr).</p>
                    </div>

                    <div class="bg-secondary/40 border border-foreground/[.20] p-6">
                        <div class="flex items-center gap-3 mb-3">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-primary flex-shrink-0"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
                            <h3 class="font-condensed font-semibold text-sm uppercase tracking-[.12em] text-foreground">Streitfälle & Reklamationen</h3>
                        </div>
                        <p class="text-sm text-foreground/80 font-light mb-2">Bei Problemen mit einem Deal oder einer Transaktion:</p>
                        <a href="mailto:office@ehren-deal.de" class="text-primary font-medium text-sm hover:underline">office@ehren-deal.de</a>
                        <p class="text-xs text-foreground/75 font-light mt-3">Bitte gib immer deine Deal-ID oder Inserat-Nummer an.</p>
                    </div>

                    <div class="bg-secondary/40 border border-foreground/[.20] p-6">
                        <div class="flex items-center gap-3 mb-3">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-primary flex-shrink-0"><rect x="3" y="11" width="18" height="11" rx="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
                            <h3 class="font-condensed font-semibold text-sm uppercase tracking-[.12em] text-foreground">Datenschutz-Anfragen</h3>
                        </div>
                        <p class="text-sm text-foreground/80 font-light mb-2">Auskunft, Löschung oder Berichtigung deiner Daten (Art. 15–21 DSGVO):</p>
                        <a href="mailto:office@ehren-deal.de" class="text-primary font-medium text-sm hover:underline">office@ehren-deal.de</a>
                    </div>

                    <div class="bg-secondary/40 border border-foreground/[.20] p-6">
                        <div class="flex items-center gap-3 mb-3">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-primary flex-shrink-0"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
                            <h3 class="font-condensed font-semibold text-sm uppercase tracking-[.12em] text-foreground">Geschäftszeiten</h3>
                        </div>
                        <div class="text-sm text-foreground/80 font-light space-y-1">
                            <p>Montag – Freitag: 09:00 – 18:00 Uhr</p>
                            <p>Samstag, Sonntag & Feiertage: Kein Support</p>
                        </div>
                    </div>
                </div>

            </div>

            <!-- FAQ hint -->
            <div class="border-t border-foreground/[.20] pt-10">
                <div class="bg-primary/5 border border-primary/20 p-6 flex items-start gap-4">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-primary flex-shrink-0 mt-0.5">
                        <circle cx="12" cy="12" r="10"></circle><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"></path><line x1="12" y1="17" x2="12.01" y2="17"></line>
                    </svg>
                    <div>
                        <p class="text-sm text-foreground font-medium mb-1">Häufige Fragen?</p>
                        <p class="text-sm text-foreground/80 font-light">Viele Antworten findest du auf unserer <a href="/sicherheit" class="text-primary hover:underline">Sicherheitsseite</a>. Dort erklären wir den Ehren-Handschlag, die Treuhand-Abwicklung und den KYC-Prozess im Detail.</p>
                    </div>
                </div>
            </div>

        </div>
    </main>
    <Footer />
</BaseLayout>

