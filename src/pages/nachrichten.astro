---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import ChatApp from "../components/ChatApp";
import { requireAuth, isAuthContext } from "../lib/auth-middleware";

const auth = await requireAuth(Astro.request, Astro.cookies);
if (!isAuthContext(auth)) return auth;

const currentUserId = auth.userId;
const listingId = Astro.url.searchParams.get("listing") || undefined;
---

<BaseLayout title="Nachrichten – Ehren-Deal">
    <Header />
    <main class="messenger-main">
        <ChatApp client:load currentUserId={currentUserId} listingId={listingId} />
    </main>
</BaseLayout>

<style>
    .messenger-main {
        height: calc(100vh - 65px);
        width: 100%;
        overflow: hidden;
        background: #F8FAFB;
    }
    @media (min-width: 640px) {
        .messenger-main {
            height: calc(100vh - 65px);
        }
    }
</style>
