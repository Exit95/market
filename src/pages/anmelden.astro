---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<BaseLayout title="Anmelden – Ehren-Deal">
    <Header />
    <main class="auth-main">
        <div class="auth-container">
            <!-- Left: Form -->
            <div class="auth-form-side">
                <div class="auth-inner">
                    <div class="auth-logo">
                        <span class="text-primary">Ehren-Deal</span>
                    </div>

                    <!-- Mobile Trust Stats (visible on mobile only) -->
                    <div class="flex md:hidden items-center justify-between gap-3 mb-6 px-1">
                        <div class="flex items-center gap-1.5">
                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-primary"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                            <span class="text-[.65rem] text-text-secondary">100% Treuhand</span>
                        </div>
                        <div class="flex items-center gap-1.5">
                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-primary"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                            <span class="text-[.65rem] text-text-secondary">Verifizierte Nutzer</span>
                        </div>
                        <div class="flex items-center gap-1.5">
                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-primary"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                            <span class="text-[.65rem] text-text-secondary">Sichere Deals</span>
                        </div>
                    </div>

                    <!-- Tab Switch -->
                    <div class="auth-tabs">
                        <button class="auth-tab active" id="loginTab"
                            >Anmelden</button
                        >
                        <button class="auth-tab" id="registerTab"
                            >Registrieren</button
                        >
                    </div>

                    <!-- Login Form -->
                    <form class="auth-form" id="loginForm">
                        <div class="form-group">
                            <label class="label" for="loginEmail"
                                >E-Mail-Adresse</label
                            >
                            <div class="input-icon-wrap">
                                <svg
                                    width="16"
                                    height="16"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2"
                                    ><path
                                        d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"
                                    ></path><polyline points="22,6 12,13 2,6"
                                    ></polyline></svg
                                >
                                <input
                                    type="email"
                                    id="loginEmail"
                                    name="email"
                                    autocomplete="email"
                                    class="input input-with-icon"
                                    placeholder="name@beispiel.de"
                                />
                            </div>
                        </div>
                        <div class="form-group">
                            <div class="flex justify-between items-center mb-2">
                                <label
                                    class="label"
                                    for="loginPw"
                                    style="margin:0;">Passwort</label
                                >
                                <a
                                    href="/passwort-vergessen"
                                    class="text-body-sm text-primary hover:underline"
                                    >Vergessen?</a
                                >
                            </div>
                            <div class="input-icon-wrap">
                                <svg
                                    width="16"
                                    height="16"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2"
                                    ><rect
                                        x="3"
                                        y="11"
                                        width="18"
                                        height="11"
                                        rx="2"
                                        ry="2"></rect><path
                                        d="M7 11V7a5 5 0 0 1 10 0v4"
                                    ></path></svg
                                >
                                <input
                                    type="password"
                                    id="loginPw"
                                    name="password"
                                    autocomplete="current-password"
                                    class="input input-with-icon"
                                    placeholder="Dein Passwort"
                                />
                                <button
                                    type="button"
                                    class="pw-toggle"
                                    id="togglePw"
                                >
                                    <svg
                                        width="14"
                                        height="14"
                                        viewBox="0 0 24 24"
                                        fill="none"
                                        stroke="currentColor"
                                        stroke-width="2"
                                        ><path
                                            d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"
                                        ></path><circle cx="12" cy="12" r="3"
                                        ></circle></svg
                                    >
                                </button>
                            </div>
                        </div>

                        <!-- 2FA Info -->
                        <div class="twofa-info">
                            <svg
                                width="14"
                                height="14"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2"
                                ><path
                                    d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"
                                ></path></svg
                            >
                            2-Faktor-Authentifizierung schützt deinen Account
                        </div>

                        <div id="loginError" class="auth-error" style="display:none; color:#DC2626; background:#FEE2E2; border:1px solid rgba(220,38,38,0.3); padding:0.75rem 1rem; border-radius:10px; margin-bottom:1rem; font-size:0.875rem;"></div>

                        <button
                            type="submit"
                            class="btn-primary w-full btn-lg"
                            id="loginBtn"
                            ><svg class="animate-spin -ml-1 mr-2 h-4 w-4 hidden" id="loginSpinner" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path></svg><span id="loginBtnText">Anmelden</span></button
                        >

                    </form>

                    <!-- Register Form -->
                    <form class="auth-form hidden" id="registerForm">
                        <div class="form-row">
                            <div class="form-group" style="flex:1;">
                                <label class="label" for="firstName"
                                    >Vorname</label
                                >
                                <input
                                    type="text"
                                    id="firstName"
                                    name="firstName"
                                    autocomplete="given-name"
                                    class="input"
                                    placeholder="Max"
                                />
                            </div>
                            <div class="form-group" style="flex:1;">
                                <label class="label" for="lastName"
                                    >Nachname</label
                                >
                                <input
                                    type="text"
                                    id="lastName"
                                    name="lastName"
                                    autocomplete="family-name"
                                    class="input"
                                    placeholder="Mustermann"
                                />
                            </div>
                        </div>
                        <div class="form-group">
                            <label class="label" for="regEmail"
                                >E-Mail-Adresse</label
                            >
                            <input
                                type="email"
                                id="regEmail"
                                name="email"
                                autocomplete="email"
                                class="input"
                                placeholder="name@beispiel.de"
                            />
                        </div>
                        <div class="form-group">
                            <label class="label" for="phone"
                                >Handynummer (für 2FA)</label
                            >
                            <div class="phone-wrap">
                                <select class="input phone-prefix">
                                    <option>+49</option>
                                    <option>+43</option>
                                    <option>+41</option>
                                </select>
                                <input
                                    type="tel"
                                    id="phone"
                                    name="phone"
                                    autocomplete="tel"
                                    class="input"
                                    placeholder="0151 123 456 78"
                                />
                            </div>
                        </div>
                        <div class="form-group">
                            <label class="label" for="regPw">Passwort</label>
                            <input
                                type="password"
                                id="regPw"
                                name="password"
                                autocomplete="new-password"
                                class="input"
                                placeholder="Mindestens 8 Zeichen"
                            />
                            <div class="pw-strength-wrap">
                                <div class="pw-strength-bar" id="pwStrengthBar">
                                </div>
                            </div>
                            <div class="pw-strength-label" id="pwStrengthLabel">
                            </div>
                        </div>

                        <!-- KYC Info box -->
                        <div class="kyc-info-box">
                            <div class="kyc-info-header">
                                <svg
                                    width="16"
                                    height="16"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2"
                                    ><path
                                        d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"
                                    ></path><circle cx="12" cy="7" r="4"
                                    ></circle></svg
                                >
                                Identitätsprüfung (KYC)
                            </div>
                            <p>
                                Nach der Registrierung wirst du gebeten, deine
                                Identität mit einem Ausweisdokument zu
                                verifizieren. Dies schützt alle Nutzer vor
                                Betrug.
                            </p>
                            <div class="kyc-steps">
                                <div class="kyc-step">E-Mail bestätigen</div>
                                <div class="kyc-arrow">→</div>
                                <div class="kyc-step">Handy verifizieren</div>
                                <div class="kyc-arrow">→</div>
                                <div class="kyc-step">Ausweis hochladen</div>
                            </div>
                        </div>

                        <label
                            class="checklist-item"
                            style="margin-bottom:1rem;"
                        >
                            <input
                                type="checkbox"
                                id="regAgb"
                                style="width:18px;height:18px;accent-color:#1B65A6;"
                            />
                            <span class="text-body-sm text-text-secondary"
                                >Ich akzeptiere die <a
                                    href="/agb"
                                    class="text-primary hover:underline">AGB</a
                                > und die <a
                                    href="/datenschutz"
                                    class="text-primary hover:underline"
                                    >Datenschutzerklärung</a
                                ></span
                            >
                        </label>

                        <div id="registerError" class="auth-error" style="display:none; color:#DC2626; background:#FEE2E2; border:1px solid rgba(220,38,38,0.3); padding:0.75rem 1rem; border-radius:10px; margin-bottom:1rem; font-size:0.875rem;"></div>

                        <button
                            type="submit"
                            class="btn-primary w-full btn-lg"
                            id="registerBtn"
                            ><svg class="animate-spin -ml-1 mr-2 h-4 w-4 hidden" id="registerSpinner" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path></svg><span id="registerBtnText">Kostenlos registrieren</span></button
                        >
                    </form>
                </div>
            </div>

            <!-- Right: Benefits -->
            <div class="auth-benefits-side">
                <div class="auth-benefits-inner">
                    <h2 class="benefits-title">Warum Ehren-Deal?</h2>
                    <div class="benefits-list">
                        <div class="benefit-item">
                            <div class="benefit-icon">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                            </div>
                            <div>
                                <strong>Maximaler Schutz</strong>
                                <p>KYC-Verifizierung, Chat-Filter und optionale Treuhandzahlung reduzieren Betrugsrisiken erheblich.</p>
                            </div>
                        </div>
                        <div class="benefit-item">
                            <div class="benefit-icon">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                            </div>
                            <div>
                                <strong>Bewertungssystem</strong>
                                <p>Transparente Bewertungen schaffen Vertrauen zwischen Käufern und Verkäufern.</p>
                            </div>
                        </div>
                        <div class="benefit-item">
                            <div class="benefit-icon">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                            </div>
                            <div>
                                <strong>Sicherer Chat</strong>
                                <p>Nachrichten werden auf Betrugsmuster analysiert -- mit automatischen Warnungen.</p>
                            </div>
                        </div>
                        <div class="benefit-item">
                            <div class="benefit-icon">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path d="M20 12V8H6a2 2 0 0 1-2-2c0-1.1.9-2 2-2h12v4"/><path d="M4 6v12c0 1.1.9 2 2 2h14v-4"/><path d="M18 12a2 2 0 0 0-2 2c0 1.1.9 2 2 2h4v-4h-4z"/></svg>
                            </div>
                            <div>
                                <strong>Kostenlos inserieren</strong>
                                <p>Anzeigen erstellen ist kostenlos. Bei Verkauf: 0,50 Servicegebuehr (Käufer) + 5 % Provision (Verkäufer).</p>
                            </div>
                        </div>
                    </div>
                    <div class="stat-row">
                        <div class="auth-stat">
                            <span class="stat-num stat-num--blue">100%</span>
                            <span class="stat-label">Treuhand-Schutz</span>
                        </div>
                        <div class="auth-stat">
                            <span class="stat-num stat-num--green">KYC</span>
                            <span class="stat-label">Identitätsprüfung</span>
                        </div>
                        <div class="auth-stat">
                            <span class="stat-num stat-num--accent">0 EUR</span>
                            <span class="stat-label">Für Anzeigen</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>
    <Footer />
</BaseLayout>

<style>
    .auth-main { @apply min-h-[calc(100vh-70px)] flex items-center bg-background; }
    .auth-container { @apply grid grid-cols-1 md:grid-cols-2 min-h-[calc(100vh-70px)] w-full; }

    .auth-form-side { @apply flex items-center justify-center p-8 md:p-12 bg-surface; }
    .auth-inner { @apply w-full max-w-[420px]; }

    .auth-logo { @apply text-xl font-headings font-semibold flex items-center gap-3 mb-10 text-text tracking-wide; }

    .auth-tabs { @apply flex bg-background p-1 mb-8 rounded-DEFAULT border border-border; }
    .auth-tab { @apply flex-1 py-3 px-4 text-sm font-medium text-text-secondary cursor-pointer transition-all duration-300 outline-none rounded-DEFAULT; border: none; background: transparent; }
    .auth-tab:hover:not(.active) { @apply text-text; }
    .auth-tab.active { @apply bg-surface text-primary border border-border shadow-card; }

    .auth-form { @apply flex flex-col gap-5; }
    .form-group { @apply flex flex-col gap-2; }

    .input-icon-wrap { @apply relative flex items-center; }
    .input-icon-wrap > svg { @apply absolute left-4 text-text-muted pointer-events-none; }
    .input-with-icon { @apply pl-12; }

    .pw-toggle { @apply absolute right-3 p-2 bg-transparent border-none text-text-muted cursor-pointer transition-colors hover:text-text; }

    .twofa-info { @apply flex items-center gap-2 text-body-sm text-primary bg-primary-light/50 border border-primary/10 py-2.5 px-3 mb-4 rounded-DEFAULT; }

    .or-divider { @apply flex items-center gap-4 my-6 text-body-sm text-text-muted; }
    .or-divider::before, .or-divider::after { @apply content-[''] flex-1 h-[1px] bg-border; }

    .phone-wrap { @apply flex gap-3; }
    .phone-prefix { @apply w-[90px] flex-shrink-0; }

    .pw-strength-wrap { @apply h-1 bg-border mt-2 overflow-hidden rounded-full; }
    .pw-strength-bar { @apply h-full transition-all duration-300 w-0 rounded-full; }
    .pw-strength-label { @apply text-caption mt-1.5; }

    .kyc-info-box { @apply bg-primary-light/50 border border-primary/10 p-5 my-3 rounded-DEFAULT; }
    .kyc-info-header { @apply flex items-center gap-2 text-primary font-semibold text-body-sm mb-3; }
    .kyc-info-box p { @apply text-body-sm text-text-secondary leading-relaxed mb-4; }

    .kyc-steps { @apply flex flex-wrap items-center gap-2; }
    .kyc-step { @apply text-caption bg-background px-3 py-1.5 text-text-secondary border border-border rounded-sm; }
    .kyc-arrow { @apply text-text-muted text-caption; }

    .checklist-item { @apply flex items-start gap-3 cursor-pointer; }

    .hidden { display: none !important; }
    .form-row { @apply flex flex-col sm:flex-row gap-4; }

    /* Benefits Side — navy bg with white text */
    .auth-benefits-side { @apply relative flex items-center justify-center p-6 md:p-12 bg-navy overflow-hidden; }
    .auth-benefits-side::before {
        content: "";
        @apply absolute -top-1/2 -right-[30%] w-[600px] h-[600px] opacity-[0.06] pointer-events-none;
        background: radial-gradient(circle, #1B65A6 0%, transparent 70%);
    }
    .auth-benefits-inner { @apply w-full max-w-[420px] relative z-10; }

    .benefits-title { @apply text-h2 text-white mb-10; }
    .benefits-list { @apply flex flex-col gap-8 mb-12; }
    .benefit-item { @apply flex items-start gap-5; }
    .benefit-icon { @apply flex-shrink-0 w-10 h-10 flex items-center justify-center border border-white/20 bg-white/10 text-white rounded-DEFAULT; }
    .benefit-item strong { @apply block font-semibold text-white mb-1 text-sm; }
    .benefit-item p { @apply text-body-sm text-white/70 leading-relaxed; }

    .stat-row { @apply flex flex-wrap gap-8 p-6 border border-white/15 bg-white/[.06] rounded-DEFAULT; }
    .auth-stat { @apply flex flex-col gap-1; }
    .stat-num { @apply text-2xl font-headings font-semibold tracking-tight; }
    .stat-num--blue { @apply text-primary-light; }
    .stat-num--green { color: #6EE7B7; }
    .stat-num--accent { color: #FCD34D; }
    .stat-label { @apply text-caption text-white/60; }

    /* Form elements */
    .label { @apply block text-label font-semibold text-text-secondary mb-2; }
    .input { @apply w-full px-4 py-3 rounded-DEFAULT border border-border bg-surface text-text placeholder-text-muted focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all duration-200 text-sm; }
    .btn-lg { @apply py-3.5 text-sm; }
    .w-full { width: 100%; }
</style>

<script>
    // Tab switching
    const loginTab = document.getElementById("loginTab")!;
    const registerTab = document.getElementById("registerTab")!;
    const loginForm = document.getElementById("loginForm")!;
    const registerForm = document.getElementById("registerForm")!;

    loginTab.addEventListener("click", () => {
        loginTab.classList.add("active");
        registerTab.classList.remove("active");
        loginForm.classList.remove("hidden");
        registerForm.classList.add("hidden");
    });
    registerTab.addEventListener("click", () => {
        registerTab.classList.add("active");
        loginTab.classList.remove("active");
        registerForm.classList.remove("hidden");
        loginForm.classList.add("hidden");
    });

    // Password toggle
    document.getElementById("togglePw")?.addEventListener("click", () => {
        const pw = document.getElementById("loginPw") as HTMLInputElement;
        pw.type = pw.type === "password" ? "text" : "password";
    });

    // Auto-open register tab if ?tab=register
    {
        const urlParams = new URLSearchParams(window.location.search);
        if (urlParams.get("tab") === "register") {
            registerTab.click();
        }
    }

    // Password strength meter
    document.getElementById("regPw")?.addEventListener("input", (e) => {
        const val = (e.target as HTMLInputElement).value;
        const bar = document.getElementById("pwStrengthBar")!;
        const label = document.getElementById("pwStrengthLabel")!;
        let strength = 0;
        if (val.length >= 8) strength++;
        if (/[A-Z]/.test(val)) strength++;
        if (/[0-9]/.test(val)) strength++;
        if (/[^A-Za-z0-9]/.test(val)) strength++;

        const levels = [
            { color: "#ef4444", text: "Schwach", width: "25%" },
            { color: "#f59e0b", text: "Mittel", width: "50%" },
            { color: "#06b6d4", text: "Gut", width: "75%" },
            { color: "#10b981", text: "Sehr sicher", width: "100%" },
        ];
        if (val.length === 0 || strength === 0) {
            bar.style.width = val.length > 0 ? "10%" : "0";
            bar.style.background = "#ef4444";
            label.style.color = "#ef4444";
            label.textContent = val.length > 0 ? "Sehr schwach" : "";
            return;
        }
        const lvl = levels[Math.min(strength - 1, 3)];
        bar.style.background = lvl.color;
        bar.style.width = lvl.width;
        label.style.color = lvl.color;
        label.textContent = lvl.text;
    });

    // ── Login Submit ─────────────────────────────────────────────────────────
    loginForm.addEventListener("submit", async (e) => {
        e.preventDefault();
        const errEl = document.getElementById("loginError")!;
        const btn = document.getElementById("loginBtn") as HTMLButtonElement;
        errEl.style.display = "none";

        const email = (document.getElementById("loginEmail") as HTMLInputElement).value.trim();
        const password = (document.getElementById("loginPw") as HTMLInputElement).value;

        if (!email || !password) {
            errEl.textContent = "Bitte E-Mail und Passwort eingeben.";
            errEl.style.display = "block";
            return;
        }

        const btnText = document.getElementById("loginBtnText")!;
        const spinner = document.getElementById("loginSpinner")!;
        btn.disabled = true;
        btnText.textContent = "Wird angemeldet...";
        spinner.classList.remove("hidden");

        try {
            const res = await fetch("/api/auth/login", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({ email, password }),
            });
            const data = await res.json();

            if (!res.ok) {
                errEl.textContent = data.error || "Anmeldung fehlgeschlagen.";
                errEl.style.display = "block";
                btn.disabled = false;
                btnText.textContent = "Anmelden";
                spinner.classList.add("hidden");
                return;
            }

            // Erfolg – weiterleiten (mit optionalem redirect-Parameter)
            const params = new URLSearchParams(window.location.search);
            const redirect = params.get("redirect");
            if (redirect && redirect.startsWith("/")) {
                window.location.href = redirect;
            } else if (data.user?.role === "ADMIN") {
                window.location.href = "/admin";
            } else {
                window.location.href = "/";
            }
        } catch {
            errEl.textContent = "Netzwerkfehler. Bitte erneut versuchen.";
            errEl.style.display = "block";
            btn.disabled = false;
            btnText.textContent = "Anmelden";
            spinner.classList.add("hidden");
        }
    });

    // ── Register Submit ──────────────────────────────────────────────────────
    registerForm.addEventListener("submit", async (e) => {
        e.preventDefault();
        const errEl = document.getElementById("registerError")!;
        const btn = document.getElementById("registerBtn") as HTMLButtonElement;
        errEl.style.display = "none";

        const email = (document.getElementById("regEmail") as HTMLInputElement).value.trim();
        const password = (document.getElementById("regPw") as HTMLInputElement).value;
        const firstName = (document.getElementById("firstName") as HTMLInputElement)?.value.trim() || undefined;
        const lastName = (document.getElementById("lastName") as HTMLInputElement)?.value.trim() || undefined;
        const phonePrefix = (document.querySelector(".phone-prefix") as HTMLSelectElement)?.value || "+49";
        const phoneRaw = (document.getElementById("phone") as HTMLInputElement)?.value.trim();
        const phone = phoneRaw ? `${phonePrefix}${phoneRaw.replace(/^0+/, '')}` : undefined;

        const agbChecked = (document.getElementById("regAgb") as HTMLInputElement)?.checked;

        if (!email || !password) {
            errEl.textContent = "Bitte alle Pflichtfelder ausfüllen.";
            errEl.style.display = "block";
            return;
        }
        if (password.length < 8) {
            errEl.textContent = "Passwort muss mindestens 8 Zeichen haben.";
            errEl.style.display = "block";
            return;
        }
        if (!agbChecked) {
            errEl.textContent = "Bitte akzeptiere die AGB und Datenschutzerklärung.";
            errEl.style.display = "block";
            return;
        }

        const btnText = document.getElementById("registerBtnText")!;
        const spinner = document.getElementById("registerSpinner")!;
        btn.disabled = true;
        btnText.textContent = "Wird registriert...";
        spinner.classList.remove("hidden");

        try {
            const res = await fetch("/api/auth/register", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({ email, password, firstName, lastName, phone }),
            });
            const data = await res.json();

            if (!res.ok) {
                errEl.textContent = data.error || "Registrierung fehlgeschlagen.";
                errEl.style.display = "block";
                btn.disabled = false;
                btnText.textContent = "Kostenlos registrieren";
                spinner.classList.add("hidden");
                return;
            }

            // Erfolg – weiterleiten (mit optionalem redirect-Parameter)
            const params = new URLSearchParams(window.location.search);
            const redirect = params.get("redirect");
            window.location.href = (redirect && redirect.startsWith("/")) ? redirect : "/";
        } catch {
            errEl.textContent = "Netzwerkfehler. Bitte erneut versuchen.";
            errEl.style.display = "block";
            btn.disabled = false;
            btnText.textContent = "Kostenlos registrieren";
            spinner.classList.add("hidden");
        }
    });
</script>
