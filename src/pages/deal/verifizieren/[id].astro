---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Header from "../../../components/Header.astro";
import Footer from "../../../components/Footer.astro";
import HandshakeApp from "../../../components/HandshakeApp";
import { requireAuth, isAuthContext } from "../../../lib/auth-middleware";
import { prisma } from "../../../lib/auth";
import { ShieldAlert } from "lucide-react";

// 1. Authenticate user
const auth = await requireAuth(Astro.request, Astro.cookies);
if (!isAuthContext(auth)) return auth;

// 2. Fetch Deal
const dealId = Astro.params.id;
if (!dealId) {
    return new Response("Deal ID missing", { status: 400 });
}

const deal = await prisma.deal.findUnique({
    where: { id: dealId },
    include: {
        listing: { select: { title: true, price: true } },
        buyer: { select: { firstName: true } },
        seller: { select: { firstName: true } }
    }
});

if (!deal) {
    return new Response("Deal not found", { status: 404 });
}

if (deal.buyerId !== auth.userId && deal.sellerId !== auth.userId) {
    return new Response("Forbidden", { status: 403 });
}

const role = deal.buyerId === auth.userId ? 'buyer' : 'seller';
const partnerName = role === 'buyer' ? deal.seller.firstName : deal.buyer.firstName;
---

<BaseLayout title="Handschlag-Verifizierung – Ehren-Deal">
    <Header />
    <main class="min-h-[calc(100vh-140px)] py-12 px-4 bg-background">
        <div class="max-w-3xl mx-auto">
            <div class="mb-8 text-center">
                <h1 class="text-h2 text-text mb-3">
                    Ehren-Deal abschließen
                </h1>
                <p class="text-text-secondary max-w-lg mx-auto">
                    Triff dich mit <strong class="text-text">{partnerName}</strong> zur Übergabe von <strong class="text-text">"{deal.listing.title}"</strong>.
                </p>
            </div>

            {deal.handshakeStatus === 'VERIFIED' ? (
                <div class="card p-8 text-center">
                    <div class="w-20 h-20 bg-success-light rounded-full border border-success/20 flex items-center justify-center mb-6 mx-auto">
                        <svg class="w-10 h-10 text-success" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                        </svg>
                    </div>
                    <h2 class="text-h3 text-text mb-2">Bereits Abgeschlossen</h2>
                    <p class="text-text-secondary mb-8 max-w-sm mx-auto">
                        Dieser Deal wurde bereits erfolgreich über den digitalen Handschlag bestätigt.
                    </p>
                    <a href="/dashboard" class="btn-primary inline-block">
                        Zum Dashboard
                    </a>
                </div>
            ) : deal.verificationMethod !== 'QR_CODE' && deal.verificationMethod !== 'SHIPPING' ? (
               <div class="card p-6 flex items-start gap-4 border-accent/20">
                   <ShieldAlert className="w-8 h-8 shrink-0 text-accent" />
                   <div>
                       <h3 class="font-medium text-text text-base mb-1">Falsche Verifizierungsmethode</h3>
                       <p class="text-text-secondary">Für diesen Deal ist der digitale Handschlag (QR-Code) nicht aktiviert. Die Abwicklung erfolgt über den Standard-Käuferschutz.</p>
                       <a href="/dashboard" class="inline-block mt-4 text-sm text-primary hover:text-primary/80 transition-colors">Zurück zur Übersicht</a>
                   </div>
               </div>
            ) : (
                <div style="animation-delay: 100ms;">
                    <HandshakeApp
                        client:only="react"
                        dealId={deal.id}
                        currentUserId={auth.userId}
                        role={role}
                        initialStatus={deal.handshakeStatus}
                    />
                </div>
            )}

            <div class="mt-12 text-center text-xs text-text-secondary">
                Probleme bei der Übergabe?
                <a href="/hilfe" class="text-primary hover:text-primary/80 ml-1 transition-colors">Support kontaktieren</a>
            </div>
        </div>
    </main>
    <Footer />
</BaseLayout>
