---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Header from "../../../components/Header.astro";
import Footer from "../../../components/Footer.astro";
import HandshakeApp from "../../../components/HandshakeApp";
import { requireAuth, isAuthContext } from "../../../lib/auth-middleware";
import { prisma } from "../../../lib/auth";
import { ShieldAlert } from "lucide-react";

// 1. Authenticate user
const auth = await requireAuth(Astro.request, Astro.cookies);
if (!isAuthContext(auth)) return auth;

// 2. Fetch Deal
const dealId = Astro.params.id;
if (!dealId) {
    return new Response("Deal ID missing", { status: 400 });
}

const deal = await prisma.deal.findUnique({
    where: { id: dealId },
    include: {
        listing: { select: { title: true, price: true } },
        buyer: { select: { firstName: true } },
        seller: { select: { firstName: true } }
    }
});

if (!deal) {
    return new Response("Deal not found", { status: 404 });
}

if (deal.buyerId !== auth.userId && deal.sellerId !== auth.userId) {
    return new Response("Forbidden", { status: 403 });
}

const role = deal.buyerId === auth.userId ? 'buyer' : 'seller';
const partnerName = role === 'buyer' ? deal.seller.firstName : deal.buyer.firstName;
---

<BaseLayout title="Handschlag-Verifizierung – Ehren-Deal">
    <Header />
    <main class="min-h-[calc(100vh-140px)] bg-slate-50 py-12 px-4">
        <div class="max-w-3xl mx-auto">
            <div class="mb-8 text-center animate-fade-up">
                <h1 class="text-3xl md:text-4xl font-black text-slate-800 tracking-tight mb-3">
                    Ehren-Deal abschließen
                </h1>
                <p class="text-slate-500 max-w-lg mx-auto">
                    Triff dich mit <strong>{partnerName}</strong> zur Übergabe von <strong class="text-slate-800">"{deal.listing.title}"</strong>.
                </p>
            </div>

            {deal.handshakeStatus === 'VERIFIED' ? (
                <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-8 text-center animate-fade-up">
                    <div class="w-20 h-20 bg-green-100 rounded-full flex items-center justify-center mb-6 mx-auto shadow-inner">
                        <svg class="w-10 h-10 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                        </svg>
                    </div>
                    <h2 class="text-2xl font-black text-slate-800 mb-2">Bereits Abgeschlossen!</h2>
                    <p class="text-slate-500 mb-8 max-w-sm mx-auto">
                        Dieser Deal wurde bereits erfolgreich über den digitalen Handschlag bestätigt.
                    </p>
                    <a href="/dashboard" class="inline-block bg-[var(--ehren-primary)] text-white px-8 py-3 rounded-xl font-bold hover:scale-105 transition-all shadow-sm">
                        Zum Dashboard
                    </a>
                </div>
            ) : deal.verificationMethod !== 'QR_CODE' && deal.verificationMethod !== 'SHIPPING' ? (
               <div class="bg-amber-50 text-amber-800 border border-amber-200 p-6 rounded-2xl flex items-start gap-4 shadow-sm animate-fade-up">
                   <ShieldAlert class="w-8 h-8 shrink-0 text-amber-600" />
                   <div>
                       <h3 class="font-bold text-lg mb-1">Falsche Verifizierungsmethode</h3>
                       <p class="text-amber-700">Für diesen Deal ist der digitale Handschlag (QR-Code) nicht aktiviert. Die Abwicklung erfolgt über den Standard-Käuferschutz.</p>
                       <a href="/dashboard" class="inline-block mt-4 text-sm font-bold text-amber-800 underline hover:text-amber-900">Zurück zur Übersicht</a>
                   </div>
               </div>
            ) : (
                <div class="animate-fade-up" style="animation-delay: 100ms;">
                    <HandshakeApp 
                        client:only="react" 
                        dealId={deal.id} 
                        currentUserId={auth.userId} 
                        role={role} 
                        initialStatus={deal.handshakeStatus}
                    />
                </div>
            )}
            
            <div class="mt-12 text-center text-sm text-slate-400">
                Probleme bei der Übergabe? 
                <a href="/hilfe" class="text-[var(--ehren-primary)] hover:underline ml-1">Support kontaktieren</a>
            </div>
        </div>
    </main>
    <Footer />
</BaseLayout>
