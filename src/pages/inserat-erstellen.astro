---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { categories } from "../data/listings";
import { lucia } from "../lib/auth";

// Auth check – redirect to login if not authenticated
const sessionId = Astro.cookies.get(lucia.sessionCookieName)?.value;
if (!sessionId) return Astro.redirect("/anmelden?redirect=/inserat-erstellen");

let sessionUser: { id: string } | null = null;
try {
    const result = await lucia.validateSession(sessionId);
    sessionUser = result.user;
} catch { /* session invalid */ }
if (!sessionUser) return Astro.redirect("/anmelden?redirect=/inserat-erstellen");
---

<BaseLayout title="Anzeige aufgeben – Ehren-Deal">
    <Header />
    <main class="create-main">
        <div class="container-sm">
            <!-- Breadcrumb -->
            <nav class="font-condensed text-xs uppercase tracking-wider mb-6 text-foreground/60" aria-label="Breadcrumb">
                <a href="/" class="hover:text-foreground transition-colors">Startseite</a>
                <span class="mx-1.5">&gt;</span>
                <span class="text-foreground/90">Anzeige aufgeben</span>
            </nav>

            <div class="create-header">
                <h1 class="section-title">Anzeige aufgeben</h1>
                <p class="section-subtitle">
                    Inseriere deine Waren sicher und erreiche tausende
                    verifizierte Käufer.
                </p>
            </div>

            <!-- Progress Steps -->
            <div class="progress-steps">
                <div class="progress-step active" data-step="1">
                    <div class="step-circle">1</div>
                    <span>Kategorie</span>
                </div>
                <div class="progress-line"></div>
                <div class="progress-step" data-step="2">
                    <div class="step-circle">2</div>
                    <span>Details</span>
                </div>
                <div class="progress-line"></div>
                <div class="progress-step" data-step="3">
                    <div class="step-circle">3</div>
                    <span>Fotos</span>
                </div>
                <div class="progress-line"></div>
                <div class="progress-step" data-step="4">
                    <div class="step-circle">4</div>
                    <span>Prüfung</span>
                </div>
            </div>

            <!-- Step 1: Category -->
            <div class="step-content" id="step1">
                <div class="card">
                    <h2 class="card-title">Kategorie auswählen</h2>
                    <div class="cat-select-grid">
                        {
                            categories.map((cat) => (
                                <button
                                    class="cat-select-btn"
                                    data-cat={cat.slug}
                                >
                                    <img
                                        src={cat.icon}
                                        alt={cat.label}
                                        class="cat-icon"
                                        loading="lazy"
                                    />
                                    <span class="cat-label">{cat.label}</span>
                                </button>
                            ))
                        }
                    </div>
                    <div class="step-nav">
                        <div></div>
                        <button class="btn btn-primary" id="toStep2" disabled
                            >Weiter →</button
                        >
                    </div>
                </div>
            </div>

            <!-- Step 2: Details -->
            <div class="step-content hidden" id="step2">
                <div class="card">
                    <h2 class="card-title">Anzeigen-Details</h2>
                    <form id="detailsForm">
                        <div class="form-group">
                            <label class="label" for="title"
                                >Titel der Anzeige *</label
                            >
                            <input
                                type="text"
                                id="title"
                                name="title"
                                autocomplete="off"
                                class="input"
                                placeholder="z.B. iPhone 15 Pro Max 256GB, unbenutzt"
                                required
                                maxlength="80"
                            />
                            <div class="char-count">0 / 80</div>
                        </div>
                        <div class="form-group">
                            <label class="label" for="desc"
                                >Beschreibung *</label
                            >
                            <textarea
                                id="desc"
                                name="description"
                                autocomplete="off"
                                class="input"
                                rows="6"
                                placeholder="Beschreibe deine Ware so genau wie möglich – Zustand, Mängel, Zubehör..."
                                required></textarea>
                        </div>
                        <div class="form-row">
                            <div class="form-group" style="flex:1;">
                                <label class="label" for="price"
                                    >Preis (€) *</label
                                >
                                <input
                                    type="number"
                                    id="price"
                                    name="price"
                                    autocomplete="off"
                                    class="input"
                                    placeholder="0,00"
                                    min="0"
                                    step="0.01"
                                    required
                                />
                                <div
                                    id="priceWarning"
                                    class="price-warning hidden"
                                >
                                    <svg
                                        width="14"
                                        height="14"
                                        viewBox="0 0 24 24"
                                        fill="none"
                                        stroke="currentColor"
                                        stroke-width="2"
                                        class="text-amber-500"
                                        ><path
                                            d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"
                                        ></path><line
                                            x1="12"
                                            y1="9"
                                            x2="12"
                                            y2="13"></line><line
                                            x1="12"
                                            y1="17"
                                            x2="12.01"
                                            y2="17"></line></svg
                                    >
                                    Ungewöhnlich niedriger Preis – könnte Betrug sein
                                </div>
                                <div class="mt-2 p-2.5 bg-primary/[.05] border border-primary/15 rounded-sm">
                                    <p class="text-[.65rem] text-foreground/60 font-light leading-relaxed">
                                        <strong class="text-primary/80 font-medium">Hinweis:</strong> Bei jedem Verkauf fällt eine Verkaufsprovision von <strong class="text-foreground/80">5 %</strong> an.
                                        Beispiel: Bei 100,00 € Verkaufspreis erhältst du <strong class="text-foreground/80">95,00 €</strong> ausgezahlt.
                                        <span id="provisionPreview"></span>
                                    </p>
                                </div>
                            </div>
                            <div class="form-group" style="flex:1;">
                                <label class="label" for="condition"
                                    >Zustand *</label
                                >
                                <select id="condition" name="condition" autocomplete="off" class="input">
                                    <option value="">Bitte wählen</option>
                                    <option value="neu"
                                        >Neu (unbenutzt, mit OVP)</option
                                    >
                                    <option value="sehr_gut"
                                        >Sehr gut (kaum benutzt)</option
                                    >
                                    <option value="gut"
                                        >Gut (leichte Gebrauchsspuren)</option
                                    >
                                    <option value="akzeptabel"
                                        >Akzeptabel (sichtbare Mängel)</option
                                    >
                                </select>
                            </div>
                        </div>
                        <div class="form-row" style="align-items:flex-end;">
                            <div class="form-group" style="flex:1;">
                                <label class="label" for="plz">PLZ *</label>
                                <input
                                    type="text"
                                    id="plz"
                                    name="postalCode"
                                    autocomplete="postal-code"
                                    class="input"
                                    placeholder="z.B. 10115"
                                    maxlength="5"
                                    pattern="[0-9]{5}"
                                    inputmode="numeric"
                                    required
                                />
                            </div>
                            <div class="form-group" style="flex:2;">
                                <label class="label" for="city">Ort</label>
                                <input
                                    type="text"
                                    id="city"
                                    name="city"
                                    autocomplete="address-level2"
                                    class="input"
                                    placeholder="wird automatisch ermittelt"
                                />
                            </div>
                            <div class="form-group" style="flex:0 0 auto;">
                                <button
                                    type="button"
                                    id="geoLocateBtn"
                                    class="btn btn-secondary btn-sm"
                                    style="white-space:nowrap; display:flex; align-items:center; gap:6px; height:42px;"
                                    title="Standort ermitteln"
                                >
                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><circle cx="12" cy="12" r="3"></circle><line x1="12" y1="2" x2="12" y2="6"></line><line x1="12" y1="18" x2="12" y2="22"></line><line x1="2" y1="12" x2="6" y2="12"></line><line x1="18" y1="12" x2="22" y2="12"></line></svg>
                                    <span id="geoLocateText">Ort ermitteln</span>
                                </button>
                            </div>
                        </div>
                        <div id="geoStatus" class="hidden" style="font-size:0.85rem; margin-top:-8px; margin-bottom:8px; color:var(--ehren-accent,#c8973a);"></div>
                        <div class="form-group">
                            <label class="label">Versand & Übergabe</label>
                            <div class="toggle-group">
                                <label class="toggle-option">
                                    <input
                                        type="checkbox"
                                        name="shipping"
                                        value="abholung"
                                        checked
                                        class="toggle-check"
                                    />
                                    <span>Selbstabholung</span>
                                </label>
                                <label class="toggle-option">
                                    <input
                                        type="checkbox"
                                        name="shipping"
                                        value="versand"
                                        class="toggle-check"
                                    />
                                    <span>Versand möglich</span>
                                </label>
                                <label class="toggle-option">
                                    <input
                                        type="checkbox"
                                        name="shipping"
                                        value="treuhand"
                                        class="toggle-check"
                                    />
                                    <span>Treuhand-Kauf anbieten</span>
                                </label>
                            </div>
                        </div>
                        <div class="step-nav">
                            <button
                                type="button"
                                class="btn btn-secondary"
                                id="backToStep1">← Zurück</button
                            >
                            <button
                                type="button"
                                class="btn btn-primary"
                                id="toStep3">Weiter →</button
                            >
                        </div>
                    </form>
                </div>
            </div>

            <!-- Step 3: Photos -->
            <div class="step-content hidden" id="step3">
                <div class="card">
                    <h2 class="card-title">Fotos hinzufügen</h2>
                    <p
                        class="text-muted"
                        style="font-size:var(--text-sm); margin-bottom:var(--space-6);"
                    >
                        Bis zu 12 Fotos, max. 10 MB pro Bild. Klare, gut
                        beleuchtete Fotos erhöhen deine Chancen erheblich.
                    </p>

                    <!-- Upload Drop Zone -->
                    <div class="upload-area" id="uploadArea">
                        <svg
                            width="40"
                            height="40"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="1.5"
                            class="text-primary"
                            ><rect x="3" y="3" width="18" height="18" rx="2"
                            ></rect><circle cx="8.5" cy="8.5" r="1.5"
                            ></circle><polyline points="21 15 16 10 5 21"
                            ></polyline></svg
                        >
                        <p>Fotos hierher ziehen oder klicken</p>
                        <span
                            >JPEG / PNG / WEBP · max. 10 MB pro Bild · bis zu 12
                            Fotos</span
                        >
                        <input
                            type="file"
                            accept="image/jpeg,image/png,image/webp"
                            multiple
                            class="hidden"
                            id="photoInput"
                        />
                    </div>

                    <!-- Upload Progress -->
                    <div
                        id="uploadProgress"
                        class="hidden"
                        style="margin-top:var(--space-4);"
                    >
                        <div
                            style="display:flex; align-items:center; gap:var(--space-3); font-size:var(--text-sm);"
                        >
                            <div class="upload-spinner"></div>
                            <span id="uploadProgressText"
                                >Wird hochgeladen…</span
                            >
                        </div>
                        <div
                            class="upload-progress-bar-wrap"
                            style="margin-top:var(--space-2);"
                        >
                            <div
                                class="upload-progress-bar"
                                id="uploadProgressBar"
                                style="width:0%"
                            >
                            </div>
                        </div>
                    </div>

                    <!-- Upload Error -->
                    <div
                        id="uploadError"
                        class="hidden bg-destructive/10 border border-destructive/25 text-red-400"
                        style="margin-top:var(--space-3); padding:var(--space-3); border-radius:var(--radius); font-size:var(--text-sm);"
                    >
                    </div>

                    <!-- Photo Thumbnails Grid -->
                    <div
                        id="photoGrid"
                        class="photo-thumb-grid"
                        style="margin-top:var(--space-5);"
                    >
                    </div>

                    <div class="photo-upload-grid" style="display:none">
                        <div class="photo-upload-main">
                            <div class="upload-area" id="uploadAreaOld"></div>
                        </div>
                    </div>

                    <div class="photo-info-box">
                        <svg
                            width="16"
                            height="16"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            class="text-primary flex-shrink-0"
                            ><circle cx="12" cy="12" r="10"></circle><line
                                x1="12"
                                y1="8"
                                x2="12"
                                y2="12"></line><line
                                x1="12"
                                y1="16"
                                x2="12.01"
                                y2="16"></line></svg
                        >
                        <div>
                            <strong>Foto-Tipps für mehr Vertrauen:</strong>
                            <ul>
                                <li>
                                    Fotografiere alle Seiten und etwaige Mängel
                                    offen
                                </li>
                                <li>
                                    Verwende keine Stockfotos – das ist verboten
                                </li>
                                <li>
                                    Fotos werden automatisch auf bekannte
                                    Stockfotos geprüft
                                </li>
                            </ul>
                        </div>
                    </div>

                    <div class="step-nav">
                        <button
                            type="button"
                            class="btn btn-secondary"
                            id="backToStep2">← Zurück</button
                        >
                        <button
                            type="button"
                            class="btn btn-primary"
                            id="toStep4">Weiter →</button
                        >
                    </div>
                </div>
            </div>

            <!-- Step 4: Review & Submit -->
            <div class="step-content hidden" id="step4">
                <div class="card">
                    <h2 class="card-title">Vorschau & Veröffentichen</h2>
                    <div class="review-card">
                        <div class="review-img-placeholder"></div>
                        <div class="review-body">
                            <div
                                class="badge badge-neutral"
                                style="margin-bottom:var(--space-2);"
                            >
                                Kategorie
                            </div>
                            <div class="review-title" id="previewTitle">
                                Deine Anzeige
                            </div>
                            <div class="review-price" id="previewPrice">
                                0 €
                            </div>
                            <div class="review-location">
                                <svg
                                    width="13"
                                    height="13"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2"
                                    class="text-foreground/80"
                                    ><path
                                        d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"
                                    ></path><circle cx="12" cy="10" r="3"
                                    ></circle></svg
                                >
                                Dein Ort
                            </div>
                        </div>
                    </div>

                    <div class="checklist-section">
                        <h3
                            style="font-size:var(--text-sm); font-weight:700; margin-bottom:var(--space-4);"
                        >
                            Vor der Veröffentlichung prüfen:
                        </h3>
                        <div class="checklist-items">
                            <label class="checklist-item">
                                <input type="checkbox" id="check1" />
                                <span
                                    >Ich habe alle Angaben wahrheitsgemäß
                                    gemacht</span
                                >
                            </label>
                            <label class="checklist-item">
                                <input type="checkbox" id="check2" />
                                <span
                                    >Ich akzeptiere die <a
                                        href="/agb"
                                        style="color:var(--color-primary);"
                                        >AGB</a
                                    > und die <a
                                        href="/datenschutz"
                                        style="color:var(--color-primary);"
                                        >Datenschutzerklärung</a
                                    ></span
                                >
                            </label>
                            <label class="checklist-item">
                                <input type="checkbox" id="check3" />
                                <span
                                    >Ich bestätige, dass ich Eigentümer der
                                    angebotenen Ware bin</span
                                >
                            </label>
                        </div>
                    </div>

                    <div class="final-actions">
                        <button
                            type="button"
                            class="btn btn-secondary"
                            id="backToStep3">← Zurück</button
                        >
                        <button
                            type="button"
                            class="btn btn-primary btn-lg"
                            id="submitBtn"
                            disabled
                        >
                            <svg
                                width="18"
                                height="18"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2.5"
                                class="text-white"
                                ><polyline points="20 6 9 17 4 12"
                                ></polyline></svg
                            >
                            Anzeige kostenfrei veröffentlichen
                        </button>
                    </div>
                </div>
            </div>

            <!-- Bail-out link -->
            <div class="text-center mt-6">
                <a href="/" class="font-condensed text-xs uppercase tracking-wider text-foreground/50 hover:text-foreground transition-colors">
                    ← Zurück zur Startseite
                </a>
            </div>

            <!-- Success State (hidden initially) -->
            <div class="step-content hidden" id="successState">
                <div class="card text-center" style="padding:var(--space-12);">
                    <div class="success-icon">
                        <svg
                            width="40"
                            height="40"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2.5"
                            class="text-success"
                            ><polyline points="20 6 9 17 4 12"></polyline></svg
                        >
                    </div>
                    <h2
                        style="font-size:var(--text-2xl); font-weight:800; margin-bottom:var(--space-3);"
                    >
                        Anzeige aufgegeben!
                    </h2>
                    <p class="text-muted" style="margin-bottom:var(--space-8);">
                        Deine Anzeige wird innerhalb von 15 Minuten geprüft und
                        dann veröffentlicht. Du erhältst eine
                        Bestätigungs-Email.
                    </p>
                    <div
                        style="display:flex; gap:var(--space-4); justify-content:center; flex-wrap:wrap;"
                    >
                        <a href="/" class="btn btn-primary btn-lg"
                            >Zur Startseite</a
                        >
                        <a href="/profil" class="btn btn-secondary btn-lg"
                            >Meine Anzeigen</a
                        >
                    </div>
                </div>
            <style>
    .create-main { @apply py-10 pb-16 bg-background min-h-screen text-foreground font-body; }
    .create-header { @apply mb-8; }
    
    .btn-secondary { @apply inline-flex items-center justify-center px-6 py-3 rounded font-bold text-foreground bg-secondary hover:bg-secondary/70 transition-all duration-200; }
    .btn-ghost { @apply inline-flex items-center justify-center px-4 py-2 rounded font-bold text-foreground/80 hover:text-foreground hover:bg-secondary/50 transition-all; }
    .btn-lg { @apply px-8 py-4 text-lg shadow-xl shadow-primary/10; }
    .btn-sm { @apply px-3 py-1.5 text-sm; }
    .text-muted { @apply text-foreground/75; }
    .section-title { @apply text-3xl md:text-4xl font-headings font-bold text-primary mb-2; }
    .section-subtitle { @apply text-foreground/80 text-lg max-w-2xl; }

    /* Progress Steps */
    .progress-steps { @apply flex items-center mb-8; }
    .progress-step { @apply flex flex-col items-center gap-2; }
    .step-circle { @apply w-10 h-10 bg-secondary border border-foreground/[.22] rounded flex items-center justify-center text-xs font-condensed text-foreground/75 transition-all duration-300; }
    .progress-step.active .step-circle { @apply bg-primary/10 border-primary text-primary; }
    .progress-step.done .step-circle { @apply bg-success border-success text-white; }
    .progress-step span { @apply text-xs font-bold text-foreground/80 transition-colors; }
    .progress-step.active span { @apply text-primary font-bold; }
    .progress-step.done span { @apply text-success; }
    .progress-line { @apply flex-1 h-[2px] bg-foreground/[.15] border-none mx-2 mb-6; }

    /* Card */
    .card { @apply bg-secondary/20 border border-foreground/[.20] rounded shadow-sm p-6 sm:p-8; }
    .card-title { @apply text-2xl font-headings font-bold text-primary mb-6; }
    .step-nav { @apply flex justify-between items-center mt-8 pt-6 border-t border-foreground/[.15]; }
    .hidden { display: none !important; }

    /* Category Select */
    .cat-select-grid { @apply grid grid-cols-2 md:grid-cols-4 gap-3 mb-6; }
    .cat-select-btn { @apply flex flex-col items-center gap-3 p-4 border-2 border-foreground/[.18] rounded bg-secondary/40 cursor-pointer transition-all duration-200 hover:border-primary hover:bg-primary/5 hover:-translate-y-1; }
    .cat-select-btn.selected { @apply border-primary bg-primary/10 ring-2 ring-primary/20; }
    .cat-select-btn .cat-icon { @apply w-8 h-8 opacity-100; }
    .cat-select-btn .cat-label { @apply text-xs font-bold text-foreground/80 text-center; }

    /* Form */
    .form-row { @apply flex flex-col sm:flex-row gap-4; }
    .form-group { @apply flex flex-col gap-2 mb-4; }
    .label { @apply text-sm font-bold text-foreground; }
    .input { @apply w-full px-4 py-3 rounded border border-foreground/[.22] bg-transparent text-foreground placeholder-foreground/60 focus:outline-none focus:border-primary/50 transition-all duration-200; }
    .char-count { @apply text-xs text-foreground/80 text-right mt-1; }
    .price-warning { @apply flex items-center gap-2 mt-2 text-xs text-amber-600 bg-amber-500/10 p-2 px-3 rounded-sm border border-amber-500/20; }
    .toggle-group { @apply flex gap-4 flex-wrap mt-2; }
    .toggle-option { @apply flex items-center gap-2 text-sm cursor-pointer font-medium text-foreground/80; }
    .toggle-check { @apply w-4 h-4 accent-primary rounded-sm; }

    /* Photo Upload */
    .upload-area { @apply border-2 border-dashed border-foreground/[.22] rounded p-12 flex flex-col items-center justify-center gap-3 text-center cursor-pointer transition-all duration-200 hover:border-primary hover:bg-primary/5 relative; }
    .upload-area p { @apply font-bold text-foreground; }
    .upload-area span { @apply text-xs text-foreground/80; }
    .upload-area input { @apply absolute inset-0 opacity-0 cursor-pointer; }
    .photo-info-box { @apply flex gap-3 p-4 bg-primary/5 border border-primary/20 rounded mt-5 text-sm text-primary; }
    .photo-info-box strong { @apply block mb-2 text-foreground font-bold; }
    .photo-info-box ul { @apply flex flex-col gap-2 list-none m-0 p-0; }
    .photo-info-box li { @apply text-xs text-foreground/80 pl-3 relative; }
    .photo-info-box li::before { content: "•"; @apply absolute left-0 text-primary; }

    /* Review Card */
    .review-card { @apply flex gap-4 bg-secondary/50 border border-secondary rounded p-4 mb-6 shadow-sm; }
    .review-img-placeholder { @apply w-[100px] h-[80px] bg-secondary rounded-sm flex-shrink-0 border border-secondary; }
    .review-body { @apply flex flex-col py-1; }
    .review-title { @apply font-bold text-base mb-1 text-foreground leading-tight; }
    .review-price { @apply text-2xl font-headings font-black text-primary; }
    .review-location { @apply flex items-center gap-1 text-sm text-foreground/75 mt-1 font-medium; }
    .badge-neutral { @apply inline-block px-2 py-0.5 bg-secondary text-foreground/75 text-[10px] font-bold uppercase rounded-sm tracking-wider w-max mb-2; }

    /* Checklist */
    .checklist-section { @apply bg-secondary/30 border border-secondary rounded p-5 mb-6; }
    .checklist-items { @apply flex flex-col gap-3; }
    .checklist-item { @apply flex items-start gap-3 text-sm cursor-pointer text-foreground/80 font-medium; }
    .checklist-item input { @apply w-4 h-4 accent-primary flex-shrink-0 mt-0.5 rounded-sm; }
    .final-actions { @apply flex flex-col sm:flex-row justify-between items-center gap-4; }
    .final-actions .btn { @apply w-full sm:w-auto; }

    /* Success Icon */
    .success-icon { @apply w-20 h-20 bg-success/10 border border-success/20 rounded flex items-center justify-center text-success mx-auto mb-6; }

    /* Photo Thumbnail Grid */
    .photo-thumb-grid { @apply grid grid-cols-2 md:grid-cols-4 gap-3; }
    .photo-thumb { @apply relative aspect-[4/3] rounded-sm overflow-hidden border-2 border-secondary shadow-sm; }
    .photo-thumb img { @apply w-full h-full object-cover; }
    .photo-thumb-del { @apply absolute top-1 right-1 w-6 h-6 bg-black/70 flex items-center justify-center text-white text-xs cursor-pointer transition-colors hover:bg-destructive; }
    .photo-thumb-add { @apply aspect-[4/3] border-2 border-dashed border-secondary rounded-sm flex items-center justify-center cursor-pointer transition-colors text-foreground/80 text-2xl hover:border-primary hover:bg-primary/5 hover:text-primary; }

    /* Upload progress bar */
    .upload-progress-bar-wrap { @apply bg-foreground/[.12] h-1.5 overflow-hidden mt-2; }
    .upload-progress-bar { @apply h-full bg-primary/60 transition-all duration-300; }
    .upload-spinner { @apply w-4 h-4 border-2 border-foreground/[.22] border-t-primary animate-spin flex-shrink-0; }
</style>

<script>
    // ── Helpers ─────────────────────────────────────────────────────────
    function fetchT(url: string, opts: RequestInit = {}, ms = 30000): Promise<Response> {
        const c = new AbortController();
        const t = setTimeout(() => c.abort(), ms);
        return fetch(url, { ...opts, signal: c.signal }).finally(() => clearTimeout(t));
    }

    // slug → ENUM mapping
    const SLUG_TO_ENUM: Record<string, string> = {
        elektronik: 'ELEKTRONIK', fahrzeuge: 'FAHRZEUGE', mode: 'MODE',
        moebel: 'MOEBEL', sport: 'SPORT', haushalt: 'HAUSHALT',
        bucher: 'BUCHER', spielzeug: 'SPIELZEUG', sonstiges: 'SONSTIGES',
    };

    // ── State ───────────────────────────────────────────────────────────
    let currentStep = 1;
    let selectedCategory: string | null = null;
    const selectedFiles: File[] = [];

    // ── Step navigation ─────────────────────────────────────────────────
    function goToStep(step: number) {
        document.querySelectorAll(".step-content").forEach((el) => el.classList.add("hidden"));
        document.getElementById(`step${step}`)?.classList.remove("hidden");
        document.querySelectorAll(".progress-step").forEach((el, idx) => {
            el.classList.remove("active", "done");
            if (idx + 1 < step) el.classList.add("done");
            if (idx + 1 === step) el.classList.add("active");
        });
        currentStep = step;
        window.scrollTo({ top: 0, behavior: "smooth" });
    }

    // ── Category selection ──────────────────────────────────────────────
    document.querySelectorAll(".cat-select-btn").forEach((btn) => {
        btn.addEventListener("click", () => {
            document.querySelectorAll(".cat-select-btn").forEach((b) => b.classList.remove("selected"));
            btn.classList.add("selected");
            selectedCategory = btn.getAttribute("data-cat");
            (document.getElementById("toStep2") as HTMLButtonElement).disabled = false;
        });
    });

    // ── Location helpers ─────────────────────────────────────────────────
    const plzInput = document.getElementById("plz") as HTMLInputElement;
    const cityInput = document.getElementById("city") as HTMLInputElement;
    const geoBtn = document.getElementById("geoLocateBtn") as HTMLButtonElement;
    const geoText = document.getElementById("geoLocateText") as HTMLSpanElement;
    const geoStatus = document.getElementById("geoStatus") as HTMLDivElement;

    function showGeoStatus(msg: string, isError = false) {
        geoStatus.textContent = msg;
        geoStatus.style.color = isError ? '#e53e3e' : 'var(--ehren-accent,#c8973a)';
        geoStatus.classList.remove('hidden');
        if (!isError) setTimeout(() => geoStatus.classList.add('hidden'), 4000);
    }

    // PLZ → City auto-lookup via openplzapi
    if (plzInput && cityInput) {
        plzInput.addEventListener("input", async () => {
            const plz = plzInput.value.trim();
            if (plz.length === 5 && /^[0-9]{5}$/.test(plz)) {
                try {
                    const res = await fetch(`https://openplzapi.org/de/Localities?postalCode=${plz}&page=1&pageSize=1`);
                    if (res.ok) {
                        const data = await res.json();
                        if (data && data.length > 0) {
                            cityInput.value = data[0].name || '';
                        }
                    }
                } catch {
                    // API not reachable – user can type manually
                }
            }
        });
    }

    // Geo-Koordinaten zwischenspeichern
    let detectedLat: number | null = null;
    let detectedLng: number | null = null;

    // Browser Geolocation → Reverse Geocode → PLZ + City + Koordinaten
    if (geoBtn) {
        geoBtn.addEventListener("click", () => {
            if (!navigator.geolocation) {
                showGeoStatus('Standortermittlung wird von deinem Browser nicht unterstützt.', true);
                return;
            }
            geoBtn.disabled = true;
            geoText.textContent = 'Wird ermittelt…';
            showGeoStatus('Standort wird ermittelt – bitte Zugriff erlauben…');

            navigator.geolocation.getCurrentPosition(
                async (pos) => {
                    const { latitude, longitude } = pos.coords;
                    detectedLat = latitude;
                    detectedLng = longitude;
                    try {
                        const res = await fetchT(
                            `https://nominatim.openstreetmap.org/reverse?lat=${latitude}&lon=${longitude}&format=json&addressdetails=1&accept-language=de`,
                            { headers: { 'User-Agent': 'EhrenDeal/1.0' } },
                            10000
                        );
                        if (res.ok) {
                            const data = await res.json();
                            const addr = data.address || {};
                            const city = addr.city || addr.town || addr.village || addr.municipality || '';
                            const postcode = addr.postcode || '';
                            if (city && cityInput) cityInput.value = city;
                            if (postcode && plzInput) plzInput.value = postcode;
                            showGeoStatus(city ? `Standort erkannt: ${postcode} ${city}` : 'Standort erkannt, Ort konnte nicht zugeordnet werden.');
                        } else {
                            showGeoStatus('Geocoding fehlgeschlagen – bitte manuell eingeben.', true);
                        }
                    } catch {
                        showGeoStatus('Geocoding-Timeout – bitte manuell eingeben.', true);
                    }
                    geoBtn.disabled = false;
                    geoText.textContent = 'Ort ermitteln';
                },
                (err) => {
                    const msgs: Record<number, string> = {
                        1: 'Standort-Zugriff verweigert. Bitte in den Browser-Einstellungen erlauben.',
                        2: 'Standort konnte nicht ermittelt werden.',
                        3: 'Zeitüberschreitung bei Standortermittlung.',
                    };
                    showGeoStatus(msgs[err.code] || 'Standortfehler.', true);
                    geoBtn.disabled = false;
                    geoText.textContent = 'Ort ermitteln';
                },
                { enableHighAccuracy: false, timeout: 10000, maximumAge: 300000 }
            );
        });
    }

    // ── Navigation buttons ──────────────────────────────────────────────
    document.getElementById("toStep2")?.addEventListener("click", () => goToStep(2));
    document.getElementById("backToStep1")?.addEventListener("click", () => goToStep(1));
    document.getElementById("toStep3")?.addEventListener("click", () => goToStep(3));
    document.getElementById("backToStep2")?.addEventListener("click", () => goToStep(2));
    document.getElementById("toStep4")?.addEventListener("click", () => {
        const titleVal = (document.getElementById("title") as HTMLInputElement)?.value || "Deine Anzeige";
        const priceVal = (document.getElementById("price") as HTMLInputElement)?.value || "0";
        const previewTitle = document.getElementById("previewTitle");
        const previewPrice = document.getElementById("previewPrice");
        if (previewTitle) previewTitle.textContent = titleVal;
        if (previewPrice) previewPrice.textContent = `${parseFloat(priceVal).toLocaleString("de-DE")} €`;

        // Show first photo in preview if available
        const reviewImg = document.querySelector(".review-img-placeholder") as HTMLElement;
        if (reviewImg && selectedFiles.length > 0) {
            reviewImg.style.backgroundImage = `url(${URL.createObjectURL(selectedFiles[0])})`;
            reviewImg.style.backgroundSize = 'cover';
            reviewImg.style.backgroundPosition = 'center';
        }

        goToStep(4);
    });
    document.getElementById("backToStep3")?.addEventListener("click", () => goToStep(3));

    // ── Price warning ───────────────────────────────────────────────────
    document.getElementById("price")?.addEventListener("input", (e) => {
        const val = parseFloat((e.target as HTMLInputElement).value);
        const warn = document.getElementById("priceWarning");
        if (warn) { val > 0 && val < 5 ? warn.classList.remove("hidden") : warn.classList.add("hidden"); }
        // Dynamische Provisionsvorschau
        const preview = document.getElementById("provisionPreview");
        if (preview && val > 0) {
            const commission = (val * 0.05);
            const payout = (val - commission);
            preview.textContent = ` — Bei ${val.toLocaleString("de-DE", {minimumFractionDigits: 2})} € erhältst du ${payout.toLocaleString("de-DE", {minimumFractionDigits: 2})} € (Provision: ${commission.toLocaleString("de-DE", {minimumFractionDigits: 2})} €).`;
        } else if (preview) {
            preview.textContent = '';
        }
    });

    // ── Char count ──────────────────────────────────────────────────────
    document.getElementById("title")?.addEventListener("input", (e) => {
        const len = (e.target as HTMLInputElement).value.length;
        const counter = document.querySelector(".char-count");
        if (counter) counter.textContent = `${len} / 80`;
    });

    // ── Photo handling ──────────────────────────────────────────────────
    const uploadArea = document.getElementById("uploadArea")!;
    const photoInput = document.getElementById("photoInput") as HTMLInputElement;
    const photoGrid = document.getElementById("photoGrid")!;
    const uploadError = document.getElementById("uploadError")!;

    function renderThumbnails() {
        photoGrid.innerHTML = '';
        selectedFiles.forEach((file, idx) => {
            const thumb = document.createElement('div');
            thumb.className = 'photo-thumb';
            const img = document.createElement('img');
            img.src = URL.createObjectURL(file);
            img.alt = file.name;
            const del = document.createElement('button');
            del.className = 'photo-thumb-del';
            del.textContent = '✕';
            del.type = 'button';
            del.addEventListener('click', () => { selectedFiles.splice(idx, 1); renderThumbnails(); });
            thumb.appendChild(img);
            thumb.appendChild(del);
            photoGrid.appendChild(thumb);
        });
        // Add "+" button if under 12
        if (selectedFiles.length < 12) {
            const addBtn = document.createElement('div');
            addBtn.className = 'photo-thumb-add';
            addBtn.textContent = '+';
            addBtn.addEventListener('click', () => photoInput.click());
            photoGrid.appendChild(addBtn);
        }
    }

    function addFiles(files: FileList | File[]) {
        uploadError.classList.add('hidden');
        for (const file of Array.from(files)) {
            if (selectedFiles.length >= 12) {
                uploadError.textContent = 'Maximal 12 Fotos erlaubt.';
                uploadError.classList.remove('hidden');
                break;
            }
            if (file.size > 10 * 1024 * 1024) {
                uploadError.textContent = `"${file.name}" ist zu groß (max. 10 MB).`;
                uploadError.classList.remove('hidden');
                continue;
            }
            if (!['image/jpeg', 'image/png', 'image/webp'].includes(file.type)) {
                uploadError.textContent = `"${file.name}" hat ein ungültiges Format.`;
                uploadError.classList.remove('hidden');
                continue;
            }
            selectedFiles.push(file);
        }
        renderThumbnails();
    }

    photoInput.addEventListener('change', () => { if (photoInput.files) addFiles(photoInput.files); photoInput.value = ''; });
    uploadArea.addEventListener('dragover', (e) => { e.preventDefault(); uploadArea.classList.add('border-primary', 'bg-primary/5'); });
    uploadArea.addEventListener('dragleave', () => { uploadArea.classList.remove('border-primary', 'bg-primary/5'); });
    uploadArea.addEventListener('drop', (e) => {
        e.preventDefault();
        uploadArea.classList.remove('border-primary', 'bg-primary/5');
        if (e.dataTransfer?.files) addFiles(e.dataTransfer.files);
    });

    // ── Checkbox submit enable ──────────────────────────────────────────
    const checks = ["check1", "check2", "check3"];
    checks.forEach((id) => {
        document.getElementById(id)?.addEventListener("change", () => {
            const allChecked = checks.every((c) => (document.getElementById(c) as HTMLInputElement)?.checked);
            (document.getElementById("submitBtn") as HTMLButtonElement).disabled = !allChecked;
        });
    });

    // ── Submit – real API flow ──────────────────────────────────────────
    let isSubmitting = false;
    document.getElementById("submitBtn")?.addEventListener("click", async () => {
        if (isSubmitting) return; // Guard against double-submit
        isSubmitting = true;
        const btn = document.getElementById("submitBtn") as HTMLButtonElement;
        btn.disabled = true;
        btn.innerHTML = '<span class="upload-spinner" style="display:inline-block;width:16px;height:16px;"></span> Wird veröffentlicht…';

        const title = (document.getElementById("title") as HTMLInputElement).value.trim();
        const description = (document.getElementById("desc") as HTMLTextAreaElement).value.trim();
        const priceRaw = parseFloat((document.getElementById("price") as HTMLInputElement).value);
        const price = Math.round(priceRaw * 100); // Convert € to Cent
        const city = (document.getElementById("city") as HTMLInputElement)?.value?.trim() || '';
        const postalCode = (document.getElementById("plz") as HTMLInputElement)?.value?.trim() || '';
        const conditionSel = (document.getElementById("condition") as HTMLSelectElement)?.value || '';
        const COND_MAP: Record<string, string> = { neu: 'Neu', sehr_gut: 'Sehr gut', gut: 'Gut', akzeptabel: 'Akzeptabel' };
        const condition = COND_MAP[conditionSel] || undefined;
        const treuhand = !!(document.querySelector('input[name="shipping"][value="treuhand"]') as HTMLInputElement)?.checked;
        const category = SLUG_TO_ENUM[selectedCategory || ''] || 'SONSTIGES';

        // ── Frontend-Validierung ──────────────────────────────────────
        const errors: string[] = [];
        if (title.length < 3) errors.push('Titel muss mindestens 3 Zeichen haben.');
        if (description.length < 10) errors.push('Beschreibung muss mindestens 10 Zeichen haben.');
        if (isNaN(price) || price < 0) errors.push('Bitte einen gültigen Preis eingeben.');
        if (postalCode.length < 4) errors.push('Bitte eine gültige PLZ eingeben.');
        if (!conditionSel) errors.push('Bitte einen Zustand auswählen.');
        if (errors.length > 0) {
            uploadError.textContent = errors.join(' ');
            uploadError.classList.remove('hidden');
            btn.disabled = false;
            btn.innerHTML = `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="text-white"><polyline points="20 6 9 17 4 12"></polyline></svg> Anzeige kostenfrei veröffentlichen`;
            const allChecked = checks.every((c) => (document.getElementById(c) as HTMLInputElement)?.checked);
            btn.disabled = !allChecked;
            return;
        }

        try {
            // Step 1: Create the listing
            const listingRes = await fetchT('/api/listings', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    title, description, price, category, city, postalCode, condition, treuhand, status: 'ACTIVE',
                    ...(detectedLat !== null && detectedLng !== null && { latitude: detectedLat, longitude: detectedLng }),
                }),
            });
            const listingData = await listingRes.json();
            if (!listingRes.ok) throw new Error(listingData.error || 'Fehler beim Erstellen der Anzeige');
            const listingId = listingData.listing.id;

            // Step 2: Upload photos (if any)
            if (selectedFiles.length > 0) {
                const progressWrap = document.getElementById("uploadProgress")!;
                const progressText = document.getElementById("uploadProgressText")!;
                const progressBar = document.getElementById("uploadProgressBar")!;
                progressWrap.classList.remove("hidden");

                for (let i = 0; i < selectedFiles.length; i++) {
                    const file = selectedFiles[i];
                    progressText.textContent = `Foto ${i + 1}/${selectedFiles.length} wird hochgeladen…`;
                    progressBar.style.width = `${((i) / selectedFiles.length) * 100}%`;

                    // 2a: Get presigned URL
                    const presignRes = await fetchT('/api/uploads/presign', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({
                            type: 'listingImage',
                            listingId,
                            contentType: file.type,
                            size: file.size,
                        }),
                    });
                    const presignData = await presignRes.json();
                    if (!presignRes.ok) throw new Error(presignData.error || 'Presign-Fehler');

                    // 2b: Upload to S3
                    const uploadRes = await fetch(presignData.uploadUrl, {
                        method: 'PUT',
                        headers: { 'Content-Type': file.type },
                        body: file,
                    });
                    if (!uploadRes.ok) throw new Error(`Upload-Fehler für Foto ${i + 1}`);

                    // 2c: Confirm upload
                    const confirmRes = await fetchT('/api/uploads/confirm', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ listingId, objectKey: presignData.objectKey, position: i }),
                    });
                    if (!confirmRes.ok) {
                        const cData = await confirmRes.json();
                        throw new Error(cData.error || 'Bestätigungs-Fehler');
                    }

                    progressBar.style.width = `${((i + 1) / selectedFiles.length) * 100}%`;
                }
                progressText.textContent = 'Alle Fotos hochgeladen ✓';
            }

            // Step 3: Show success
            document.querySelectorAll(".step-content").forEach((el) => el.classList.add("hidden"));
            document.getElementById("successState")?.classList.remove("hidden");
            window.scrollTo({ top: 0, behavior: "smooth" });

        } catch (err: any) {
            isSubmitting = false; // Allow retry
            const msg = err instanceof DOMException && err.name === 'AbortError'
                ? 'Zeitüberschreitung – bitte erneut versuchen.'
                : err.message || 'Unbekannter Fehler';
            uploadError.textContent = msg;
            uploadError.classList.remove('hidden');
            btn.disabled = false;
            btn.innerHTML = `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="text-white"><polyline points="20 6 9 17 4 12"></polyline></svg> Anzeige kostenfrei veröffentlichen`;
            // Re-check checkboxes state
            const allChecked = checks.every((c) => (document.getElementById(c) as HTMLInputElement)?.checked);
            btn.disabled = !allChecked;
        }
    });
</script>
