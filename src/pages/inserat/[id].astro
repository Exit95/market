---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { listings as staticListings } from "../../data/listings";
import { prisma } from "../../lib/auth";

const { id } = Astro.params;
if (!id) return Astro.redirect('/404');

// ── Category labels ──
const catLabels: Record<string, string> = {
    ELEKTRONIK: 'Elektronik', FAHRZEUGE: 'Fahrzeuge', MODE: 'Mode & Kleidung',
    MOEBEL: 'Möbel & Wohnen', SPORT: 'Sport & Freizeit', HAUSHALT: 'Haushalt',
    BUCHER: 'Bücher & Medien', SPIELZEUG: 'Spielzeug', SONSTIGES: 'Sonstiges',
};

// ── Time-ago helper ──
function timeAgo(date: Date): string {
    const ms = Date.now() - date.getTime();
    const mins = Math.floor(ms / 60000);
    if (mins < 1) return 'Gerade eben';
    if (mins < 60) return `vor ${mins} Min.`;
    const hrs = Math.floor(mins / 60);
    if (hrs < 24) return `vor ${hrs} Std.`;
    const days = Math.floor(hrs / 24);
    if (days === 1) return 'Gestern';
    if (days < 30) return `vor ${days} Tagen`;
    const months = Math.floor(days / 30);
    return `vor ${months} Monat${months > 1 ? 'en' : ''}`;
}

// ── 1) Try DB first ──
let listing: any = null;
let allImages: { url: string; id: string }[] = [];
let sellerMemberSince = '';
let sellerListingCount = 0;
let sellerTrustScore = 0;
let sellerId = '';
let isFromDB = false;
let dbCategory = '';

const dbListing = await prisma.listing.findUnique({
    where: { id },
    include: {
        images: { orderBy: { position: 'asc' } },
        seller: {
            select: {
                id: true,
                firstName: true,
                lastName: true,
                idVerified: true,
                emailVerified: true,
                phoneVerified: true,
                createdAt: true,
                trustScore: true,
                _count: { select: { listings: true } },
            },
        },
    },
});

if (dbListing) {
    isFromDB = true;
    dbCategory = dbListing.category;
    sellerId = dbListing.seller.id;

    // Increment view count (fire & forget)
    prisma.listing.update({ where: { id }, data: { viewCount: { increment: 1 } } }).catch(() => {});

    const s = dbListing.seller;
    const sellerFirst = s.firstName || '';
    const sellerLast = s.lastName || '';
    const sellerName = sellerFirst
        ? `${sellerFirst} ${sellerLast ? sellerLast.charAt(0) + '.' : ''}`.trim()
        : 'Verkäufer';

    // Seller stats
    sellerMemberSince = s.createdAt.toLocaleDateString('de-DE', { month: 'long', year: 'numeric' });
    sellerListingCount = s._count.listings;
    sellerTrustScore = s.trustScore?.score ?? 0;

    // All images
    allImages = dbListing.images.map((img: any) => ({ url: img.url, id: img.id }));
    const mainImage = allImages[0]?.url || 'https://placehold.co/600x400/1a1a2e/c8973a?text=Kein+Bild';

    listing = {
        id: dbListing.id,
        title: dbListing.title,
        price: dbListing.price / 100,
        location: [dbListing.postalCode, dbListing.city].filter(Boolean).join(' '),
        category: catLabels[dbListing.category] || dbListing.category,
        image: mainImage,
        sellerName,
        sellerRating: sellerTrustScore / 20, // 0-100 → 0-5
        sellerVerified: s.emailVerified || s.phoneVerified,
        sellerKYC: s.idVerified,
        postedAt: timeAgo(dbListing.createdAt),
        condition: dbListing.condition || 'Gut',
        treuhandAvailable: dbListing.treuhand,
        description: dbListing.description,
        viewCount: dbListing.viewCount + 1,
        status: dbListing.status,
    };
}

// ── 2) Fallback: static demo data ──
if (!listing) {
    const staticListing = staticListings.find((l) => l.id === id);
    if (staticListing) {
        listing = { ...staticListing, viewCount: 0, status: 'ACTIVE' };
        allImages = [{ url: staticListing.image, id: 'static-0' }];
        sellerMemberSince = 'Januar 2024';
        sellerListingCount = 3;
        sellerTrustScore = 75;
    }
}

// ── 404 ──
if (!listing) return Astro.redirect('/404');

// ── Stars ──
const rating = Math.max(0, Math.min(5, Math.round(listing.sellerRating)));
const stars = '★'.repeat(rating) + '☆'.repeat(5 - rating);

// ── Security Score (dynamisch berechnen) ──
let securityScore = 40; // Basis
if (listing.sellerVerified) securityScore += 15;
if (listing.sellerKYC) securityScore += 20;
if (listing.treuhandAvailable) securityScore += 15;
if (sellerTrustScore >= 50) securityScore += 5;
if (sellerTrustScore >= 80) securityScore += 5;
securityScore = Math.min(100, securityScore);
const securityLabel = securityScore >= 80 ? 'Niedrig' : securityScore >= 50 ? 'Mittel' : 'Hoch';
const securityBadge = securityScore >= 80 ? 'badge-success' : securityScore >= 50 ? 'badge-warning' : 'badge-danger';
const securityColor = securityScore >= 80 ? 'var(--color-success)' : securityScore >= 50 ? 'var(--color-warning)' : 'var(--color-danger)';

// ── Related Listings (DB + static fallback) ──
let relatedListings: any[] = [];
if (isFromDB && dbCategory) {
    const dbRelated = await prisma.listing.findMany({
        where: { category: dbCategory as any, status: 'ACTIVE', id: { not: id } },
        include: { images: { orderBy: { position: 'asc' }, take: 1 } },
        orderBy: { createdAt: 'desc' },
        take: 3,
    });
    relatedListings = dbRelated.map((r: any) => ({
        id: r.id,
        title: r.title,
        price: r.price / 100,
        location: [r.postalCode, r.city].filter(Boolean).join(' '),
        image: r.images[0]?.url || 'https://placehold.co/400x300/1a1a2e/c8973a?text=Kein+Bild',
    }));
}
// Fill up with static if needed
if (relatedListings.length < 3) {
    const staticRelated = staticListings
        .filter((l) => l.id !== listing!.id && l.category === listing!.category)
        .slice(0, 3 - relatedListings.length)
        .map((l) => ({ id: l.id, title: l.title, price: l.price, location: l.location, image: l.image }));
    relatedListings = [...relatedListings, ...staticRelated];
}
---

<BaseLayout title={`${listing.title} – Ehren-Deal`}>
    <Header />
    <main class="detail-main">
        <div class="container">
            <!-- Breadcrumb -->
            <nav class="breadcrumb">
                <a href="/">Startseite</a>
                <span>›</span>
                <a href={`/kategorie/${listing.category.toLowerCase()}`}
                    >{listing.category}</a
                >
                <span>›</span>
                <span>{listing.title}</span>
            </nav>

            <div class="detail-grid">
                <!-- Left: Images & Description -->
                <div class="detail-left">
                    <!-- Image Gallery -->
                    <div class="img-gallery">
                        <div class="img-main-wrap">
                            <img
                                src={allImages[0]?.url || listing.image}
                                alt={listing.title}
                                class="img-main"
                                id="mainImg"
                            />
                            {listing.condition === "Neu" && (
                                <span class="badge badge-success img-badge-large">Neu</span>
                            )}
                            {listing.treuhandAvailable && (
                                <div class="treuhand-ribbon">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                                        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
                                    </svg>
                                    Käuferschutz aktiv
                                </div>
                            )}
                            {allImages.length > 1 && (
                                <button class="gallery-nav gallery-prev" id="galleryPrev" aria-label="Vorheriges Bild">‹</button>
                            )}
                            {allImages.length > 1 && (
                                <button class="gallery-nav gallery-next" id="galleryNext" aria-label="Nächstes Bild">›</button>
                            )}
                            <div class="img-counter" id="imgCounter">
                                {allImages.length > 1 ? `1 / ${allImages.length}` : ''}
                            </div>
                        </div>
                        {allImages.length > 1 && (
                            <div class="img-thumbs">
                                {allImages.map((img, i) => (
                                    <button
                                        class={`img-thumb ${i === 0 ? 'active' : ''}`}
                                        data-index={i}
                                        data-url={img.url}
                                    >
                                        <img src={img.url} alt={`Bild ${i + 1}`} />
                                    </button>
                                ))}
                            </div>
                        )}
                    </div>

                    <!-- Description -->
                    <div class="card" style="margin-top:var(--space-5);">
                        <h2
                            style="font-size:var(--text-lg); font-weight:700; margin-bottom:var(--space-4);"
                        >
                            Beschreibung
                        </h2>
                        <p
                            style="color:var(--color-text-muted); line-height:1.8; font-size:var(--text-sm);"
                        >
                            {listing.description}
                        </p>
                    </div>

                    <!-- Details Table -->
                    <div class="card" style="margin-top:var(--space-4);">
                        <h2
                            style="font-size:var(--text-lg); font-weight:700; margin-bottom:var(--space-4);"
                        >
                            Details
                        </h2>
                        <div class="detail-table">
                            <div class="detail-row">
                                <span class="detail-key">Zustand</span>
                                <span
                                    class={`badge ${listing.condition === "Neu" ? "badge-success" : listing.condition === "Sehr gut" ? "badge-primary" : "badge-warning"}`}
                                    >{listing.condition}</span
                                >
                            </div>
                            <div class="detail-row">
                                <span class="detail-key">Kategorie</span>
                                <span class="detail-val"
                                    >{listing.category}</span
                                >
                            </div>
                            <div class="detail-row">
                                <span class="detail-key">Standort</span>
                                <span class="detail-val"
                                    >{listing.location}</span
                                >
                            </div>
                            <div class="detail-row">
                                <span class="detail-key">Eingestellt</span>
                                <span class="detail-val">{listing.postedAt}</span>
                            </div>
                            <div class="detail-row">
                                <span class="detail-key">Aufrufe</span>
                                <span class="detail-val">{listing.viewCount ?? 0}</span>
                            </div>
                            <div class="detail-row">
                                <span class="detail-key">Inserat-ID</span>
                                <span class="detail-val" style="color:var(--color-text-faint); font-size:var(--text-xs); font-family:monospace;">
                                    {listing.id.length > 12 ? listing.id.slice(-8) : listing.id}
                                </span>
                            </div>
                        </div>
                    </div>

                    <!-- Safety Tips -->
                    <div
                        class="card safety-tips-card"
                        style="margin-top:var(--space-4);"
                    >
                        <div class="safety-tips-header">
                            <svg
                                width="18"
                                height="18"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2"
                                ><path
                                    d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"
                                ></path><line x1="12" y1="9" x2="12" y2="13"
                                ></line><line x1="12" y1="17" x2="12.01" y2="17"
                                ></line></svg
                            >
                            <strong>Sicherheitstipps für Käufer</strong>
                        </div>
                        <ul class="safety-list">
                            <li>
                                Kaufe nur über unser <strong
                                    >Treuhandkonto</strong
                                > – nie direkt via PayPal Freunde & Familie
                            </li>
                            <li>
                                Triff Verkäufer <strong
                                    >persönlich an öffentlichen Orten</strong
                                > oder nutze Versand mit Treuhand
                            </li>
                            <li>
                                Lass dich <strong
                                    >nie zu schnellen Entscheidungen drängen</strong
                                > – seriöse Verkäufer haben Zeit
                            </li>
                            <li>
                                Kaufe <strong
                                    >keine Codes oder Geschenkgutscheine</strong
                                > als Zahlungsmittel
                            </li>
                            <li>
                                Melde verdächtige Anzeigen sofort über den <strong
                                    >"Melden"-Button</strong>
                            </li>
                        </ul>
                    </div>
                </div>

                <!-- Right: Purchase Box -->
                <div class="detail-right">
                    <div
                        class="purchase-box card-glass"
                        style="padding:var(--space-6);"
                    >
                        <div class="price-row">
                            <span class="detail-price"
                                >{listing.price.toLocaleString("de-DE")} €</span
                            >
                            {
                                listing.treuhandAvailable && (
                                    <span
                                        class="trust-badge trust-verified"
                                        style="font-size:0.7rem;"
                                    >
                                        Treuhand
                                    </span>
                                )
                            }
                        </div>
                        <div class="location-row">
                            <svg
                                width="14"
                                height="14"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2"
                                ><path
                                    d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"
                                ></path><circle cx="12" cy="10" r="3"
                                ></circle></svg
                            >
                            {listing.location}
                            <span class="listing-date-badge"
                                >{listing.postedAt}</span
                            >
                        </div>

                        {
                            listing.treuhandAvailable && (
                                <div class="treuhand-info-box">
                                    <div class="treuhand-info-header">
                                        <svg
                                            width="16"
                                            height="16"
                                            viewBox="0 0 24 24"
                                            fill="none"
                                            stroke="currentColor"
                                            stroke-width="2.5"
                                        >
                                            <>
                                                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
                                                <polyline points="9 12 11 14 15 10" />
                                            </>
                                        </svg>
                                        Käuferschutz verfügbar
                                    </div>
                                    <p>
                                        Dein Geld liegt sicher auf dem
                                        Treuhandkonto und wird erst nach
                                        bestätigtem Warenerhalt freigegeben.
                                    </p>
                                </div>
                            )
                        }

                        <div class="action-buttons">
                            <button
                                class="btn btn-primary w-full btn-lg"
                                id="contactBtn"
                            >
                                <svg
                                    width="18"
                                    height="18"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2"
                                    ><path
                                        d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"
                                    ></path></svg
                                >
                                Verkäufer kontaktieren
                            </button>
                            {
                                listing.treuhandAvailable && (
                                    <button
                                        class="btn btn-secondary w-full"
                                        id="buyBtn"
                                    >
                                        <svg
                                            width="16"
                                            height="16"
                                            viewBox="0 0 24 24"
                                            fill="none"
                                            stroke="currentColor"
                                            stroke-width="2.5"
                                        >
                                            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
                                        </svg>
                                        Sicher kaufen (Treuhand)
                                    </button>
                                )
                            }
                            <button
                                class="btn btn-ghost w-full"
                                style="color:var(--color-text-muted); font-size:var(--text-sm);"
                            >
                                <svg
                                    width="14"
                                    height="14"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2"
                                    ><path
                                        d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"
                                    ></path></svg
                                >
                                Merken
                            </button>
                        </div>

                        <div class="report-row">
                            <button
                                class="btn btn-ghost btn-sm"
                                style="color:var(--color-danger); font-size:var(--text-xs);"
                            >
                                <svg
                                    width="12"
                                    height="12"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2"
                                    ><path
                                        d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"
                                    ></path></svg
                                >
                                Anzeige melden
                            </button>
                        </div>
                    </div>

                    <!-- Risk Score (dynamisch) -->
                    <div class="card" style="margin-top:var(--space-4); padding:var(--space-5);">
                        <div class="risk-header">
                            <span style="font-size:var(--text-sm); font-weight:700;">Sicherheits-Score</span>
                            <span class={`badge ${securityBadge}`} style="font-size:0.65rem;">{securityLabel}</span>
                        </div>
                        <div class="risk-bar-wrap">
                            <div class="risk-bar" style={`width: ${securityScore}%`}></div>
                        </div>
                        <div class="risk-labels">
                            <span>Risiko</span>
                            <span style={`color:${securityColor}; font-weight:600;`}>{securityScore} / 100</span>
                        </div>
                        <div class="risk-checks">
                            <div class={`risk-check ${listing.sellerVerified ? 'ok' : 'warn'}`}>
                                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                                    {listing.sellerVerified
                                        ? <polyline points="20 6 9 17 4 12" />
                                        : <><line x1="18" y1="6" x2="6" y2="18" /><line x1="6" y1="6" x2="18" y2="18" /></>
                                    }
                                </svg>
                                {listing.sellerVerified ? 'Verifizierter Verkäufer' : 'Verkäufer nicht verifiziert'}
                            </div>
                            <div class={`risk-check ${listing.sellerKYC ? 'ok' : 'warn'}`}>
                                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                                    {listing.sellerKYC
                                        ? <polyline points="20 6 9 17 4 12" />
                                        : <><line x1="18" y1="6" x2="6" y2="18" /><line x1="6" y1="6" x2="18" y2="18" /></>
                                    }
                                </svg>
                                {listing.sellerKYC ? 'KYC-Identität bestätigt' : 'Keine KYC-Verifizierung'}
                            </div>
                            <div class={`risk-check ${listing.treuhandAvailable ? 'ok' : 'warn'}`}>
                                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                                    {listing.treuhandAvailable
                                        ? <polyline points="20 6 9 17 4 12" />
                                        : <><line x1="18" y1="6" x2="6" y2="18" /><line x1="6" y1="6" x2="18" y2="18" /></>
                                    }
                                </svg>
                                {listing.treuhandAvailable ? 'Treuhandkonto verfügbar' : 'Kein Treuhandschutz'}
                            </div>
                        </div>
                    </div>

                    <!-- Seller Card (echte Daten) -->
                    <div class="card" style="margin-top:var(--space-4); padding:var(--space-5);">
                        <h3 style="font-size:var(--text-sm); font-weight:700; margin-bottom:var(--space-4); color:var(--color-text-muted); text-transform:uppercase; letter-spacing:0.06em;">
                            Über den Verkäufer
                        </h3>
                        <div class="seller-block">
                            <div class="seller-avatar-lg">
                                {listing.sellerName.charAt(0)}
                            </div>
                            <div>
                                <div class="seller-name-detail">{listing.sellerName}</div>
                                <div class="seller-badges">
                                    {listing.sellerKYC && (
                                        <span class="trust-badge trust-kyc" style="font-size:0.65rem; padding:3px 7px;">KYC-verifiziert</span>
                                    )}
                                    {listing.sellerVerified && (
                                        <span class="trust-badge trust-verified" style="font-size:0.65rem; padding:3px 7px;">✓ Bestätigt</span>
                                    )}
                                </div>
                            </div>
                        </div>
                        <div class="seller-stats">
                            <div class="seller-stat-item">
                                <span class="stars" style="font-size:1rem;">{stars}</span>
                                <span style="font-size:var(--text-sm); font-weight:600;">
                                    {listing.sellerRating > 0 ? listing.sellerRating.toFixed(1) : '–'}
                                </span>
                            </div>
                            <div class="seller-stats-meta">
                                <span style="font-size:var(--text-xs); color:var(--color-text-muted);">
                                    Mitglied seit {sellerMemberSince} · {sellerListingCount} {sellerListingCount === 1 ? 'Anzeige' : 'Anzeigen'}
                                </span>
                            </div>
                        </div>
                        {sellerId ? (
                            <a href={`/profil/${sellerId}`} class="btn btn-secondary w-full btn-sm" style="margin-top:var(--space-4); justify-content:center;">
                                Profil ansehen
                            </a>
                        ) : (
                            <a href="/profil" class="btn btn-secondary w-full btn-sm" style="margin-top:var(--space-4); justify-content:center;">
                                Profil ansehen
                            </a>
                        )}
                    </div>
                </div>
            </div>

            <!-- Related Listings -->
            {
                relatedListings.length > 0 && (
                    <section style="margin-top:var(--space-12);">
                        <h2
                            class="section-title"
                            style="margin-bottom:var(--space-6);"
                        >
                            Ähnliche Anzeigen
                        </h2>
                        <div class="related-grid">
                            {relatedListings.map((l) => (
                                <a
                                    href={`/inserat/${l.id}`}
                                    class="related-card"
                                >
                                    <img
                                        src={l.image}
                                        alt={l.title}
                                        class="related-img"
                                    />
                                    <div class="related-body">
                                        <div class="related-title">
                                            {l.title}
                                        </div>
                                        <div class="related-price">
                                            {l.price.toLocaleString("de-DE")} €
                                        </div>
                                        <div class="related-loc">
                                            {l.location}
                                        </div>
                                    </div>
                                </a>
                            ))}
                        </div>
                    </section>
                )
            }
        </div>
    </main>

    <!-- Contact Modal -->
    <div class="modal-overlay" id="contactModal">
        <div class="modal card-glass">
            <div class="modal-header">
                <h3>Nachricht an {listing.sellerName}</h3>
                <button class="btn btn-ghost btn-icon" id="closeModal" aria-label="Dialog schließen">
                    <svg
                        width="18"
                        height="18"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        ><line x1="18" y1="6" x2="6" y2="18"></line><line
                            x1="6"
                            y1="6"
                            x2="18"
                            y2="18"></line></svg
                    >
                </button>
            </div>
            <p class="modal-note">
                <svg
                    width="14"
                    height="14"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    ><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"
                    ></path></svg
                >
