---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<BaseLayout title="Passwort vergessen – Ehren-Deal">
    <Header />
    <main class="min-h-[calc(100vh-70px)] flex items-center justify-center px-4 py-16 bg-background">
        <div class="w-full max-w-md">

            <!-- Back link -->
            <a href="/anmelden" class="inline-flex items-center gap-2 text-xs text-text-muted hover:text-primary transition-colors mb-8">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path d="M19 12H5m0 0l7 7m-7-7l7-7"/></svg>
                Zurück zur Anmeldung
            </a>

            <div class="card p-8 md:p-10">

                <!-- Header -->
                <div class="text-center mb-8">
                    <div class="w-14 h-14 border border-primary/30 bg-primary-light rounded flex items-center justify-center mx-auto mb-5">
                        <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                    </div>
                    <h1 class="font-semibold text-2xl text-text mb-2">Passwort vergessen?</h1>
                    <p class="text-sm text-text-secondary leading-relaxed">
                        Gib deine E-Mail-Adresse ein und wir senden dir einen Link zum Zurücksetzen deines Passworts.
                    </p>
                </div>

                <!-- Form -->
                <form id="forgot-form" class="space-y-5">
                    <div>
                        <label for="email" class="block text-xs font-semibold text-text-secondary mb-2">E-Mail-Adresse</label>
                        <input type="email" id="email" required placeholder="name@beispiel.de" class="input-field" autocomplete="email" />
                    </div>

                    <div id="error-msg" class="hidden p-3 border border-danger/30 bg-danger-light text-sm text-danger rounded"></div>

                    <button type="submit" id="submit-btn" class="btn-primary w-full py-3.5">
                        Link senden
                    </button>
                </form>

                <!-- Success State (hidden by default) -->
                <div id="success-state" class="hidden text-center space-y-4">
                    <div class="w-14 h-14 border border-success/30 bg-success-light rounded flex items-center justify-center mx-auto">
                        <svg class="w-6 h-6 text-success" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path d="M5 13l4 4L19 7"/></svg>
                    </div>
                    <h2 class="font-semibold text-xl text-text">E-Mail gesendet</h2>
                    <p class="text-sm text-text-secondary leading-relaxed">
                        Falls ein Konto mit dieser E-Mail existiert, erhältst du in Kürze einen Link zum Zurücksetzen. Prüfe auch deinen Spam-Ordner.
                    </p>
                    <p class="text-xs text-text-muted">Der Link ist 1 Stunde gültig.</p>
                    <a href="/anmelden" class="btn-outline inline-block mt-4">Zurück zur Anmeldung</a>
                </div>

                <!-- Security hint -->
                <div class="mt-6 flex gap-2 p-3 border border-primary/10 bg-primary-light/50 rounded">
                    <svg class="w-4 h-4 text-primary/60 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                    <p class="text-[.65rem] text-text-muted leading-relaxed">
                        Aus Sicherheitsgründen verraten wir nicht, ob ein Konto existiert. Du erhältst nur eine E-Mail, wenn die Adresse registriert ist.
                    </p>
                </div>
            </div>
        </div>
    </main>
    <Footer />
</BaseLayout>

<script>
    const form = document.getElementById('forgot-form') as HTMLFormElement;
    const errorMsg = document.getElementById('error-msg')!;
    const successState = document.getElementById('success-state')!;
    const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;

    form.addEventListener('submit', async (e) => {
        e.preventDefault();
        errorMsg.classList.add('hidden');

        const email = (document.getElementById('email') as HTMLInputElement).value.trim();
        if (!email) {
            errorMsg.textContent = 'Bitte gib deine E-Mail-Adresse ein.';
            errorMsg.classList.remove('hidden');
            return;
        }

        submitBtn.disabled = true;
        submitBtn.textContent = 'Wird gesendet...';

        try {
            const res = await fetch('/api/auth/forgot-password', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ email }),
            });

            if (!res.ok) {
                const data = await res.json().catch(() => ({}));
                throw new Error(data.error || 'Anfrage fehlgeschlagen.');
            }

            // Always show success (even if email not found – prevents enumeration)
            form.classList.add('hidden');
            successState.classList.remove('hidden');
        } catch (err: any) {
            errorMsg.textContent = err.message || 'Ein Fehler ist aufgetreten. Bitte versuche es erneut.';
            errorMsg.classList.remove('hidden');
            submitBtn.disabled = false;
            submitBtn.textContent = 'Link senden';
        }
    });
</script>
