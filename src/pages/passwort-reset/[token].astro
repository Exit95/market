---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";

const { token } = Astro.params;
const uid = Astro.url.searchParams.get("uid") ?? "";

if (!token || !uid) return Astro.redirect("/passwort-vergessen");
---

<BaseLayout title="Neues Passwort – Ehren-Deal">
    <Header />
    <main class="min-h-[calc(100vh-70px)] flex items-center justify-center px-4 py-16 bg-background">
        <div class="w-full max-w-md">

            <div class="card p-8 md:p-10">

                <!-- Header -->
                <div class="text-center mb-8" id="form-header">
                    <div class="w-14 h-14 border border-primary/30 bg-primary-light rounded flex items-center justify-center mx-auto mb-5">
                        <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                    </div>
                    <h1 class="font-semibold text-2xl text-text mb-2">Neues Passwort vergeben</h1>
                    <p class="text-sm text-text-secondary leading-relaxed">
                        Wähle ein sicheres Passwort mit mindestens 8 Zeichen.
                    </p>
                </div>

                <!-- Form -->
                <form id="reset-form" class="space-y-5">
                    <div>
                        <label for="pw" class="block text-xs font-semibold text-text-secondary mb-2">Neues Passwort</label>
                        <input type="password" id="pw" required minlength="8" placeholder="Mindestens 8 Zeichen" class="input-field" autocomplete="new-password" />
                        <div class="h-1 bg-border mt-2 overflow-hidden rounded-full">
                            <div class="h-full transition-all duration-300 w-0 rounded-full" id="pw-bar"></div>
                        </div>
                        <p class="text-xs mt-1" id="pw-label"></p>
                    </div>
                    <div>
                        <label for="pw2" class="block text-xs font-semibold text-text-secondary mb-2">Passwort bestätigen</label>
                        <input type="password" id="pw2" required minlength="8" placeholder="Passwort wiederholen" class="input-field" autocomplete="new-password" />
                    </div>

                    <div id="error-msg" class="hidden p-3 border border-danger/30 bg-danger-light text-sm text-danger rounded"></div>

                    <button type="submit" id="submit-btn" class="btn-primary w-full py-3.5">
                        Passwort ändern
                    </button>
                </form>

                <!-- Success State -->
                <div id="success-state" class="hidden text-center space-y-4">
                    <div class="w-14 h-14 border border-success/30 bg-success-light rounded flex items-center justify-center mx-auto">
                        <svg class="w-6 h-6 text-success" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path d="M5 13l4 4L19 7"/></svg>
                    </div>
                    <h2 class="font-semibold text-xl text-text">Passwort geändert</h2>
                    <p class="text-sm text-text-secondary leading-relaxed">
                        Dein Passwort wurde erfolgreich aktualisiert. Du bist jetzt angemeldet.
                    </p>
                    <a href="/" class="btn-primary inline-block mt-4">Zur Startseite</a>
                </div>

                <!-- Referrer-Policy hint -->
                <div class="mt-6 flex gap-2 p-3 border border-primary/10 bg-primary-light/50 rounded">
                    <svg class="w-4 h-4 text-primary/60 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                    <p class="text-[.65rem] text-text-muted leading-relaxed">
                        Diese Seite ist durch Referrer-Policy geschützt. Dein Reset-Token wird nicht an Dritte weitergegeben.
                    </p>
                </div>
            </div>
        </div>
    </main>
    <Footer />
</BaseLayout>

<script define:vars={{ token, uid }}>
    // Password strength meter
    const pwInput = document.getElementById('pw');
    const pwBar = document.getElementById('pw-bar');
    const pwLabel = document.getElementById('pw-label');

    pwInput.addEventListener('input', () => {
        const val = pwInput.value;
        let s = 0;
        if (val.length >= 8) s++;
        if (/[A-Z]/.test(val)) s++;
        if (/[0-9]/.test(val)) s++;
        if (/[^A-Za-z0-9]/.test(val)) s++;
        const levels = [
            { color: '#ef4444', text: 'Schwach', width: '25%' },
            { color: '#f59e0b', text: 'Mittel', width: '50%' },
            { color: '#06b6d4', text: 'Gut', width: '75%' },
            { color: '#10b981', text: 'Sehr sicher', width: '100%' },
        ];
        if (!val.length) { pwBar.style.width = '0'; pwLabel.textContent = ''; return; }
        const l = levels[Math.min(s - 1, 3)];
        pwBar.style.background = l.color;
        pwBar.style.width = l.width;
        pwLabel.style.color = l.color;
        pwLabel.textContent = l.text;
    });

    // Submit
    const form = document.getElementById('reset-form');
    const errorMsg = document.getElementById('error-msg');
    const successState = document.getElementById('success-state');
    const formHeader = document.getElementById('form-header');
    const submitBtn = document.getElementById('submit-btn');

    form.addEventListener('submit', async (e) => {
        e.preventDefault();
        errorMsg.classList.add('hidden');
        const password = pwInput.value;
        const pw2 = document.getElementById('pw2').value;

        if (password.length < 8) {
            errorMsg.textContent = 'Passwort muss mindestens 8 Zeichen haben.';
            errorMsg.classList.remove('hidden');
            return;
        }
        if (password !== pw2) {
            errorMsg.textContent = 'Passwörter stimmen nicht überein.';
            errorMsg.classList.remove('hidden');
            return;
        }

        submitBtn.disabled = true;
        submitBtn.textContent = 'Wird gespeichert...';

        try {
            const res = await fetch('/api/auth/reset-password', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ token, uid, password }),
            });
            const data = await res.json();
            if (!res.ok) throw new Error(data.error || 'Fehler beim Zurücksetzen.');

            form.classList.add('hidden');
            formHeader.classList.add('hidden');
            successState.classList.remove('hidden');
        } catch (err) {
            errorMsg.textContent = err.message;
            errorMsg.classList.remove('hidden');
            submitBtn.disabled = false;
            submitBtn.textContent = 'Passwort ändern';
        }
    });
</script>
