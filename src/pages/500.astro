---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<BaseLayout title="Fehler – Ehren-Deal">
    <Header />
    <main id="main-content" class="min-h-[60vh] flex items-center justify-center px-4">
        <div class="text-center max-w-lg card px-8 py-14">
            <div class="text-8xl sm:text-9xl font-bold text-danger/80 mb-4 leading-none">500</div>
            <h1 class="text-lg sm:text-xl font-semibold text-text mb-3">Etwas ist schiefgelaufen</h1>
            <p class="text-sm text-text-secondary mb-10 leading-relaxed max-w-sm mx-auto">
                Wir arbeiten daran, das Problem zu beheben. Bitte versuche es in wenigen Minuten erneut.
            </p>
            <div class="flex flex-col sm:flex-row gap-3 justify-center">
                <a href="/" class="btn-primary">Zur Startseite</a>
                <a href="/kontakt" class="btn-outline">Support kontaktieren</a>
            </div>
        </div>
    </main>
    <Footer />
</BaseLayout>
