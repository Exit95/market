---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { categories } from "../data/listings";
---

<BaseLayout title="Kategorien – Ehren-Deal">
    <Header />
    <main class="min-h-screen pt-12 pb-24">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

            <!-- Header -->
            <div class="mb-8">
                <h1 class="text-3xl md:text-4xl font-headings font-light text-foreground mb-2">Alle Kategorien</h1>
                <p class="text-foreground/50 text-sm font-light">
                    {categories.reduce((s, c) => s + c.count, 0).toLocaleString('de-DE')} Anzeigen in {categories.length} Kategorien
                </p>
            </div>

            <!-- Category Grid -->
            <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-3">
                {categories.map((cat) => (
                    <a
                        href={`/?category=${cat.slug.toUpperCase()}`}
                        class="group flex flex-col gap-3 bg-secondary/40 border border-foreground/[.15] p-5 hover:border-primary/40 hover:bg-primary/5 transition-all duration-200"
                    >
                        <div class="w-10 h-10 flex items-center justify-center bg-foreground/[.07] border border-foreground/[.15] group-hover:border-primary/25 group-hover:bg-primary/8 transition-all duration-200 flex-shrink-0">
                            <img src={cat.icon} alt={cat.label} class="w-6 h-6 opacity-70 group-hover:opacity-100 transition-opacity" loading="lazy" />
                        </div>
                        <div>
                            <h2 class="font-condensed font-medium text-sm uppercase tracking-wide text-foreground/80 group-hover:text-primary transition-colors leading-tight">{cat.label}</h2>
                            <p class="text-[.65rem] text-foreground/40 font-light mt-0.5">{cat.count.toLocaleString('de-DE')} Anzeigen</p>
                        </div>
                    </a>
                ))}
            </div>

        </div>
    </main>
    <Footer />
</BaseLayout>

