---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { categories } from "../data/listings";

const totalListings = categories.reduce((s, c) => s + c.count, 0);
const totalSubs = categories.reduce((s, c) => s + c.subcategories.length, 0);
---

<BaseLayout title="Kategorien – Ehren-Deal" description="Stöbere durch alle Kategorien auf Ehren-Deal. Elektronik, Fahrzeuge, Mode und mehr — mit Treuhand-Schutz." canonicalPath="/kategorien">
    <Header />
    <main id="main-content" class="min-h-screen pt-12 pb-24">
        <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">

            <!-- Breadcrumb -->
            <nav class="flex items-center gap-2 text-text-secondary mb-6 flex-wrap text-sm">
                <a href="/" class="hover:text-primary transition-colors">Startseite</a>
                <span class="text-text-muted">/</span>
                <span class="text-text">Kategorien</span>
            </nav>

            <!-- Header -->
            <div class="mb-8 text-center">
                <h1 class="text-h1 sm:text-3xl text-text mb-3">Alle Kategorien</h1>
                <p class="text-text-secondary text-sm mb-1">
                    Finde genau das, was du suchst &ndash; in {categories.length} Kategorien und {totalSubs} Unterkategorien.
                </p>
                <p class="text-text-muted text-caption">
                    {totalListings.toLocaleString('de-DE')} Anzeigen insgesamt
                </p>
            </div>

            <!-- Search Bar -->
            <form action="/" method="GET" class="max-w-xl mx-auto mb-12">
                <div class="flex items-center gap-2 bg-surface border border-border rounded-DEFAULT p-1.5 focus-within:border-primary transition-colors">
                    <svg class="w-5 h-5 text-text-muted ml-2 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z" />
                    </svg>
                    <input
                        name="query"
                        type="text"
                        placeholder="Was suchst du?"
                        class="flex-1 bg-transparent text-sm text-text placeholder:text-text-muted outline-none py-2 px-1"
                    />
                    <button type="submit" class="btn-primary text-sm px-5 py-2">
                        Suchen
                    </button>
                </div>
            </form>

            <!-- Categories with Subcategories -->
            <div class="space-y-6">
                {categories.map((cat) => (
                    <section class="card p-5 sm:p-6">
                        <!-- Category Header -->
                        <a href={`/?category=${cat.slug.toUpperCase()}`} class="flex items-center gap-4 mb-4 group">
                            <div class="w-12 h-12 flex items-center justify-center bg-primary-light border border-border rounded-DEFAULT group-hover:border-primary/30 transition-all duration-200">
                                <img
                                    src={cat.icon}
                                    alt=""
                                    width="32"
                                    height="32"
                                    class="w-8 h-8 group-hover:scale-110 transition-transform duration-200"
                                    loading="lazy"
                                />
                            </div>
                            <div class="flex-1 min-w-0">
                                <h2 class="text-h3 text-text group-hover:text-primary transition-colors">
                                    {cat.label}
                                </h2>
                                <p class="text-caption text-text-muted">
                                    {cat.count.toLocaleString('de-DE')} Anzeigen
                                </p>
                            </div>
                            <svg class="w-5 h-5 text-text-muted group-hover:text-primary transition-colors flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
                            </svg>
                        </a>

                        <!-- Subcategories -->
                        <div class="flex flex-wrap gap-2">
                            {cat.subcategories.map((sub) => (
                                <a
                                    href={`/?category=${cat.slug.toUpperCase()}&sub=${sub.slug}`}
                                    class="text-sm text-text-secondary hover:text-primary hover:bg-primary-light px-3 py-1.5 rounded-full border border-border hover:border-primary/30 transition-all duration-200"
                                >
                                    {sub.label}
                                </a>
                            ))}
                        </div>
                    </section>
                ))}
            </div>

            <!-- Trust Message -->
            <div class="mt-14 flex items-center justify-center gap-2.5 text-text-secondary">
                <svg class="w-5 h-5 text-success flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />
                </svg>
                <p class="text-sm">
                    Alle Anzeigen werden gepr&uuml;ft. Verd&auml;chtige Inserate werden automatisch erkannt und entfernt.
                </p>
            </div>

        </div>
    </main>
    <Footer />
</BaseLayout>
