---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<BaseLayout title="Nicht gefunden – Ehren-Deal">
    <Header />
    <main class="min-h-[60vh] flex items-center justify-center px-4">
        <div class="text-center max-w-lg border border-foreground/[.15] rounded bg-secondary/30 px-8 py-14">
            <div class="font-headings text-8xl sm:text-9xl font-light text-primary/80 mb-4 leading-none">404</div>
            <h1 class="font-condensed text-lg sm:text-xl font-medium tracking-[.08em] uppercase text-foreground mb-3">Seite nicht gefunden</h1>
            <p class="text-sm text-foreground/55 mb-10 leading-relaxed font-light max-w-sm mx-auto">
                Die gewünschte Seite existiert leider nicht oder wurde verschoben.
            </p>
            <div class="flex flex-col sm:flex-row gap-3 justify-center">
                <a href="/" class="btn-primary">Zur Startseite</a>
                <a href="/?category=" class="btn-outline">Anzeigen durchsuchen</a>
            </div>
        </div>
    </main>
    <Footer />
</BaseLayout>
