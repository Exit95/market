---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { requireAuth, isAuthContext } from "../../lib/auth-middleware";

// Protect page – redirect to login if unauthenticated
const auth = await requireAuth(Astro.request, Astro.cookies);
if (!isAuthContext(auth)) return Astro.redirect("/anmelden");

const res = await fetch(
    `${Astro.url.origin}/api/listings?status=ACTIVE&pageSize=100`,
    { headers: Astro.request.headers },
);

// Fetch only this user's listings by filtering on client (no sellerId filter in API yet)
const allData = res.ok ? await res.json() : { listings: [] };
const myListings = (allData.listings ?? []).filter(
    (l: any) => l.seller?.id === auth.userId,
);

const STATUS_LABEL: Record<string, string> = {
    DRAFT: "Entwurf",
    ACTIVE: "Aktiv",
    RESERVED: "Reserviert",
    SOLD: "Verkauft",
    ARCHIVED: "Archiviert",
    REMOVED: "Gelöscht",
};
---

<BaseLayout title="Meine Anzeigen – Novamarkt">
    <Header />
    <main class="container dash-wrap">
        <div class="dash-header">
            <h1>Meine Anzeigen</h1>
            <a href="/inserat-erstellen" class="btn btn-primary"
                >+ Neue Anzeige</a
            >
        </div>

        {
            myListings.length === 0 && (
                <div class="empty-state">
                    <p>Du hast noch keine Anzeigen.</p>
                    <a
                        href="/inserat-erstellen"
                        class="btn btn-primary"
                        style="margin-top:1rem;"
                    >
                        Erste Anzeige erstellen
                    </a>
                </div>
            )
        }

        <div class="listing-table-wrap">
            {
                myListings.length > 0 && (
                    <table class="listing-table">
                        <thead>
                            <tr>
                                <th>Titel</th>
                                <th>Preis</th>
                                <th>Kategorie</th>
                                <th>Status</th>
                                <th>Aufrufe</th>
                                <th>Aktionen</th>
                            </tr>
                        </thead>
                        <tbody>
                            {myListings.map((l: any) => (
                                <tr>
                                    <td>
                                        <a href={`/listing/${l.id}`}>
                                            {l.title}
                                        </a>
                                    </td>
                                    <td>
                                        {(l.price / 100).toLocaleString(
                                            "de-DE",
                                            {
                                                style: "currency",
                                                currency: "EUR",
                                            },
                                        )}
                                    </td>
                                    <td>{l.category}</td>
                                    <td>
                                        <span
                                            class={`status-badge status-${l.status.toLowerCase()}`}
                                        >
                                            {STATUS_LABEL[l.status] ?? l.status}
                                        </span>
                                    </td>
                                    <td>{l.viewCount}</td>
                                    <td class="action-cell">
                                        <button
                                            class="btn btn-ghost btn-xs"
                                            data-action="archive"
                                            data-id={l.id}
                                        >
                                            Archivieren
                                        </button>
                                        <button
                                            class="btn btn-danger btn-xs"
                                            data-action="delete"
                                            data-id={l.id}
                                        >
                                            Löschen
                                        </button>
                                    </td>
                                </tr>
                            ))}
                        </tbody>
                    </table>
                )
            }
        </div>
    </main>
    <Footer />
</BaseLayout>

<style>
    .dash-wrap { @apply py-10 pb-16 bg-background min-h-screen text-foreground font-body max-w-7xl mx-auto px-4 sm:px-6 lg:px-8; }
    .dash-header { @apply flex flex-col sm:flex-row items-start sm:items-center justify-between mb-8 pb-6 border-b border-secondary gap-4; }
    .dash-header h1 { @apply text-3xl font-headings font-bold text-primary m-0; }
    
    .empty-state { @apply text-center py-16 px-4 bg-secondary/30 rounded-default border-2 border-dashed border-secondary text-foreground/70; }
    
    .listing-table-wrap { @apply bg-background border border-secondary rounded-default shadow-sm overflow-x-auto; }
    .listing-table { @apply w-full border-collapse text-left whitespace-nowrap; }
    .listing-table th, .listing-table td { @apply px-6 py-4 border-b border-secondary text-sm; }
    .listing-table th { @apply font-bold text-foreground/60 bg-secondary/50 uppercase tracking-wider text-xs; }
    .listing-table tr { @apply transition-colors duration-200; }
    .listing-table tr:hover td { @apply bg-secondary/30; }
    .listing-table tr:last-child td { @apply border-b-0; }
    .listing-table a { @apply font-bold text-primary hover:text-primary/80 transition-colors; }
    
    .status-badge { @apply inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-bold tracking-wide uppercase; }
    .status-active { @apply bg-success/10 text-success border border-success/20; }
    .status-draft { @apply bg-foreground/10 text-foreground/70 border border-foreground/20; }
    .status-sold { @apply bg-primary/10 text-primary border border-primary/20; }
    .status-archived, .status-removed { @apply bg-destructive/10 text-destructive border border-destructive/20; }
    
    .action-cell { @apply flex items-center gap-2; }
    .btn-xs { @apply px-3 py-1.5 text-xs rounded-sm font-bold transition-colors; }
    .btn-ghost { @apply text-foreground/70 hover:text-foreground hover:bg-secondary/80 bg-secondary/40; }
    .btn-danger { @apply bg-destructive/10 text-destructive hover:bg-destructive hover:text-white; }
</style>

<script>
    document.querySelectorAll("[data-action]").forEach((btn) => {
        btn.addEventListener("click", async () => {
            const id = (btn as HTMLElement).dataset.id!;
            const action = (btn as HTMLElement).dataset.action!;
            const body = action === "archive" ? { status: "ARCHIVED" } : null;

            if (
                !confirm(
                    action === "delete"
                        ? "Anzeige wirklich löschen?"
                        : "Anzeige archivieren?",
                )
            )
                return;

            const res = await fetch(`/api/listings/${id}`, {
                method: action === "delete" ? "DELETE" : "PATCH",
                headers: { "Content-Type": "application/json" },
                body: body ? JSON.stringify(body) : undefined,
            });

            if (res.ok) location.reload();
            else alert("Fehler: " + (await res.json()).error);
        });
    });
</script>
