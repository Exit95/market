---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { requireAuth, isAuthContext } from "../../lib/auth-middleware";

// Protect page – redirect to login if unauthenticated
const auth = await requireAuth(Astro.request, Astro.cookies);
if (!isAuthContext(auth)) return Astro.redirect("/anmelden");

const res = await fetch(
    `${Astro.url.origin}/api/listings?status=ACTIVE&pageSize=100`,
    { headers: Astro.request.headers },
);

// Fetch only this user's listings by filtering on client (no sellerId filter in API yet)
const allData = res.ok ? await res.json() : { listings: [] };
const myListings = (allData.listings ?? []).filter(
    (l: any) => l.seller?.id === auth.userId,
);

const STATUS_LABEL: Record<string, string> = {
    DRAFT: "Entwurf",
    ACTIVE: "Aktiv",
    RESERVED: "Reserviert",
    SOLD: "Verkauft",
    ARCHIVED: "Archiviert",
    REMOVED: "Gelöscht",
};
---

<BaseLayout title="Meine Anzeigen – Ehren-Deal">
    <Header />
    <main class="container dash-wrap">
        <!-- Breadcrumb -->
        <nav class="breadcrumb" aria-label="Breadcrumb">
            <a href="/">Startseite</a>
            <span class="breadcrumb-sep">/</span>
            <span class="breadcrumb-current">Meine Anzeigen</span>
        </nav>

        <div class="dash-header">
            <h1>Meine Anzeigen</h1>
            <a href="/inserat-erstellen" class="btn-primary"
                >+ Neue Anzeige</a
            >
        </div>

        {
            myListings.length === 0 && (
                <div class="empty-state">
                    <svg class="empty-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v6m3-3H9m12 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
                    </svg>
                    <p class="empty-title">Du hast noch keine Anzeigen erstellt.</p>
                    <p class="empty-desc">Erstelle deine erste Anzeige und erreiche tausende Nutzer auf Ehren-Deal.</p>
                    <a
                        href="/inserat-erstellen"
                        class="btn-primary"
                        style="margin-top:1rem;"
                    >
                        Erste Anzeige erstellen
                    </a>
                </div>
            )
        }

        <div class="listing-table-wrap">
            {
                myListings.length > 0 && (
                    <table class="listing-table">
                        <thead>
                            <tr>
                                <th>Titel</th>
                                <th>Preis</th>
                                <th>Kategorie</th>
                                <th>Status</th>
                                <th>Aufrufe</th>
                                <th>Aktionen</th>
                            </tr>
                        </thead>
                        <tbody>
                            {myListings.map((l: any) => (
                                <tr>
                                    <td>
                                        <a href={`/inserat/${l.id}`}>
                                            {l.title}
                                        </a>
                                    </td>
                                    <td>
                                        {(l.price / 100).toLocaleString(
                                            "de-DE",
                                            {
                                                style: "currency",
                                                currency: "EUR",
                                            },
                                        )}
                                    </td>
                                    <td>{l.category}</td>
                                    <td>
                                        <span
                                            class={`status-badge status-${l.status.toLowerCase()}`}
                                        >
                                            {STATUS_LABEL[l.status] ?? l.status}
                                        </span>
                                    </td>
                                    <td>{l.viewCount}</td>
                                    <td class="action-cell">
                                        <button
                                            class="btn-ghost btn-xs"
                                            data-action="archive"
                                            data-id={l.id}
                                        >
                                            Archivieren
                                        </button>
                                        <button
                                            class="btn-danger btn-xs"
                                            data-action="delete"
                                            data-id={l.id}
                                        >
                                            Löschen
                                        </button>
                                    </td>
                                </tr>
                            ))}
                        </tbody>
                    </table>
                )
            }
        </div>
    </main>
    <Footer />
</BaseLayout>

<style>
    .dash-wrap { @apply py-10 pb-16 bg-background min-h-screen text-text font-body max-w-7xl mx-auto px-4 sm:px-6 lg:px-8; }

    /* Breadcrumb */
    .breadcrumb { @apply flex items-center gap-2 text-xs text-text-muted mb-6; }
    .breadcrumb a { @apply text-text-muted hover:text-primary transition-colors no-underline; }
    .breadcrumb-sep { @apply text-text-muted; }
    .breadcrumb-current { @apply text-text; }

    .dash-header { @apply flex flex-col sm:flex-row items-start sm:items-center justify-between mb-8 pb-6 border-b border-border gap-4; }
    .dash-header h1 { @apply text-2xl font-semibold text-text m-0; }

    /* Empty state */
    .empty-state { @apply text-center py-16 px-4 bg-surface border border-dashed border-border text-text-secondary rounded; }
    .empty-icon { @apply w-12 h-12 mx-auto mb-4 text-text-muted; }
    .empty-title { @apply text-lg font-semibold text-text mb-2; }
    .empty-desc { @apply text-sm text-text-muted max-w-md mx-auto; }

    /* Table */
    .listing-table-wrap { @apply bg-surface border border-border rounded overflow-x-auto; }
    .listing-table { @apply w-full border-collapse text-left whitespace-nowrap; }
    .listing-table th, .listing-table td { @apply px-6 py-4 border-b border-border text-sm; }
    .listing-table th { @apply font-medium text-text-secondary bg-background text-xs; }
    .listing-table tr { @apply transition-colors duration-200; }
    .listing-table tr:hover td { @apply bg-background; }
    .listing-table tr:last-child td { @apply border-b-0; }
    .listing-table a { @apply font-bold text-primary hover:text-primary/80 transition-colors; }

    .status-badge { @apply inline-flex items-center px-2.5 py-0.5 text-xs font-medium rounded-full; }
    .status-active { @apply bg-success-light text-success; }
    .status-draft { @apply bg-background text-text-muted; }
    .status-sold { @apply bg-primary-light text-primary; }
    .status-reserved { @apply bg-accent-light text-accent; }
    .status-archived, .status-removed { @apply bg-danger-light text-danger; }

    .action-cell { @apply flex items-center gap-2; }
    .btn-xs { @apply px-3 py-1.5 text-xs; }
</style>

<script>
    document.querySelectorAll("[data-action]").forEach((btn) => {
        btn.addEventListener("click", async () => {
            const id = (btn as HTMLElement).dataset.id!;
            const action = (btn as HTMLElement).dataset.action!;
            const body = action === "archive" ? { status: "ARCHIVED" } : null;

            if (
                !confirm(
                    action === "delete"
                        ? "Anzeige wirklich löschen?"
                        : "Anzeige archivieren?",
                )
            )
                return;

            const res = await fetch(`/api/listings/${id}`, {
                method: action === "delete" ? "DELETE" : "PATCH",
                headers: { "Content-Type": "application/json" },
                body: body ? JSON.stringify(body) : undefined,
            });

            if (res.ok) location.reload();
            else alert("Fehler: " + (await res.json()).error);
        });
    });
</script>
