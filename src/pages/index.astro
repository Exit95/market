---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { categories } from "../data/listings";

// Server-side: fetch first page from our own API
const url = new URL("/api/listings", Astro.url.origin);
url.searchParams.set("pageSize", "20");
url.searchParams.set("page", "1");

// Forward search params from URL
for (const [k, v] of Astro.url.searchParams) {
    if (["query", "category", "minPrice", "maxPrice", "city", "page", "pageSize"].includes(k)) {
        url.searchParams.set(k, v);
    }
}

const res = await fetch(url.toString());
const data = res.ok
    ? await res.json()
    : { listings: [], pagination: { total: 0, totalPages: 1, page: 1 } };
const { listings, pagination } = data;

const currentPage = pagination.page ?? 1;
const totalPages = pagination.totalPages ?? 1;
const currentQuery = Astro.url.searchParams.get("query") ?? "";
const currentCat = Astro.url.searchParams.get("category") ?? "";
---

<BaseLayout title="Ehren-Deal · Handeln mit Handschlag">
    <Header />
    <main class="min-h-screen pt-8 pb-24">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

            <!-- Hero Section -->
            <div class="mb-16 text-center pt-16 pb-4">
                <p class="font-condensed text-[.7rem] font-medium tracking-[.2em] uppercase text-primary mb-5">Marktplatz</p>
                <h1 class="font-headings font-light text-5xl md:text-6xl lg:text-7xl leading-[1.05] mb-4 text-foreground">
                    Handeln<br/><em class="italic text-primary">mit Handschlag</em>
                </h1>
                <hr class="gold-rule" />
                <p class="text-sm text-foreground/40 font-light max-w-md mx-auto leading-relaxed">
                    Verifizierte Identitäten · Treuhand-Schutz · Lokale Deals
                </p>

                <!-- Search bar -->
                <div class="pt-10 max-w-3xl mx-auto">
                    <form method="GET" class="flex flex-col sm:flex-row gap-3 p-3 bg-secondary/50 border border-foreground/[.04]">
                        <input
                            name="query"
                            value={currentQuery}
                            placeholder="Was suchst du?"
                            class="input-field flex-grow bg-transparent"
                        />
                        <select name="category" class="input-field sm:w-52 bg-transparent">
                            <option value="">Alle Kategorien</option>
                            {
                                categories.map((c) => (
                                    <option
                                        value={c.slug.toUpperCase()}
                                        selected={currentCat === c.slug.toUpperCase()}
                                    >
                                        {c.label}
                                    </option>
                                ))
                            }
                        </select>
                        <button type="submit" class="btn-primary sm:w-36">
                            Suchen
                        </button>
                    </form>
                </div>
            </div>

            <!-- Pillars -->
            <div class="grid grid-cols-1 sm:grid-cols-3 gap-8 max-w-2xl mx-auto mb-16 text-center">
                <div>
                    <div class="w-8 h-8 mx-auto mb-3 flex items-center justify-center text-primary/60">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M7 11v4a1 1 0 001 1h1m4-6v4a1 1 0 001 1h1m-8 0h8m-8 0H6m12 0h-2m-4-8l4-4m0 0l4 4m-4-4v12"/></svg>
                    </div>
                    <h3 class="font-condensed font-medium text-xs tracking-[.08em] uppercase text-foreground/70 mb-1">Handschlag</h3>
                    <p class="text-xs text-foreground/30 font-light">Transparent & verbindlich</p>
                </div>
                <div>
                    <div class="w-8 h-8 mx-auto mb-3 flex items-center justify-center text-primary/60">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
                    </div>
                    <h3 class="font-condensed font-medium text-xs tracking-[.08em] uppercase text-foreground/70 mb-1">Treuhand</h3>
                    <p class="text-xs text-foreground/30 font-light">Dein Geld bleibt sicher</p>
                </div>
                <div>
                    <div class="w-8 h-8 mx-auto mb-3 flex items-center justify-center text-primary/60">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M5.121 17.804A13.937 13.937 0 0112 16c2.5 0 4.847.655 6.879 1.804M15 10a3 3 0 11-6 0 3 3 0 016 0zm6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                    </div>
                    <h3 class="font-condensed font-medium text-xs tracking-[.08em] uppercase text-foreground/70 mb-1">Identitäten</h3>
                    <p class="text-xs text-foreground/30 font-light">Keine Fake-Profile</p>
                </div>
            </div>

            <!-- Result summary -->
            <div class="flex justify-between items-end mb-8 border-b border-foreground/[.04] pb-4">
                <div>
                    <h2 class="text-2xl font-headings font-light text-foreground">
                        {currentQuery ? `Ergebnisse für „${currentQuery}"` : "Aktuelle Angebote"}
                    </h2>
                    <p class="text-foreground/30 text-xs mt-1.5 font-condensed font-light tracking-wider uppercase">
                        {pagination.total} Anzeige{pagination.total !== 1 ? "n" : ""} gefunden
                    </p>
                </div>
                <div class="hidden sm:flex items-center">
                    <span class="trust-badge">
                        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                        Sicher Handeln
                    </span>
                </div>
            </div>

            <!-- Listings Grid -->
            {
                listings.length > 0 ? (
                    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
                        {listings.map((l: any) => (
                            <a href={`/listing/${l.id}`} class="group block h-full">
                                <article class="bg-secondary/40 border border-foreground/[.04] overflow-hidden hover:border-primary/20 transition-all duration-500 h-full flex flex-col relative">

                                    <!-- Badges -->
                                    <div class="absolute top-3 right-3 flex flex-col gap-2 z-10">
                                        {l.treuhand && (
                                            <span class="bg-primary/90 backdrop-blur-sm text-primary-foreground text-[.65rem] px-2 py-0.5 font-condensed font-medium uppercase tracking-wider">
                                                Treuhand
                                            </span>
                                        )}
                                        {l.seller?.trustScore?.level === 'VERIFIED' && (
                                            <span class="bg-foreground/80 backdrop-blur-sm text-background text-[.65rem] px-2 py-0.5 font-condensed font-medium uppercase tracking-wider flex items-center gap-1">
                                                <svg class="w-2.5 h-2.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
                                                Verifiziert
                                            </span>
                                        )}
                                    </div>

                                    <!-- Image -->
                                    <div class="aspect-[4/3] w-full bg-secondary relative overflow-hidden flex-shrink-0">
                                        {l.images[0] ? (
                                            <img
                                                src={l.images[0].url}
                                                alt={l.title}
                                                class="w-full h-full object-cover group-hover:scale-[1.03] transition-transform duration-700 ease-out"
                                                loading="lazy"
                                            />
                                        ) : (
                                            <div class="w-full h-full flex items-center justify-center text-foreground/10">
                                                <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                                            </div>
                                        )}
                                    </div>

                                    <!-- Content -->
                                    <div class="p-4 flex flex-col flex-grow">
                                        <div class="text-lg font-headings font-light text-primary mb-0.5">
                                            {(l.price / 100).toLocaleString("de-DE", { style: "currency", currency: "EUR" })}
                                        </div>
                                        <h3 class="font-light text-foreground/80 mb-2 line-clamp-2 leading-snug text-sm">
                                            {l.title}
                                        </h3>
                                        <div class="mt-auto pt-3 flex items-center justify-between text-[.65rem] text-foreground/30 font-condensed tracking-wider uppercase">
                                            <div class="flex items-center gap-1">
                                                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                                                {l.city}
                                            </div>
                                            <div class="text-foreground/20">
                                                {l.category}
                                            </div>
                                        </div>
                                    </div>
                                </article>
                            </a>
                        ))}
                    </div>
                ) : (
                    <div class="text-center py-24 rounded-default border border-dashed border-foreground/10">
                        <svg class="w-12 h-12 mx-auto mb-4 text-foreground/20" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
                        <h3 class="text-xl font-headings font-medium text-foreground mb-2">Keine Angebote gefunden</h3>
                        <p class="text-foreground/50 max-w-sm mx-auto font-light">
                            Versuche andere Suchbegriffe oder erweitere deine Filterkriterien.
                        </p>
                    </div>
                )
            }

            <!-- Pagination -->
            {
                totalPages > 1 && (
                    <nav class="flex items-center justify-center gap-4 mt-16 pb-8">
                        {currentPage > 1 && (
                            <a
                                href={`?${new URLSearchParams({ ...Object.fromEntries(Astro.url.searchParams), page: String(currentPage - 1) })}`}
                                class="px-5 py-2.5 border border-foreground/10 text-foreground font-condensed text-xs tracking-wider uppercase hover:border-primary hover:text-primary transition-colors"
                            >
                                ← Zurück
                            </a>
                        )}
                        <span class="text-foreground/40 font-medium text-sm px-4">
                            Seite {currentPage} von {totalPages}
                        </span>
                        {currentPage < totalPages && (
                            <a
                                href={`?${new URLSearchParams({ ...Object.fromEntries(Astro.url.searchParams), page: String(currentPage + 1) })}`}
                                class="px-5 py-2.5 border border-foreground/10 text-primary font-condensed text-xs tracking-wider uppercase hover:bg-primary hover:text-primary-foreground hover:border-primary transition-colors"
                            >
                                Weiter →
                            </a>
                        )}
                    </nav>
                )
            }
        </div>
    </main>
    <Footer />
</BaseLayout>
