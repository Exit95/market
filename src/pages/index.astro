---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { categories } from "../data/listings";

// Server-side: fetch first page from our own API
const url = new URL("/api/listings", Astro.url.origin);
url.searchParams.set("pageSize", "20");
url.searchParams.set("page", "1");

// Forward search params from URL
for (const [k, v] of Astro.url.searchParams) {
    if (["query", "category", "minPrice", "maxPrice", "city", "lat", "lng", "radius", "page", "pageSize"].includes(k)) {
        url.searchParams.set(k, v);
    }
}

const res = await fetch(url.toString());
const data = res.ok
    ? await res.json()
    : { listings: [], pagination: { total: 0, totalPages: 1, page: 1 } };
const { listings, pagination } = data;

const currentPage = pagination.page ?? 1;
const totalPages = pagination.totalPages ?? 1;
const currentQuery = Astro.url.searchParams.get("query") ?? "";
const currentCat = Astro.url.searchParams.get("category") ?? "";
---

<BaseLayout title="Ehren-Deal · Handeln mit Handschlag">
    <Header />
    <main class="min-h-screen pt-8 pb-24">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

            <!-- Hero Section -->
            <div class="mb-6 text-center pt-6 pb-2">
                <h1 class="font-headings font-light text-4xl md:text-5xl leading-[1.1] mb-2 text-foreground">
                    Handeln <em class="italic text-primary">mit Handschlag</em>
                </h1>
                <p class="text-xs text-foreground/60 font-condensed uppercase tracking-widest mb-5">
                    Verifiziert · Treuhand-Schutz · Lokal
                </p>

                <!-- Search bar -->
                <div class="max-w-3xl mx-auto">
                    <form id="searchForm" method="GET" class="flex flex-col gap-2 p-2.5 bg-secondary/50 border border-foreground/[.20]">
                        <div class="flex flex-col sm:flex-row gap-2">
                            <input
                                name="query"
                                value={currentQuery}
                                placeholder="Was suchst du?"
                                class="input-field flex-grow bg-transparent"
                            />
                            <select name="category" class="input-field sm:w-48 bg-transparent">
                                <option value="">Alle Kategorien</option>
                                {
                                    categories.map((c) => (
                                        <option
                                            value={c.slug.toUpperCase()}
                                            selected={currentCat === c.slug.toUpperCase()}
                                        >
                                            {c.label}
                                        </option>
                                    ))
                                }
                            </select>
                            <button type="submit" class="btn-primary sm:w-32">
                                Suchen
                            </button>
                        </div>
                        <!-- Umkreissuche -->
                        <div class="flex flex-row gap-3 items-center">
                            <select id="radiusSelect" name="radius" class="input-field sm:w-40 bg-transparent text-sm py-2">
                                <option value="">Kein Umkreis</option>
                                <option value="5">5 km</option>
                                <option value="10">10 km</option>
                                <option value="25">25 km</option>
                                <option value="50">50 km</option>
                                <option value="100">100 km</option>
                                <option value="200">200 km</option>
                            </select>
                            <button type="button" id="geoLocateBtn" class="flex items-center gap-1.5 text-xs text-primary hover:text-primary/80 font-condensed uppercase tracking-wider transition-colors whitespace-nowrap">
                                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><circle cx="12" cy="12" r="3"></circle><line x1="12" y1="2" x2="12" y2="6"></line><line x1="12" y1="18" x2="12" y2="22"></line><line x1="2" y1="12" x2="6" y2="12"></line><line x1="18" y1="12" x2="22" y2="12"></line></svg>
                                <span id="geoLocateText">Standort</span>
                            </button>
                            <input type="hidden" name="lat" id="geoLat" />
                            <input type="hidden" name="lng" id="geoLng" />
                            <span id="geoStatus" class="text-xs text-primary/80 hidden"></span>
                        </div>
                    </form>
                </div>

                <!-- Category pills -->
                <div class="mt-3 max-w-3xl mx-auto">
                    <div class="flex gap-2 overflow-x-auto pb-1" style="scrollbar-width:none;-ms-overflow-style:none;">
                        <a href="/" class={`flex-shrink-0 px-3 py-1 text-[.7rem] font-condensed uppercase tracking-wider border transition-colors ${!currentCat ? 'border-primary text-primary bg-primary/10' : 'border-foreground/20 text-foreground/60 hover:border-foreground/40 hover:text-foreground/80'}`}>
                            Alle
                        </a>
                        {categories.map((c) => (
                            <a
                                href={`/?category=${c.slug.toUpperCase()}`}
                                class={`flex-shrink-0 px-3 py-1 text-[.7rem] font-condensed uppercase tracking-wider border transition-colors ${currentCat === c.slug.toUpperCase() ? 'border-primary text-primary bg-primary/10' : 'border-foreground/20 text-foreground/60 hover:border-foreground/40 hover:text-foreground/80'}`}
                            >
                                {c.label}
                            </a>
                        ))}
                    </div>
                </div>
            </div>

            <!-- Result summary -->
            <div class="flex justify-between items-end mb-8 border-b border-foreground/[.20] pb-4">
                <div>
                    <h2 class="text-2xl font-headings font-light text-foreground">
                        {currentQuery ? `Ergebnisse für „${currentQuery}"` : "Aktuelle Angebote"}
                    </h2>
                    <p class="text-foreground/80 text-xs mt-1.5 font-condensed font-light tracking-wider uppercase">
                        {pagination.total} Anzeige{pagination.total !== 1 ? "n" : ""} gefunden
                    </p>
                </div>
                <div class="hidden sm:flex items-center">
                    <span class="trust-badge">
                        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                        Sicher Handeln
                    </span>
                </div>
            </div>

            <!-- Listings Grid -->
            {
                listings.length > 0 ? (
                    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
                        {listings.map((l: any, i: number) => (
                            <a href={`/listing/${l.id}`} class="group block h-full">
                                <article class="bg-secondary/40 border border-foreground/[.20] overflow-hidden hover:border-primary/30 transition-all duration-300 h-full flex flex-col relative">

                                    <!-- Badges -->
                                    <div class="absolute top-2 right-2 flex flex-col gap-1.5 z-10">
                                        {l.treuhand && (
                                            <span class="bg-primary/90 backdrop-blur-sm text-primary-foreground text-[.6rem] px-1.5 py-0.5 font-condensed font-medium uppercase tracking-wider">
                                                Treuhand
                                            </span>
                                        )}
                                        {l.seller?.trustScore?.level === 'VERIFIED' && (
                                            <span class="bg-foreground/80 backdrop-blur-sm text-background text-[.6rem] px-1.5 py-0.5 font-condensed font-medium uppercase tracking-wider flex items-center gap-1">
                                                <svg class="w-2 h-2" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
                                                Verifiziert
                                            </span>
                                        )}
                                    </div>

                                    <!-- Image -->
                                    <div class="aspect-[4/3] w-full bg-secondary relative overflow-hidden flex-shrink-0">
                                        {l.images[0] ? (
                                            <img
                                                src={l.images[0].url}
                                                alt={l.title}
                                                class="w-full h-full object-cover group-hover:scale-[1.03] transition-transform duration-500 ease-out"
                                                loading={i < 4 ? "eager" : "lazy"}
                                                fetchpriority={i === 0 ? "high" : "auto"}
                                            />
                                        ) : (
                                            <div class="w-full h-full flex items-center justify-center text-foreground/75">
                                                <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                                            </div>
                                        )}
                                    </div>

                                    <!-- Content -->
                                    <div class="p-4 flex flex-col flex-grow">
                                        <div class="text-lg font-headings font-light text-primary mb-0.5">
                                            {(l.price / 100).toLocaleString("de-DE", { style: "currency", currency: "EUR" })}
                                        </div>
                                        <h3 class="font-light text-foreground/80 mb-2 line-clamp-2 leading-snug text-sm">
                                            {l.title}
                                        </h3>
                                        <div class="mt-auto pt-3 flex items-center justify-between text-[.65rem] text-foreground/80 font-condensed tracking-wider uppercase">
                                            <div class="flex items-center gap-1">
                                                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                                                {l.city}
                                            </div>
                                            <div class="text-foreground/75">
                                                {l.category}
                                            </div>
                                        </div>
                                    </div>
                                </article>
                            </a>
                        ))}
                    </div>
                ) : (
                    <div class="text-center py-24 rounded-default border border-dashed border-foreground/25">
                        <svg class="w-12 h-12 mx-auto mb-4 text-foreground/75" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
                        <h3 class="text-xl font-headings font-medium text-foreground mb-2">Keine Angebote gefunden</h3>
                        <p class="text-foreground/80 max-w-sm mx-auto font-light">
                            Versuche andere Suchbegriffe oder erweitere deine Filterkriterien.
                        </p>
                    </div>
                )
            }

            <!-- Pagination -->
            {
                totalPages > 1 && (
                    <nav class="flex items-center justify-center gap-4 mt-16 pb-8">
                        {currentPage > 1 && (
                            <a
                                href={`?${new URLSearchParams({ ...Object.fromEntries(Astro.url.searchParams), page: String(currentPage - 1) })}`}
                                class="px-5 py-2.5 border border-foreground/25 text-foreground font-condensed text-xs tracking-wider uppercase hover:border-primary hover:text-primary transition-colors"
                            >
                                ← Zurück
                            </a>
                        )}
                        <span class="text-foreground/75 font-medium text-sm px-4">
                            Seite {currentPage} von {totalPages}
                        </span>
                        {currentPage < totalPages && (
                            <a
                                href={`?${new URLSearchParams({ ...Object.fromEntries(Astro.url.searchParams), page: String(currentPage + 1) })}`}
                                class="px-5 py-2.5 border border-foreground/25 text-primary font-condensed text-xs tracking-wider uppercase hover:bg-primary hover:text-primary-foreground hover:border-primary transition-colors"
                            >
                                Weiter →
                            </a>
                        )}
                    </nav>
                )
            }
        </div>
    </main>
    <Footer />
</BaseLayout>

<script>
    const geoBtn = document.getElementById('geoLocateBtn');
    const geoText = document.getElementById('geoLocateText');
    const geoStatus = document.getElementById('geoStatus');
    const latInput = document.getElementById('geoLat') as HTMLInputElement;
    const lngInput = document.getElementById('geoLng') as HTMLInputElement;
    const radiusSelect = document.getElementById('radiusSelect') as HTMLSelectElement;

    // Restore radius from URL
    const urlParams = new URLSearchParams(window.location.search);
    if (urlParams.get('radius') && radiusSelect) {
        radiusSelect.value = urlParams.get('radius')!;
    }
    if (urlParams.get('lat') && latInput) latInput.value = urlParams.get('lat')!;
    if (urlParams.get('lng') && lngInput) lngInput.value = urlParams.get('lng')!;

    if (geoBtn) {
        geoBtn.addEventListener('click', () => {
            if (!navigator.geolocation) {
                if (geoStatus) { geoStatus.textContent = 'Geolocation nicht verfügbar'; geoStatus.classList.remove('hidden'); }
                return;
            }
            if (geoText) geoText.textContent = 'Wird ermittelt…';
            navigator.geolocation.getCurrentPosition(
                (pos) => {
                    latInput.value = String(pos.coords.latitude);
                    lngInput.value = String(pos.coords.longitude);
                    if (geoText) geoText.textContent = 'Standort erkannt';
                    if (geoStatus) { geoStatus.textContent = `${pos.coords.latitude.toFixed(2)}, ${pos.coords.longitude.toFixed(2)}`; geoStatus.classList.remove('hidden'); }
                    // Default radius if none selected
                    if (radiusSelect && !radiusSelect.value) radiusSelect.value = '25';
                },
                (err) => {
                    const msgs: Record<number, string> = { 1: 'Zugriff verweigert', 2: 'Nicht verfügbar', 3: 'Timeout' };
                    if (geoStatus) { geoStatus.textContent = msgs[err.code] || 'Fehler'; geoStatus.classList.remove('hidden'); geoStatus.style.color = '#e53e3e'; }
                    if (geoText) geoText.textContent = 'Standort nutzen';
                },
                { enableHighAccuracy: false, timeout: 10000, maximumAge: 300000 }
            );
        });
    }

    // Remove empty geo fields before submit
    document.getElementById('searchForm')?.addEventListener('submit', () => {
        if (!latInput?.value || !lngInput?.value || !radiusSelect?.value) {
            latInput.removeAttribute('name');
            lngInput.removeAttribute('name');
            if (!radiusSelect.value) radiusSelect.removeAttribute('name');
        }
    });
</script>
