---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import ServiceDetail from '../../../components/leistungstausch/ServiceDetail.astro';
import ServiceProviderCard from '../../../components/leistungstausch/ServiceProviderCard.astro';
import ServiceProposalModal from '../../../components/leistungstausch/ServiceProposalModal';
import ServiceProposalList from '../../../components/leistungstausch/ServiceProposalList';
import { lucia } from '../../../lib/auth';

const { id } = Astro.params;

const internalOrigin = import.meta.env.PROD ? `http://localhost:${import.meta.env.PORT || 3000}` : Astro.url.origin;
const res = await fetch(`${internalOrigin}/api/leistungstausch/listings/${id}`);

if (!res.ok) {
  return Astro.redirect('/leistungstausch');
}

const { listing } = await res.json();

let isOwner = false;
const sessionId = Astro.cookies.get(lucia.sessionCookieName)?.value;
if (sessionId) {
  try {
    const { user } = await lucia.validateSession(sessionId);
    if (user && user.id === listing.userId) isOwner = true;
  } catch {}
}

let matches: any[] = [];
if (isOwner) {
  try {
    const matchRes = await fetch(`${internalOrigin}/api/leistungstausch/matches?listingId=${id}`, {
      headers: { Cookie: `${lucia.sessionCookieName}=${sessionId}` },
    });
    if (matchRes.ok) {
      const matchData = await matchRes.json();
      matches = matchData.matches ?? [];
    }
  } catch {}
}

const catRes = await fetch(`${internalOrigin}/api/leistungstausch/categories`);
const { categories: allCategories } = catRes.ok ? await catRes.json() : { categories: [] };

const pageTitle = `${listing.title} — Leistungstausch | Ehren-Deal`;
const pageDesc = listing.offeredDescription.slice(0, 160);
---

<BaseLayout title={pageTitle} description={pageDesc}>
  <Header />
  <main id="main-content" class="min-h-screen bg-background">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
      <nav class="flex items-center gap-2 text-sm text-text-secondary">
        <a href="/leistungstausch" class="hover:text-teal-700 transition-colors">Leistungstausch</a>
        <span>/</span>
        <a href={`/leistungstausch?offeredCategory=${listing.offeredCategory.slug}`} class="hover:text-teal-700 transition-colors">{listing.offeredCategory.name}</a>
        <span>/</span>
        <span class="text-text truncate max-w-xs">{listing.title}</span>
      </nav>
    </div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-16">
      <div class="lt-info-banner mb-6 flex items-center gap-2">
        <svg class="w-4 h-4 text-teal-600 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path d="M11.25 11.25l.041-.02a.75.75 0 011.063.852l-.708 2.836a.75.75 0 001.063.853l.041-.021M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-9-3.75h.008v.008H12V8.25z"/></svg>
        <span>Leistungstausch — Dienstleistung gegen Dienstleistung. Ohne Geld, ohne Waren.</span>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <div class="lg:col-span-2">
          <div class="bg-surface border border-border rounded-DEFAULT p-6 sm:p-8">
            <ServiceDetail listing={listing} />
          </div>

          {/* Proposals Section */}
          <div class="bg-surface border border-border rounded-DEFAULT p-6 sm:p-8 mt-6">
            <ServiceProposalList
              client:load
              listingId={listing.id}
              isOwner={isOwner}
            />
          </div>

          {/* Matches Section (only for owner) */}
          {isOwner && matches.length > 0 && (
            <div class="bg-surface border border-teal-200 rounded-DEFAULT p-6 sm:p-8 mt-6">
              <div class="flex items-center gap-2 mb-4">
                <span class="w-8 h-8 rounded-full bg-teal-100 text-teal-700 flex items-center justify-center">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path d="M7 16V4m0 0L3 8m4-4l4 4m6 0v12m0 0l4-4m-4 4l-4-4"/></svg>
                </span>
                <h3 class="text-lg font-semibold text-text">Passende Angebote ({matches.length})</h3>
              </div>
              <p class="text-sm text-text-secondary mb-4">Diese Nutzer bieten an was du suchst — und suchen was du anbietest!</p>
              <div class="space-y-3">
                {matches.map((match: any) => {
                  const matchName = [match.user.firstName, match.user.lastName].filter(Boolean).join(' ') || 'Nutzer';
                  const matchInitial = (match.user.firstName?.[0] || 'N').toUpperCase();
                  return (
                    <a href={`/leistungstausch/angebot/${match.id}`} class="flex items-center gap-3 p-3 rounded-DEFAULT border border-border hover:border-teal-300 hover:bg-teal-50/50 transition-colors group">
                      <div class="w-10 h-10 rounded-full bg-teal-100 text-teal-700 flex items-center justify-center font-bold text-sm flex-shrink-0">
                        {matchInitial}
                      </div>
                      <div class="flex-1 min-w-0">
                        <p class="text-sm font-semibold text-text group-hover:text-teal-700 transition-colors truncate">{match.title}</p>
                        <p class="text-xs text-text-secondary">von {matchName} · {match.offeredCategory.name}</p>
                      </div>
                      <div class="flex items-center gap-1.5 flex-shrink-0">
                        <span class="text-xs font-medium text-teal-700 bg-teal-100 px-2 py-0.5 rounded-full">{match.matchScore}%</span>
                      </div>
                    </a>
                  );
                })}
              </div>
            </div>
          )}
        </div>
        <div class="lg:col-span-1">
          <div class="sticky top-20">
            <ServiceProviderCard listing={listing} isOwner={isOwner} />
          </div>
        </div>
      </div>
    </div>
  </main>
  <Footer />

  {!isOwner && (
    <div id="proposalModalMount">
      <ServiceProposalModal
        client:load
        listingId={listing.id}
        listingTitle={listing.title}
        soughtCategories={listing.soughtCategories}
        soughtDescription={listing.soughtDescription}
        categories={allCategories}
        onClose={() => {}}
      />
    </div>
  )}

  <style>
    #proposalModalMount { display: none; }
    #proposalModalMount.open { display: block; }
  </style>

  <script>
    const btn = document.getElementById('openProposalBtn');
    const mount = document.getElementById('proposalModalMount');
    if (btn && mount) {
      btn.addEventListener('click', () => mount.classList.add('open'));
      mount.addEventListener('click', (e) => {
        if (e.target === mount) mount.classList.remove('open');
      });
    }
  </script>
</BaseLayout>
