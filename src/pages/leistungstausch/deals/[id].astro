---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import ServiceDealStatus from '../../../components/leistungstausch/ServiceDealStatus';
import ServiceReviewModal from '../../../components/leistungstausch/ServiceReviewModal';
import { lucia } from '../../../lib/auth';

const { id } = Astro.params;

const sessionId = Astro.cookies.get(lucia.sessionCookieName)?.value;
if (!sessionId) return Astro.redirect('/anmelden?redirect=/leistungstausch/deals');

let authUserId: string | null = null;
try {
  const { user } = await lucia.validateSession(sessionId);
  if (!user) return Astro.redirect('/anmelden?redirect=/leistungstausch/deals');
  authUserId = user.id;
} catch {
  return Astro.redirect('/anmelden?redirect=/leistungstausch/deals');
}

const internalOrigin = import.meta.env.PROD ? `http://localhost:${import.meta.env.PORT || 3000}` : Astro.url.origin;
const res = await fetch(`${internalOrigin}/api/leistungstausch/deals/${id}`, {
  headers: { Cookie: `${lucia.sessionCookieName}=${sessionId}` },
});

if (!res.ok) return Astro.redirect('/leistungstausch/deals');

const { deal } = await res.json();
const listingTitle = deal.proposal?.serviceListing?.title ?? 'Deal';
const isPartyA = deal.partyA?.id === authUserId;
const other = isPartyA ? deal.partyB : deal.partyA;
const otherName = [other?.firstName, other?.lastName].filter(Boolean).join(' ') || 'Partner';

const hasReviewed = deal.reviews?.some((r: any) => r.reviewerId === authUserId) ?? false;
const showReviewPrompt = deal.status === 'COMPLETED' && !hasReviewed;
---

<BaseLayout title={`Deal: ${listingTitle} | Ehren-Deal`}>
  <Header />
  <main id="main-content" class="min-h-screen bg-background">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <!-- Breadcrumb -->
      <nav class="flex items-center gap-2 text-sm text-text-secondary mb-6">
        <a href="/leistungstausch" class="hover:text-teal-700 transition-colors">Leistungstausch</a>
        <span>/</span>
        <a href="/leistungstausch/deals" class="hover:text-teal-700 transition-colors">Meine Deals</a>
        <span>/</span>
        <span class="text-text truncate max-w-xs">{listingTitle}</span>
      </nav>

      <div class="lt-info-banner mb-6 flex items-center gap-2">
        <svg class="w-4 h-4 text-teal-600 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path d="M11.25 11.25l.041-.02a.75.75 0 011.063.852l-.708 2.836a.75.75 0 001.063.853l.041-.021M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-9-3.75h.008v.008H12V8.25z"/></svg>
        <span>Markiere deine Leistung als erledigt, sobald du sie erbracht hast. Der Deal ist abgeschlossen, wenn beide Seiten bestätigt haben.</span>
      </div>

      <div class="bg-surface border border-border rounded-DEFAULT p-6 sm:p-8">
        <ServiceDealStatus client:load deal={deal} currentUserId={authUserId} />
      </div>

      {/* Review Prompt */}
      {showReviewPrompt && (
        <div class="bg-teal-50 border border-teal-200 rounded-DEFAULT p-6 mt-6 text-center">
          <h3 class="text-lg font-semibold text-text mb-2">Wie war dein Deal?</h3>
          <p class="text-sm text-text-secondary mb-4">Bewerte deinen Leistungstausch mit {otherName}.</p>
          <button id="openReviewBtn" class="btn-teal">Jetzt bewerten</button>
        </div>
      )}

      {/* Dispute Button for active deals */}
      {deal.status === 'ACTIVE' && !deal.dispute && (
        <div class="mt-6 text-center">
          <button id="openDisputeBtn" class="text-sm text-text-muted hover:text-danger transition-colors">
            Problem melden
          </button>
        </div>
      )}
    </div>
  </main>
  <Footer />

  {/* Review Modal */}
  {showReviewPrompt && (
    <div id="reviewModalMount" style="display:none">
      <ServiceReviewModal
        client:load
        dealId={deal.id}
        otherName={otherName}
        onClose={() => {}}
      />
    </div>
  )}

  <script>
    const reviewBtn = document.getElementById('openReviewBtn');
    const reviewMount = document.getElementById('reviewModalMount');
    if (reviewBtn && reviewMount) {
      reviewBtn.addEventListener('click', () => reviewMount.style.display = 'block');
    }
  </script>
</BaseLayout>
