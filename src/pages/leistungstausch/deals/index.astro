---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import { lucia } from '../../../lib/auth';

const sessionId = Astro.cookies.get(lucia.sessionCookieName)?.value;
if (!sessionId) return Astro.redirect('/anmelden?redirect=/leistungstausch/deals');

let authUserId: string | null = null;
try {
  const { user } = await lucia.validateSession(sessionId);
  if (!user) return Astro.redirect('/anmelden?redirect=/leistungstausch/deals');
  authUserId = user.id;
} catch {
  return Astro.redirect('/anmelden?redirect=/leistungstausch/deals');
}

const internalOrigin = import.meta.env.PROD ? `http://localhost:${import.meta.env.PORT || 3000}` : Astro.url.origin;
const status = Astro.url.searchParams.get('status') || '';
const page = Astro.url.searchParams.get('page') || '1';

const url = new URL('/api/leistungstausch/deals', internalOrigin);
if (status) url.searchParams.set('status', status);
url.searchParams.set('page', page);

const res = await fetch(url.toString(), {
  headers: { Cookie: `${lucia.sessionCookieName}=${sessionId}` },
});
const data = res.ok ? await res.json() : { deals: [], pagination: { total: 0, totalPages: 1, page: 1 } };
const { deals, pagination } = data;

const STATUS_LABELS: Record<string, { label: string; color: string; bg: string }> = {
  ACTIVE: { label: 'Aktiv', color: '#0D9488', bg: '#F0FDFA' },
  COMPLETED: { label: 'Abgeschlossen', color: '#22A06B', bg: '#E8F5E9' },
  DISPUTED: { label: 'Dispute', color: '#DC2626', bg: '#FEE2E2' },
  CANCELLED: { label: 'Abgebrochen', color: '#64748B', bg: '#F1F5F9' },
};
---

<BaseLayout title="Meine Leistungstausch-Deals | Ehren-Deal">
  <Header />
  <main id="main-content" class="min-h-screen bg-background">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <div class="flex items-center justify-between mb-6">
        <h1 class="text-2xl font-bold text-text">Meine Leistungstausch-Deals</h1>
        <a href="/leistungstausch" class="btn-teal-ghost text-sm">Zurück zum Leistungstausch</a>
      </div>

      <!-- Status Filter -->
      <div class="flex gap-2 mb-6">
        <a href="/leistungstausch/deals" class={`px-4 py-2 rounded-full text-sm font-medium transition-colors ${!status ? 'bg-teal-600 text-white' : 'bg-background text-text-secondary hover:bg-teal-50'}`}>Alle</a>
        <a href="/leistungstausch/deals?status=ACTIVE" class={`px-4 py-2 rounded-full text-sm font-medium transition-colors ${status === 'ACTIVE' ? 'bg-teal-600 text-white' : 'bg-background text-text-secondary hover:bg-teal-50'}`}>Aktiv</a>
        <a href="/leistungstausch/deals?status=COMPLETED" class={`px-4 py-2 rounded-full text-sm font-medium transition-colors ${status === 'COMPLETED' ? 'bg-teal-600 text-white' : 'bg-background text-text-secondary hover:bg-teal-50'}`}>Abgeschlossen</a>
        <a href="/leistungstausch/deals?status=CANCELLED" class={`px-4 py-2 rounded-full text-sm font-medium transition-colors ${status === 'CANCELLED' ? 'bg-teal-600 text-white' : 'bg-background text-text-secondary hover:bg-teal-50'}`}>Abgebrochen</a>
      </div>

      {deals.length > 0 ? (
        <div class="space-y-4">
          {deals.map((deal: any) => {
            const isPartyA = deal.partyAId === authUserId;
            const other = isPartyA ? deal.partyB : deal.partyA;
            const otherName = [other.firstName, other.lastName].filter(Boolean).join(' ') || 'Nutzer';
            const otherInitial = (other.firstName?.[0] || 'N').toUpperCase();
            const statusCfg = STATUS_LABELS[deal.status] ?? STATUS_LABELS.ACTIVE;
            const date = new Date(deal.createdAt).toLocaleDateString('de-DE', { day: 'numeric', month: 'short' });
            const title = deal.proposal?.serviceListing?.title ?? 'Deal';

            return (
              <a href={`/leistungstausch/deals/${deal.id}`} class="lt-card block p-5 group">
                <div class="flex items-center justify-between">
                  <div class="flex items-center gap-3">
                    <div class="w-10 h-10 rounded-full bg-teal-100 text-teal-700 flex items-center justify-center font-bold text-sm">
                      {otherInitial}
                    </div>
                    <div>
                      <h3 class="text-sm font-semibold text-text group-hover:text-teal-700 transition-colors">{title}</h3>
                      <p class="text-xs text-text-secondary">mit {otherName} · {date}</p>
                    </div>
                  </div>
                  <div class="flex items-center gap-3">
                    <div class="text-right hidden sm:block">
                      <div class="flex gap-1">
                        <span class={`w-2 h-2 rounded-full ${deal.partyACompleted ? 'bg-green-500' : 'bg-gray-300'}`}></span>
                        <span class={`w-2 h-2 rounded-full ${deal.partyBCompleted ? 'bg-green-500' : 'bg-gray-300'}`}></span>
                      </div>
                    </div>
                    <span class="text-xs font-medium px-2.5 py-1 rounded-full" style={`background-color:${statusCfg.bg};color:${statusCfg.color}`}>
                      {statusCfg.label}
                    </span>
                  </div>
                </div>
              </a>
            );
          })}
        </div>
      ) : (
        <div class="text-center py-16">
          <div class="w-14 h-14 rounded-full bg-teal-100 text-teal-600 flex items-center justify-center mx-auto mb-4">
            <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path d="M7 16V4m0 0L3 8m4-4l4 4m6 0v12m0 0l4-4m-4 4l-4-4"/></svg>
          </div>
          <h2 class="text-lg font-semibold text-text mb-2">Noch keine Deals</h2>
          <p class="text-text-secondary text-sm mb-4">Starte deinen ersten Leistungstausch!</p>
          <a href="/leistungstausch" class="btn-teal">Angebote entdecken</a>
        </div>
      )}
    </div>
  </main>
  <Footer />
</BaseLayout>
