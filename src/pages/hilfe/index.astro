---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";

const categories = [
    {
        title: "Erste Schritte",
        description: "Registrierung, Verifizierung und dein erster Deal auf Ehren-Deal.",
        href: "/hilfe/erste-schritte",
        icon: `<path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/>`,
    },
    {
        title: "Kaufen",
        description: "So kaufst du sicher ein und nutzt den Treuhand-Schutz als Kaeufer.",
        href: "/hilfe/kaufen",
        icon: `<circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>`,
    },
    {
        title: "Verkaufen",
        description: "Inserate erstellen, Tipps fuer gute Angebote und Auszahlungen.",
        href: "/hilfe/verkaufen",
        icon: `<line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>`,
    },
    {
        title: "Zahlung & Treuhand",
        description: "Zahlungsmethoden, Treuhand-Ablauf, Gebuehren und Rueckerstattungen.",
        href: "/hilfe/zahlung",
        icon: `<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>`,
    },
    {
        title: "Sicherheit & Verifizierung",
        description: "KYC-Pruefung, Betrugsschutz und wie Ehren-Deal dich absichert.",
        href: "/hilfe/sicherheit",
        icon: `<rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>`,
    },
    {
        title: "Account & Einstellungen",
        description: "Profil bearbeiten, Passwort aendern und Konto-Einstellungen.",
        href: "/einstellungen",
        icon: `<circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/>`,
    },
];
---

<BaseLayout title="Hilfe-Center – Ehren-Deal" description="Finde Antworten auf deine Fragen rund um Ehren-Deal. Hilfe zu Kauf, Verkauf, Zahlung, Treuhand und Sicherheit." canonicalPath="/hilfe">
    <Header />
    <main id="main-content" class="min-h-screen pt-12 pb-24 bg-background">
        <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">

            <!-- Breadcrumb -->
            <nav aria-label="Breadcrumb" class="mb-8">
                <ol class="flex items-center gap-2 text-sm text-text-secondary">
                    <li><a href="/" class="hover:text-primary transition-colors">Startseite</a></li>
                    <li class="flex items-center gap-2">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"></polyline></svg>
                        <span class="text-text font-medium">Hilfe-Center</span>
                    </li>
                </ol>
            </nav>

            <!-- Header -->
            <div class="mb-12">
                <h1 class="text-4xl md:text-5xl font-bold text-primary mb-3">Hilfe-Center</h1>
                <p class="text-text-secondary text-lg max-w-2xl">
                    Wie koennen wir dir helfen? Finde Antworten auf haeufige Fragen oder durchsuche unsere Hilfe-Themen.
                </p>
            </div>

            <!-- Search -->
            <div class="mb-16">
                <div class="card p-6">
                    <div class="relative">
                        <svg class="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-text-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                            <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
                        </svg>
                        <input
                            type="text"
                            id="hilfe-search"
                            placeholder="Suche nach Themen, z.B. Treuhand, Verifizierung, Rueckerstattung ..."
                            class="input-field pl-12 w-full"
                        />
                    </div>
                </div>
            </div>

            <!-- Category Cards -->
            <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 mb-20">
                {categories.map((cat) => (
                    <a href={cat.href} class="card p-6 hover:border-primary/30 transition-all duration-300 group">
                        <div class="w-10 h-10 rounded-full bg-primary-light flex items-center justify-center mb-4">
                            <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5" set:html={cat.icon} />
                        </div>
                        <h2 class="text-sm font-semibold text-text mb-2 group-hover:text-primary transition-colors">{cat.title}</h2>
                        <p class="text-sm text-text-secondary leading-relaxed">{cat.description}</p>
                        <span class="inline-flex items-center gap-1 text-xs text-primary mt-4 font-medium">
                            Mehr erfahren
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"></polyline></svg>
                        </span>
                    </a>
                ))}
            </div>

            <!-- Contact CTA -->
            <div class="border-t border-border pt-12">
                <div class="card p-8 text-center">
                    <div class="w-12 h-12 rounded-full bg-primary-light flex items-center justify-center mx-auto mb-4">
                        <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                            <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
                        </svg>
                    </div>
                    <h2 class="text-lg font-semibold text-text mb-2">Keine Antwort gefunden?</h2>
                    <p class="text-sm text-text-secondary mb-6 max-w-md mx-auto">
                        Unser Support-Team hilft dir gerne persoenlich weiter. Schreib uns eine Nachricht oder ruf uns an.
                    </p>
                    <div class="flex flex-col sm:flex-row gap-3 justify-center">
                        <a href="/kontakt" class="btn btn-primary px-6">Kontakt aufnehmen</a>
                        <a href="https://wa.me/4915757126123" target="_blank" rel="noopener noreferrer" class="btn btn-outline px-6">WhatsApp schreiben</a>
                    </div>
                </div>
            </div>

        </div>
    </main>
    <Footer />
</BaseLayout>

<script>
    const searchInput = document.getElementById('hilfe-search') as HTMLInputElement | null;
    const cards = document.querySelectorAll<HTMLAnchorElement>('.grid a.card');

    if (searchInput) {
        searchInput.addEventListener('input', () => {
            const query = searchInput.value.toLowerCase().trim();
            cards.forEach((card) => {
                const text = card.textContent?.toLowerCase() ?? '';
                card.style.display = query === '' || text.includes(query) ? '' : 'none';
            });
        });
    }
</script>
