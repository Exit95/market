---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
---

<BaseLayout title="Erfolgreich verkaufen – Hilfe-Center – Ehren-Deal" description="Tipps zum Verkaufen auf Ehren-Deal: Inserate erstellen, gute Fotos, Auszahlungen und Gebuehren." canonicalPath="/hilfe/verkaufen">
    <Header />
    <main id="main-content" class="min-h-screen pt-12 pb-24 bg-background">
        <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">

            <!-- Breadcrumb -->
            <nav aria-label="Breadcrumb" class="mb-8">
                <ol class="flex items-center gap-2 text-sm text-text-secondary">
                    <li><a href="/" class="hover:text-primary transition-colors">Startseite</a></li>
                    <li class="flex items-center gap-2">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"></polyline></svg>
                        <a href="/hilfe" class="hover:text-primary transition-colors">Hilfe-Center</a>
                    </li>
                    <li class="flex items-center gap-2">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"></polyline></svg>
                        <span class="text-text font-medium">Verkaufen</span>
                    </li>
                </ol>
            </nav>

            <!-- Header -->
            <div class="mb-12">
                <h1 class="text-4xl md:text-5xl font-bold text-primary mb-3">Erfolgreich verkaufen</h1>
                <p class="text-text-secondary text-lg max-w-2xl">
                    So erstellst du ansprechende Inserate, erreichst mehr Kaeufer und erhaeltst dein Geld sicher und zuverlaessig.
                </p>
            </div>

            <!-- Tips Box -->
            <div class="card p-6 md:p-8 mb-10">
                <h2 class="text-lg font-semibold text-text mb-4">Schnelltipps fuer mehr Verkaufserfolg</h2>
                <div class="grid sm:grid-cols-2 gap-4">
                    <div class="flex items-start gap-3">
                        <svg class="w-5 h-5 text-success flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><polyline points="20 6 9 17 4 12"></polyline></svg>
                        <p class="text-sm text-text-secondary">Verwende aussagekraeftige Titel mit Marke und Zustand</p>
                    </div>
                    <div class="flex items-start gap-3">
                        <svg class="w-5 h-5 text-success flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><polyline points="20 6 9 17 4 12"></polyline></svg>
                        <p class="text-sm text-text-secondary">Lade mindestens 3 Fotos bei gutem Licht hoch</p>
                    </div>
                    <div class="flex items-start gap-3">
                        <svg class="w-5 h-5 text-success flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><polyline points="20 6 9 17 4 12"></polyline></svg>
                        <p class="text-sm text-text-secondary">Setze einen fairen, marktgerechten Preis</p>
                    </div>
                    <div class="flex items-start gap-3">
                        <svg class="w-5 h-5 text-success flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><polyline points="20 6 9 17 4 12"></polyline></svg>
                        <p class="text-sm text-text-secondary">Antworte schnell auf Nachrichten von Interessenten</p>
                    </div>
                </div>
            </div>

            <!-- FAQ Accordion -->
            <div class="space-y-4" id="faq-accordion">

                <!-- FAQ 1 -->
                <div class="card overflow-hidden">
                    <button class="faq-toggle w-full flex items-center justify-between p-5 text-left" aria-expanded="false">
                        <span class="text-sm font-semibold text-text pr-4">Wie erstelle ich ein Inserat?</span>
                        <svg class="faq-chevron w-5 h-5 text-text-muted flex-shrink-0 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><polyline points="6 9 12 15 18 9"></polyline></svg>
                    </button>
                    <div class="faq-content hidden px-5 pb-5">
                        <div class="text-sm text-text-secondary leading-relaxed space-y-3 border-t border-border pt-4">
                            <p>Ein Inserat auf Ehren-Deal zu erstellen ist einfach und kostenlos:</p>
                            <ol class="list-decimal list-inside space-y-2 pl-1">
                                <li>Klicke auf <strong>"Inserat erstellen"</strong> in der Navigation oder besuche direkt die <a href="/inserat-erstellen" class="text-primary hover:underline">Inseratseite</a>.</li>
                                <li><strong>Titel:</strong> Waehle einen klaren, beschreibenden Titel (z.B. "Samsung Galaxy S24 Ultra, 256GB, wie neu").</li>
                                <li><strong>Beschreibung:</strong> Beschreibe den Artikel detailliert. Erwaehne Zustand, Maengel, Zubehoer und Besonderheiten.</li>
                                <li><strong>Fotos:</strong> Lade mindestens ein Foto hoch. Mehr Fotos erhoehen die Verkaufschancen deutlich.</li>
                                <li><strong>Kategorie:</strong> Waehle die passende Kategorie, damit Kaeufer deinen Artikel finden.</li>
                                <li><strong>Preis:</strong> Lege deinen Verkaufspreis fest. Du kannst auch "Verhandlungsbasis" angeben.</li>
                                <li><strong>Veroeffentlichen:</strong> Pruefe alle Angaben und veroeffentliche dein Inserat.</li>
                            </ol>
                            <p>Dein Inserat ist sofort auf dem Marktplatz sichtbar. Du kannst es jederzeit in deinem <a href="/dashboard/listings" class="text-primary hover:underline">Dashboard</a> bearbeiten oder deaktivieren.</p>
                        </div>
                    </div>
                </div>

                <!-- FAQ 2 -->
                <div class="card overflow-hidden">
                    <button class="faq-toggle w-full flex items-center justify-between p-5 text-left" aria-expanded="false">
                        <span class="text-sm font-semibold text-text pr-4">Tipps fuer gute Produktfotos</span>
                        <svg class="faq-chevron w-5 h-5 text-text-muted flex-shrink-0 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><polyline points="6 9 12 15 18 9"></polyline></svg>
                    </button>
                    <div class="faq-content hidden px-5 pb-5">
                        <div class="text-sm text-text-secondary leading-relaxed space-y-3 border-t border-border pt-4">
                            <p>Gute Fotos sind der wichtigste Faktor fuer einen erfolgreichen Verkauf. Beachte diese Tipps:</p>
                            <p><strong>Beleuchtung:</strong></p>
                            <ul class="list-disc list-inside space-y-2 pl-1">
                                <li>Fotografiere bei Tageslicht oder guter Beleuchtung - keine dunklen, koernigen Bilder.</li>
                                <li>Vermeide direktes Blitzlicht, da es Spiegelungen und unnatuerliche Schatten erzeugt.</li>
                            </ul>
                            <p><strong>Perspektiven:</strong></p>
                            <ul class="list-disc list-inside space-y-2 pl-1">
                                <li>Zeige den Artikel von mehreren Seiten (vorne, hinten, seitlich, Detail).</li>
                                <li>Fotografiere Maengel, Kratzer oder Gebrauchsspuren ehrlich - das schafft Vertrauen.</li>
                                <li>Zeige das mitgelieferte Zubehoer separat.</li>
                            </ul>
                            <p><strong>Hintergrund:</strong></p>
                            <ul class="list-disc list-inside space-y-2 pl-1">
                                <li>Nutze einen neutralen, aufgeraeuemten Hintergrund (weiss, helles Holz).</li>
                                <li>Vermeide unruhige Umgebungen, die vom Artikel ablenken.</li>
                            </ul>
                            <p><strong>Empfehlung:</strong> Lade mindestens 3-5 Fotos hoch. Inserate mit mehreren Bildern verkaufen sich bis zu 3x schneller.</p>
                        </div>
                    </div>
                </div>

                <!-- FAQ 3 -->
                <div class="card overflow-hidden">
                    <button class="faq-toggle w-full flex items-center justify-between p-5 text-left" aria-expanded="false">
                        <span class="text-sm font-semibold text-text pr-4">Wie funktioniert die Auszahlung?</span>
                        <svg class="faq-chevron w-5 h-5 text-text-muted flex-shrink-0 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><polyline points="6 9 12 15 18 9"></polyline></svg>
                    </button>
                    <div class="faq-content hidden px-5 pb-5">
                        <div class="text-sm text-text-secondary leading-relaxed space-y-3 border-t border-border pt-4">
                            <p>Die Auszahlung nach einem erfolgreichen Verkauf laeuft automatisch ueber unseren Zahlungspartner Mangopay:</p>
                            <ol class="list-decimal list-inside space-y-2 pl-1">
                                <li>Der Kaeufer zahlt den Kaufpreis auf das Treuhandkonto.</li>
                                <li>Du versendest die Ware und teilst die Sendungsnummer mit.</li>
                                <li>Der Kaeufer erhaelt die Ware und bestaetigt den Empfang.</li>
                                <li>Der Verkaufspreis abzueglich der Servicegebuehr (<strong>5% vom Verkaufspreis</strong>) wird auf dein Mangopay-Wallet ausgezahlt.</li>
                                <li>Von dort kannst du das Geld jederzeit auf dein Bankkonto ueberweisen.</li>
                            </ol>
                            <p><strong>Voraussetzung fuer Auszahlungen:</strong> Du musst die KYC-Verifizierung abgeschlossen und ein Bankkonto in deinem Profil hinterlegt haben.</p>
                        </div>
                    </div>
                </div>

                <!-- FAQ 4 -->
                <div class="card overflow-hidden">
                    <button class="faq-toggle w-full flex items-center justify-between p-5 text-left" aria-expanded="false">
                        <span class="text-sm font-semibold text-text pr-4">Wann bekomme ich mein Geld?</span>
                        <svg class="faq-chevron w-5 h-5 text-text-muted flex-shrink-0 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><polyline points="6 9 12 15 18 9"></polyline></svg>
                    </button>
                    <div class="faq-content hidden px-5 pb-5">
                        <div class="text-sm text-text-secondary leading-relaxed space-y-3 border-t border-border pt-4">
                            <p>Die Auszahlung erfolgt, sobald der Deal abgeschlossen ist. Hier die Zeitraeueme im ueberblick:</p>
                            <div class="overflow-x-auto mt-2">
                                <table class="w-full text-sm">
                                    <thead>
                                        <tr class="border-b border-border">
                                            <th class="text-left py-2 pr-4 font-semibold text-text">Schritt</th>
                                            <th class="text-left py-2 font-semibold text-text">Zeitraum</th>
                                        </tr>
                                    </thead>
                                    <tbody class="text-text-secondary">
                                        <tr class="border-b border-border/50">
                                            <td class="py-2 pr-4">Kaeufer bestaetigt Erhalt</td>
                                            <td class="py-2">Sofort nach Bestaetigung</td>
                                        </tr>
                                        <tr class="border-b border-border/50">
                                            <td class="py-2 pr-4">Automatische Bestaetigung</td>
                                            <td class="py-2">48 Stunden nach Zustellung</td>
                                        </tr>
                                        <tr class="border-b border-border/50">
                                            <td class="py-2 pr-4">Gutschrift auf Mangopay-Wallet</td>
                                            <td class="py-2">Sofort nach Deal-Abschluss</td>
                                        </tr>
                                        <tr>
                                            <td class="py-2 pr-4">Ueberweisung auf Bankkonto</td>
                                            <td class="py-2">1-3 Werktage</td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                            <p class="mt-3"><strong>Tipp:</strong> Versende zuegig und teile dem Kaeufer die Sendungsnummer mit. So wird der Deal schneller abgeschlossen und du erhaeltst dein Geld frueher.</p>
                        </div>
                    </div>
                </div>

            </div>

            <!-- Back to Hilfe-Center -->
            <div class="mt-12 pt-8 border-t border-border flex flex-col sm:flex-row items-center justify-between gap-4">
                <a href="/hilfe" class="text-sm text-primary hover:underline flex items-center gap-2">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"></polyline></svg>
                    Zurueck zum Hilfe-Center
                </a>
                <a href="/kontakt" class="btn btn-outline text-sm px-5">Kontakt aufnehmen</a>
            </div>

        </div>
    </main>
    <Footer />
</BaseLayout>

<script>
    document.querySelectorAll('.faq-toggle').forEach((btn) => {
        btn.addEventListener('click', () => {
            const expanded = btn.getAttribute('aria-expanded') === 'true';
            btn.setAttribute('aria-expanded', String(!expanded));
            const content = btn.nextElementSibling as HTMLElement | null;
            const chevron = btn.querySelector('.faq-chevron') as HTMLElement | null;
            if (content) content.classList.toggle('hidden', expanded);
            if (chevron) chevron.style.transform = expanded ? '' : 'rotate(180deg)';
        });
    });
</script>
