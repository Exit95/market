generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum ListingStatus {
  DRAFT
  ACTIVE
  RESERVED
  SOLD
  DEACTIVATED
  DELETED
}

enum ListingCondition {
  NEW
  LIKE_NEW
  GOOD
  ACCEPTABLE
  DEFECTIVE
}

enum PriceType {
  FIXED
  NEGOTIABLE
  FREE
}

enum DealStatus {
  INQUIRY
  NEGOTIATING
  RESERVED
  AGREED
  PAID
  SHIPPED
  HANDED_OVER
  COMPLETED
  CANCELED
  CONFLICT
}

enum DealType {
  PICKUP
  SHIPPING
  DIGITAL
}

enum ReportTargetType {
  USER
  LISTING
  REVIEW
  MESSAGE
}

enum ReportReason {
  SCAM
  FAKE
  OFFENSIVE
  PROHIBITED
  MISLEADING
  DUPLICATE
  HARASSMENT
  SPAM
  OTHER
}

enum ReportStatus {
  PENDING
  REVIEWING
  RESOLVED
  DISMISSED
}

enum VerificationType {
  EMAIL
  PHONE
  IDENTITY
}

enum VerificationStatus {
  PENDING
  VERIFIED
  REJECTED
  EXPIRED
}

enum NotificationType {
  MESSAGE
  DEAL_UPDATE
  REVIEW
  LISTING_UPDATE
  SYSTEM
  MODERATION
}

enum TrustLevel {
  NEW
  CONFIRMED
  VERIFIED
  TRUSTED
  IDENTIFIED
}

enum MessageType {
  TEXT
  IMAGE
  SYSTEM
  DEAL_ACTION
}

enum UserRole {
  USER
  MODERATOR
  ADMIN
}

model User {
  id           String   @id @default(uuid()) @db.VarChar(36)
  email        String   @unique @db.VarChar(255)
  passwordHash String   @db.VarChar(255)
  role         UserRole @default(USER)
  createdAt    DateTime @default(now()) @db.DateTime(3)
  updatedAt    DateTime @updatedAt @db.DateTime(3)

  profile Profile?
}

model Profile {
  id                   String     @id @default(uuid()) @db.VarChar(36)
  userId               String     @unique @db.VarChar(36)
  displayName          String     @db.VarChar(100)
  avatarUrl            String?    @db.VarChar(500)
  bio                  String?    @db.Text
  city                 String?    @db.VarChar(100)
  postalCode           String?    @db.VarChar(10)
  locationLat          Float?
  locationLng          Float?
  trustLevel           TrustLevel @default(NEW)
  avgRating            Float      @default(0)
  totalDeals           Int        @default(0)
  responseTimeMinutes  Int?
  isBlocked            Boolean    @default(false)
  blockedReason        String?    @db.VarChar(500)
  onboardingCompleted  Boolean    @default(false)
  createdAt            DateTime   @default(now()) @db.DateTime(3)
  updatedAt            DateTime   @updatedAt @db.DateTime(3)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  listings             Listing[]
  favorites            Favorite[]
  conversationsAsBuyer Conversation[]    @relation("BuyerConversations")
  conversationsAsSeller Conversation[]   @relation("SellerConversations")
  messages             Message[]
  dealsAsBuyer         Deal[]            @relation("BuyerDeals")
  dealsAsSeller        Deal[]            @relation("SellerDeals")
  dealStatusChanges    DealStatusHistory[]
  reviewsGiven         Review[]          @relation("ReviewsGiven")
  reviewsReceived      Review[]          @relation("ReviewsReceived")
  reviewsRemoved       Review[]          @relation("ReviewsRemoved")
  reports              Report[]          @relation("ReportsCreated")
  reportsReviewed      Report[]          @relation("ReportsReviewed")
  notifications        Notification[]
  blockedUsers         BlockedUser[]     @relation("Blocker")
  blockedByUsers       BlockedUser[]     @relation("Blocked")
  verifications        Verification[]
}

model Verification {
  id         String             @id @default(uuid()) @db.VarChar(36)
  userId     String             @db.VarChar(36)
  type       VerificationType
  status     VerificationStatus @default(PENDING)
  verifiedAt DateTime?          @db.DateTime(3)
  expiresAt  DateTime?          @db.DateTime(3)
  metadata   Json?
  createdAt  DateTime           @default(now()) @db.DateTime(3)
  updatedAt  DateTime           @updatedAt @db.DateTime(3)

  profile Profile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
}

model Category {
  id        String   @id @default(uuid()) @db.VarChar(36)
  name      String   @db.VarChar(100)
  slug      String   @unique @db.VarChar(100)
  icon      String?  @db.VarChar(50)
  parentId  String?  @db.VarChar(36)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now()) @db.DateTime(3)

  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children Category[] @relation("CategoryTree")
  listings Listing[]
}

model Listing {
  id                String           @id @default(uuid()) @db.VarChar(36)
  sellerId          String           @db.VarChar(36)
  categoryId        String           @db.VarChar(36)
  title             String           @db.VarChar(200)
  description       String           @db.Text
  price             Int
  currency          String           @default("EUR") @db.VarChar(3)
  priceType         PriceType        @default(FIXED)
  condition         ListingCondition
  city              String?          @db.VarChar(100)
  postalCode        String?          @db.VarChar(10)
  locationLat       Float?
  locationLng       Float?
  shippingAvailable Boolean          @default(false)
  pickupAvailable   Boolean          @default(true)
  status            ListingStatus    @default(ACTIVE)
  viewCount         Int              @default(0)
  aiQualityScore    Float?
  aiRiskScore       Float?
  aiSuggestions     Json?
  createdAt         DateTime         @default(now()) @db.DateTime(3)
  updatedAt         DateTime         @updatedAt @db.DateTime(3)

  seller        Profile         @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  category      Category        @relation(fields: [categoryId], references: [id])
  images        ListingImage[]
  favorites     Favorite[]
  conversations Conversation[]
  deals         Deal[]

  @@index([status, createdAt])
  @@index([sellerId])
  @@index([categoryId])
  @@index([city])
}

model ListingImage {
  id        String   @id @default(uuid()) @db.VarChar(36)
  listingId String   @db.VarChar(36)
  url       String   @db.VarChar(500)
  position  Int      @default(0)
  createdAt DateTime @default(now()) @db.DateTime(3)

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
}

model Favorite {
  id        String   @id @default(uuid()) @db.VarChar(36)
  userId    String   @db.VarChar(36)
  listingId String   @db.VarChar(36)
  createdAt DateTime @default(now()) @db.DateTime(3)

  user    Profile @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([userId, listingId])
}

model Conversation {
  id            String   @id @default(uuid()) @db.VarChar(36)
  listingId     String   @db.VarChar(36)
  buyerId       String   @db.VarChar(36)
  sellerId      String   @db.VarChar(36)
  dealId        String?  @db.VarChar(36)
  lastMessageAt DateTime? @db.DateTime(3)
  createdAt     DateTime @default(now()) @db.DateTime(3)

  listing  Listing   @relation(fields: [listingId], references: [id], onDelete: Cascade)
  buyer    Profile   @relation("BuyerConversations", fields: [buyerId], references: [id], onDelete: Cascade)
  seller   Profile   @relation("SellerConversations", fields: [sellerId], references: [id], onDelete: Cascade)
  messages Message[]
  deals    Deal[]

  @@unique([listingId, buyerId])
}

model Message {
  id             String      @id @default(uuid()) @db.VarChar(36)
  conversationId String      @db.VarChar(36)
  senderId       String      @db.VarChar(36)
  body           String      @db.Text
  messageType    MessageType @default(TEXT)
  metadata       Json?
  readAt         DateTime?   @db.DateTime(3)
  createdAt      DateTime    @default(now()) @db.DateTime(3)

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       Profile      @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

model Deal {
  id              String     @id @default(uuid()) @db.VarChar(36)
  listingId       String     @db.VarChar(36)
  buyerId         String     @db.VarChar(36)
  sellerId        String     @db.VarChar(36)
  conversationId  String?    @db.VarChar(36)
  status          DealStatus @default(INQUIRY)
  dealType        DealType   @default(PICKUP)
  agreedPrice     Int?
  trackingNumber  String?    @db.VarChar(100)
  buyerConfirmed  Boolean?
  sellerConfirmed Boolean?
  completedAt     DateTime?  @db.DateTime(3)
  canceledAt      DateTime?  @db.DateTime(3)
  cancelReason    String?    @db.Text
  createdAt       DateTime   @default(now()) @db.DateTime(3)
  updatedAt       DateTime   @updatedAt @db.DateTime(3)

  listing       Listing             @relation(fields: [listingId], references: [id], onDelete: Cascade)
  buyer         Profile             @relation("BuyerDeals", fields: [buyerId], references: [id], onDelete: Cascade)
  seller        Profile             @relation("SellerDeals", fields: [sellerId], references: [id], onDelete: Cascade)
  conversation  Conversation?       @relation(fields: [conversationId], references: [id])
  statusHistory DealStatusHistory[]
  reviews       Review[]
}

model DealStatusHistory {
  id          String      @id @default(uuid()) @db.VarChar(36)
  dealId      String      @db.VarChar(36)
  oldStatus   DealStatus?
  newStatus   DealStatus
  changedById String      @db.VarChar(36)
  note        String?     @db.Text
  createdAt   DateTime    @default(now()) @db.DateTime(3)

  deal      Deal    @relation(fields: [dealId], references: [id], onDelete: Cascade)
  changedBy Profile @relation(fields: [changedById], references: [id], onDelete: Cascade)
}

model Review {
  id            String   @id @default(uuid()) @db.VarChar(36)
  dealId        String   @db.VarChar(36)
  reviewerId    String   @db.VarChar(36)
  revieweeId    String   @db.VarChar(36)
  rating        Int
  text          String?  @db.Text
  visibleAt     DateTime? @db.DateTime(3)
  isRemoved     Boolean  @default(false)
  removedReason String?  @db.Text
  removedById   String?  @db.VarChar(36)
  createdAt     DateTime @default(now()) @db.DateTime(3)

  deal      Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  reviewer  Profile  @relation("ReviewsGiven", fields: [reviewerId], references: [id], onDelete: Cascade)
  reviewee  Profile  @relation("ReviewsReceived", fields: [revieweeId], references: [id], onDelete: Cascade)
  removedBy Profile? @relation("ReviewsRemoved", fields: [removedById], references: [id])

  @@unique([dealId, reviewerId])
}

model Report {
  id             String           @id @default(uuid()) @db.VarChar(36)
  reporterId     String           @db.VarChar(36)
  targetType     ReportTargetType
  targetId       String           @db.VarChar(36)
  reason         ReportReason
  description    String?          @db.Text
  status         ReportStatus     @default(PENDING)
  reviewedById   String?          @db.VarChar(36)
  reviewedAt     DateTime?        @db.DateTime(3)
  resolutionNote String?          @db.Text
  createdAt      DateTime         @default(now()) @db.DateTime(3)

  reporter   Profile  @relation("ReportsCreated", fields: [reporterId], references: [id], onDelete: Cascade)
  reviewedBy Profile? @relation("ReportsReviewed", fields: [reviewedById], references: [id])
}

model Notification {
  id        String           @id @default(uuid()) @db.VarChar(36)
  userId    String           @db.VarChar(36)
  type      NotificationType
  title     String           @db.VarChar(200)
  body      String           @db.Text
  data      Json?
  readAt    DateTime?        @db.DateTime(3)
  createdAt DateTime         @default(now()) @db.DateTime(3)

  user Profile @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model BlockedUser {
  id        String   @id @default(uuid()) @db.VarChar(36)
  blockerId String   @db.VarChar(36)
  blockedId String   @db.VarChar(36)
  createdAt DateTime @default(now()) @db.DateTime(3)

  blocker Profile @relation("Blocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked Profile @relation("Blocked", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
}

model PasswordResetToken {
  id        String   @id @default(uuid()) @db.VarChar(36)
  userId    String   @db.VarChar(36)
  token     String   @unique @db.VarChar(100)
  expiresAt DateTime @db.DateTime(3)
  usedAt    DateTime? @db.DateTime(3)
  createdAt DateTime @default(now()) @db.DateTime(3)

  @@index([token])
  @@index([userId])
}

model PushToken {
  id        String   @id @default(uuid()) @db.VarChar(36)
  userId    String   @db.VarChar(36)
  token     String   @unique @db.VarChar(500)
  platform  String   @db.VarChar(10)
  createdAt DateTime @default(now()) @db.DateTime(3)
  updatedAt DateTime @updatedAt @db.DateTime(3)

  @@index([userId])
}

model AiCheck {
  id         String   @id @default(uuid()) @db.VarChar(36)
  checkType  String   @db.VarChar(50)
  targetType String   @db.VarChar(50)
  targetId   String   @db.VarChar(36)
  score      Float?
  result     Json
  flagged    Boolean  @default(false)
  reviewed   Boolean  @default(false)
  createdAt  DateTime @default(now()) @db.DateTime(3)
}
